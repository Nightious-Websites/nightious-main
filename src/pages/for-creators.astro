    description:
      "Something specific to your workflow? Custom integrations, hybrid solutions, and consulting.",
    features: ['Custom integrations', 'Workflow solutions', 'Consulting'],
  },
  {
    slug: 'training-documentation',
    title: 'Training & Documentation',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />',
    tier: 'compact' as const,
    description:
      'Learn your tools properly. Custom training and documentation for any service or platform.',
    features: ['Tool training', 'Custom guides', 'Platform onboarding'],
  },
]

const heroService = services.find(s => s.tier === 'hero')!
const standardServices = services.filter(s => s.tier === 'standard')
const compactServices = services.filter(s => s.tier === 'compact')

const crossSellBundles = [
  { href: '/for-businesses', label: 'For Businesses', accentRgb: '59, 130, 246', count: 10 },
  { href: '/for-individuals', label: 'For Individuals', accentRgb: '34, 197, 94', count: 5 },
]
---

<BundleLayout
  title="Tech & Growth Tools for Content Creators | Nightious"
  description="9 services tailored for content creators. Streaming setup, web presence, audience growth, privacy, and more."
  audience="Creators"
  accentColor={accentColor}
  accentRgb={accentRgb}
  ogImage="/images/og/og-for-creators.png"
>
  <BundleHero
    slot="hero"
    audience="Creators"
    headline="Level up your content"
    tagline="tailored to help creators grow and go professional."
    accentRgb={accentRgb}
    serviceCount={services.length}
  />
  <LivingGrid
    slot="grid"
    heroService={heroService}
    standardServices={standardServices}
    compactServices={compactServices}
    accentRgb={accentRgb}
    columnCount={3}
  />
  <CrossSell slot="crosssell" bundles={crossSellBundles} />
</BundleLayout>
