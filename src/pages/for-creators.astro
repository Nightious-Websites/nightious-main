---
import BundleLayout from '@/layouts/BundleLayout.astro'
import BundleHero from '@/components/sections/BundleHero.astro'
import { type WalkthroughSection } from '@/components/sections/BundleWalkthrough.astro'
import ServiceTour, { type TourStep } from '@/components/sections/ServiceTour.astro'
import CrossSell from '@/components/sections/CrossSell.astro'

const accentRgb = '236, 72, 153'
const accentColor = '#ec4899'

// 6 sections covering all 9 services
const sections: WalkthroughSection[] = [
  // ── 1. Streaming Consultation — cinematic flagship ───────────────
  {
    format: 'cinematic',
    bgImage: '/images/photos/service-streaming-consultation-hero.webp',
    problem: {
      headline: 'Your content quality is limiting your growth',
      description:
        "You have the ideas, the personality, and the consistency — but the production tells a different story. Choppy audio, laggy stream, overlays that look rushed. Viewers form an impression in the first ten seconds, and platforms amplify the creators that clear that bar.",
      painPoints: [
        'Stream drops, lag, and sync issues during live sessions',
        'Hardware and software decisions made without a clear technical roadmap',
        'No monetisation strategy beyond waiting to be discovered',
      ],
    },
    services: [
      {
        slug: 'streaming-consultation',
        title: 'Streaming Consultation',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />',
        image: '/images/photos/service-streaming-consultation-1.webp',
        solutionTagline:
          'OBS setup and tuning, multi-platform streaming configuration, overlays, hardware recommendations, and monetisation strategy — everything to level up your production from the first stream.',
        features: ['OBS Studio setup & tuning', 'Multi-platform streaming', 'Overlay & alert design', 'Monetization strategy'],
      },
    ],
  },

  // ── 2. Website Solutions — panel ────────────────────────────────
  {
    format: 'panel',
    problem: {
      headline: 'Your entire online presence is rented from a platform',
      description:
        "Your audience follows you on TikTok or YouTube — but that's their platform, their algorithm, their rules. One policy change, one account flag, one platform shutdown, and you have no way to reach the people you spent years building.",
      painPoints: [
        'No owned platform to fall back on if a social account is suspended or banned',
        'No way to sell directly without a third-party platform taking a significant cut',
        "Brand identity tied to a handle on someone else's infrastructure",
      ],
    },
    services: [
      {
        slug: 'website-solutions',
        title: 'Website Solutions',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.038 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.038-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />',
        image: '/images/photos/service-website-solutions-1.webp',
        solutionTagline:
          'A professional site that represents your brand — portfolio, landing pages, digital products, merch store, or booking calendar — built custom, not from a template.',
        features: ['Custom portfolio sites', 'E-commerce integration', 'Mobile-first design'],
      },
    ],
  },

  // ── 3. Digital Marketing — panel ────────────────────────────────
  {
    format: 'panel',
    problem: {
      headline: "Your best content isn't reaching the right people",
      description:
        "You spent hours producing something that deserved thousands of views. The algorithm served it to two hundred people. Growing an audience shouldn't be about gaming distribution — but distribution still matters and you need a strategy.",
      painPoints: [
        'Organic reach is unpredictable — quality content still gets buried on a bad week',
        'No clear strategy for converting casual viewers into loyal subscribers or customers',
        'Posting consistently with a flat growth curve and no idea what to change',
      ],
    },
    services: [
      {
        slug: 'digital-marketing',
        title: 'Digital Marketing',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />',
        image: '/images/photos/service-digital-marketing-1.webp',
        solutionTagline:
          'SEO, YouTube optimisation, targeted ads on the platforms your audience actually uses — strategy and execution to turn your content into consistent, compounding growth.',
        features: ['YouTube & TikTok ads', 'Content strategy', 'SEO & audience growth'],
      },
    ],
  },

  // ── 4. Domain Solutions + Email Solutions — bundle ───────────────
  {
    format: 'bundle',
    problem: {
      headline: "Your brand name isn't locked down and your emails aren't landing",
      description:
        "You have a handle on every platform but what happens when a platform rebrands, dies, or someone registers your name on a new one first? And every brand deal or press inquiry you send from a free consumer address costs you credibility before you've said a word.",
      painPoints: [
        'Domain not registered — someone else could take your brand name at any time',
        'Brand collaborations and PR contacts receiving email from a free consumer address',
        'Newsletters and transactional emails ending up in spam without deliverability config',
      ],
    },
    services: [
      {
        slug: 'domain-solutions',
        title: 'Domain Solutions',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />',
        image: '/images/photos/service-domain-solutions-1.webp',
        solutionTagline:
          'Domain registration, DNS management, SSL, and CDN — your brand name locked down and professional from the URL up, with everything consolidated.',
        features: ['Domain registration', 'DNS management', 'Brand protection'],
      },
      {
        slug: 'email-solutions',
        title: 'Email Solutions',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />',
        image: '/images/photos/service-email-solutions-1.webp',
        solutionTagline:
          "Professional email on your own domain, newsletter setup, and deliverability fully configured — so your outreach lands and your brand looks the part.",
        features: ['Custom domain email', 'Newsletter setup', 'Deliverability tuning'],
      },
    ],
  },

  // ── 5. Online Privacy — panel ────────────────────────────────────
  {
    format: 'panel',
    problem: {
      headline: 'Being public makes you a target',
      description:
        "Your face, name, and location are searchable. Your accounts are high-value targets for takeovers. Data brokers are selling your personal information right now. The public figure threat model is real and most creators don't take it seriously until something goes wrong.",
      painPoints: [
        'Personal details appearing on people-search and data broker sites',
        'Accounts without proper 2FA or active breach monitoring',
        'No separation between your public creator identity and your personal data',
      ],
    },
    services: [
      {
        slug: 'online-privacy',
        title: 'Online Privacy',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />',
        image: '/images/photos/service-online-privacy-1.webp',
        solutionTagline:
          'Security audit, VPN, password management, 2FA setup, breach monitoring, and data broker removal — personal security made practical, not paranoid.',
        features: ['Security audit', 'VPN & 2FA setup', 'Data broker removal'],
      },
    ],
  },

  // ── 6. AI Integration + Training + Custom Services — bundle ──────
  {
    format: 'bundle',
    problem: {
      headline: "You're spending hours on things that could be automated or systematised",
      description:
        "Responding to the same DMs, scheduling posts manually, learning every new tool from scratch, and hitting problems that don't fit any standard solution. These hours add up to days every month that could go toward creating.",
      painPoints: [
        'Community management and content scheduling consuming time that should go toward content',
        'New tools taking weeks to learn properly from scattered YouTube tutorials',
        "Workflows that require custom solutions no off-the-shelf tool handles",
      ],
    },
    services: [
      {
        slug: 'ai-integration',
        title: 'AI Integration',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" />',
        image: '/images/photos/service-ai-integration-1.webp',
        solutionTagline:
          'Creator-focused AI workflows: community response automation, content scheduling, performance dashboards, and AI writing tools — configured for your specific platforms and content style.',
        features: ['Content scheduling AI', 'Community automation', 'Audience analytics'],
      },
      {
        slug: 'training-documentation',
        title: 'Training & Documentation',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />',
        image: '/images/photos/service-training-documentation-1.webp',
        solutionTagline:
          'Hands-on training for any tool or platform we work with, plus custom documentation — so you understand what was built, how to use it, and how to grow it.',
        features: ['Tool training', 'Custom guides', 'Platform onboarding'],
      },
      {
        slug: 'custom-services',
        title: 'Custom Services',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 0 1-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 1 1-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 0 1 6.336-4.486l-3.276 3.276a3.004 3.004 0 0 0 2.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852Z" />',
        image: '/images/photos/service-custom-services-1.webp',
        solutionTagline:
          "Custom integrations, hybrid solutions, and consulting for the gaps that standard tools don't cover. Bring the specific problem — we'll scope the solution.",
        features: ['Custom integrations', 'Workflow solutions', 'Consulting'],
      },
    ],
  },
]

// Flatten sections into tour steps
const tourSteps: TourStep[] = sections.flatMap(section =>
  section.services.map(service => ({
    slug: service.slug,
    title: service.title,
    icon: service.icon,
    image: service.image,
    tagline: service.solutionTagline,
    features: service.features,
  }))
)

const crossSellBundles = [
  { href: '/for-businesses', label: 'For Businesses', accentRgb: '59, 130, 246', count: 10 },
  { href: '/for-individuals', label: 'For Individuals', accentRgb: '34, 197, 94', count: 5 },
]
---

<BundleLayout
  title="Tech & Growth Tools for Content Creators | Nightious"
  description="9 services built for content creators. Streaming setup, web presence, audience growth, privacy, and more."
  audience="Creators"
  accentColor={accentColor}
  accentRgb={accentRgb}
  ogImage="/images/og/og-for-creators.png"
>
  <BundleHero
    slot="hero"
    audience="Creators"
    headline="Level up your content"
    tagline="built to help creators grow and go professional."
    accentRgb={accentRgb}
    serviceCount={9}
    animStyle="waveform"
    bgVideo="/videos/bundle-pink.webm"
  />
  <ServiceTour slot="grid" steps={tourSteps} accentRgb={accentRgb} />
  <CrossSell slot="crosssell" bundles={crossSellBundles} />
</BundleLayout>
