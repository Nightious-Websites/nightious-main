---
import { Image } from 'astro:assets'
import BaseLayout from '@/layouts/BaseLayout.astro'
import cityNight from '@/assets/images/photos/city-night.jpg'
import logoCompleteColor from '@/assets/images/logos/logo-complete-color.png'
---

<BaseLayout
  title="Page Not Found — Nightious"
  description="This page doesn't exist — but your IT solution does. Return to Nightious to find what you're looking for."
  noindex={true}
>
  <section
    class="relative min-h-dvh flex items-center justify-center overflow-hidden pt-16"
    aria-label="404 error"
  >
    <!-- Background photo -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <Image
        src={cityNight}
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        widths={[800, 1200, 1920]}
        sizes="100vw"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(2,0,10,0.7) 0%, rgba(2,0,10,0.55) 50%, rgba(2,0,10,0.85) 100%);"
      ></div>
      <!-- Purple tint -->
      <div class="absolute inset-0" style="background: rgba(124,58,237,0.12);"></div>
    </div>

    <!-- Static blobs on top of photo -->
    <div aria-hidden="true" class="absolute inset-0 z-10">
      <div
        class="blob"
        style="
          width: 500px;
          height: 500px;
          background: radial-gradient(circle, rgba(124, 58, 237, 0.25) 0%, transparent 70%);
          top: -80px;
          left: -120px;
        "
      ></div>
      <div
        class="blob"
        style="
          width: 380px;
          height: 380px;
          background: radial-gradient(circle, rgba(232, 121, 249, 0.15) 0%, transparent 70%);
          top: -30px;
          right: -80px;
        "
      ></div>
    </div>

    <div class="relative z-20 max-w-lg mx-auto px-4 sm:px-6 text-center">
      <!-- Logo (color variant — stands out on dark photo) -->
      <div class="flex justify-center mb-8">
        <Image
          src={logoCompleteColor}
          alt="Nightious"
          class="h-10 w-auto object-contain"
          width={300}
          height={72}
        />
      </div>

      <!-- Large 404 -->
      <p
        class="font-display text-8xl sm:text-9xl mb-2 select-none"
        style="
          background: linear-gradient(135deg, rgba(168, 85, 247, 0.4), rgba(232, 121, 249, 0.4));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          line-height: 1;
        "
        aria-hidden="true"
      >
        404
      </p>

      <h1 class="font-display text-2xl sm:text-3xl mb-4 text-glow" style="color: var(--color-text-primary);">
        Lost in the Network
      </h1>

      <p class="text-base mb-10" style="color: var(--color-text-muted);">
        This page doesn't exist — but your solution does.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          Back to Home
        </a>
        <a href="/services" class="btn-ghost">
          View Our Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
