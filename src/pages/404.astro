---
import { Image } from 'astro:assets'
import BaseLayout from '@/layouts/BaseLayout.astro'
import AuroraBackground from '@/components/ui/AuroraBackground.astro'
import ConstellationParticles from '@/components/ui/ConstellationParticles.astro'
import HudBrackets from '@/components/ui/HudBrackets.astro'
import logoCompleteColor from '@/assets/images/logos/logo-complete-color.png'
---

<BaseLayout
  title="Page Not Found — Nightious"
  description="This page doesn't exist — but your IT solution does. Return to Nightious to find what you're looking for."
  noindex={true}
>
  <!-- CRT noise canvas -->
  <canvas id="noise-canvas" aria-hidden="true" style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:3;opacity:0.03;mix-blend-mode:screen;"></canvas>

  <section
    class="e404-section relative min-h-dvh flex items-center justify-center overflow-hidden pt-16"
    aria-label="404 error"
    id="e404-section"
  >
    <!-- Motion-treated still background -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        class="hero-motion-bg"
        src="/images/hero-poster.webp"
        alt=""
        aria-hidden="true"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <!-- Deep dark overlay -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(2,0,10,0.75) 0%, rgba(2,0,10,0.6) 50%, rgba(2,0,10,0.88) 100%);"
      ></div>
      <!-- Amber/red tint — signals error -->
      <div class="absolute inset-0" style="background: rgba(180,40,20,0.06);"></div>
    </div>

    <!-- Aurora (full variant for max drama) -->
    <AuroraBackground variant="full" colors="purple-pink" zIndex={2} />

    <!-- Constellation particles -->
    <ConstellationParticles density="medium" colors="purple-only" zIndex={3} />

    <!-- HUD brackets — full page frame -->
    <HudBrackets zIndex={21} />

    <!-- Scan line -->
    <div class="scan-line" aria-hidden="true" style="z-index: 15;"></div>

    <!-- Grid overlay — gives it a terminal feel -->
    <div
      class="absolute inset-0 bg-grid pointer-events-none"
      style="z-index: 4; opacity: 0.25;"
      aria-hidden="true"
    ></div>

    <!-- Main content -->
    <div class="relative max-w-lg mx-auto px-4 sm:px-6 text-center" style="z-index: 22;">

      <!-- Logo -->
      <div id="e404-logo" class="flex justify-center mb-8" style="opacity:0;">
        <Image
          src={logoCompleteColor}
          alt="Nightious"
          class="h-10 w-auto object-contain"
          width={300}
          height={72}
        />
      </div>

      <!-- Glitch 404 -->
      <p
        id="e404-number"
        class="e404-glitch select-none"
        data-text="404"
        aria-hidden="true"
        style="opacity:0;"
      >
        404
      </p>

      <!-- Heading -->
      <h1 id="e404-heading" class="e404-heading text-glow" style="opacity:0;">
        Lost in the Network
      </h1>

      <!-- Subtext -->
      <p id="e404-sub" class="e404-sub" style="opacity:0;">
        This page doesn't exist — but your solution does.
      </p>

      <!-- Buttons -->
      <div id="e404-btns" class="flex flex-col sm:flex-row items-center justify-center gap-4" style="opacity:0;">
        <a href="/" class="btn-primary">
          Back to Home
        </a>
        <a href="/services" class="btn-ghost">
          View Our Services
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<noscript>
  <style>
    #e404-logo, #e404-number, #e404-heading, #e404-sub, #e404-btns {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<style>
  /* ── Section ── */
  .e404-section {
    background: var(--color-bg-deep);
  }

  /* ── Glitch 404 ── */
  .e404-glitch {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(96px, 18vw, 180px);
    line-height: 1;
    letter-spacing: -0.04em;
    /* Base: gradient fill */
    background: linear-gradient(135deg, rgba(168,85,247,0.65), rgba(232,121,249,0.55));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
    position: relative;
    display: inline-block;
    animation: glitch-main 5s ease-in-out infinite;
  }

  /* Pseudo-elements for RGB split effect */
  .e404-glitch::before,
  .e404-glitch::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    /* Override gradient — pseudo-elements get solid color for the split */
    background: none;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }
  .e404-glitch::before {
    background: linear-gradient(135deg, rgba(0,255,255,0.6), rgba(0,200,200,0.4));
    -webkit-background-clip: text;
    background-clip: text;
    left: 2px;
    top: -1px;
    animation: glitch-before 5s ease-in-out infinite;
    clip-path: polygon(0 20%, 100% 20%, 100% 40%, 0 40%);
  }
  .e404-glitch::after {
    background: linear-gradient(135deg, rgba(255,0,100,0.55), rgba(200,0,80,0.4));
    -webkit-background-clip: text;
    background-clip: text;
    left: -2px;
    top: 1px;
    animation: glitch-after 5s ease-in-out infinite;
    clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%);
  }

  @keyframes glitch-main {
    0%, 88%, 100% { transform: none; filter: none; }
    90%  { transform: skewX(-1.5deg); }
    92%  { transform: skewX(0.8deg); }
    94%  { transform: none; }
  }
  @keyframes glitch-before {
    0%, 88%, 100% { transform: none; opacity: 0; }
    90%  { transform: translate(-3px, 0); opacity: 1; }
    92%  { transform: translate(3px, 0); opacity: 0.8; }
    94%  { transform: none; opacity: 0; }
  }
  @keyframes glitch-after {
    0%, 88%, 100% { transform: none; opacity: 0; }
    90%  { transform: translate(3px, 0); opacity: 1; }
    92%  { transform: translate(-3px, 0); opacity: 0.7; }
    94%  { transform: none; opacity: 0; }
  }

  /* ── Heading ── */
  .e404-heading {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(22px, 3.5vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text-primary-aurora);
    margin-bottom: 16px;
  }

  /* ── Subtext ── */
  .e404-sub {
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-muted-aurora);
    margin-bottom: 36px;
  }

  @media (prefers-reduced-motion: reduce) {
    .e404-glitch,
    .e404-glitch::before,
    .e404-glitch::after {
      animation: none;
    }
    .e404-glitch::before,
    .e404-glitch::after {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'

  let tl: gsap.core.Timeline | null = null
  let mouseMoveController: AbortController | null = null
  let noiseStop: (() => void) | null = null

  function startNoise() {
    const canvas = document.getElementById('noise-canvas') as HTMLCanvasElement | null
    if (!canvas) return null

    const ctx = canvas.getContext('2d')
    if (!ctx) return null

    // Size to viewport
    function resize() {
      canvas.width  = window.innerWidth
      canvas.height = window.innerHeight
    }
    resize()
    window.addEventListener('resize', resize)

    let lastNoise = 0
    let rafId: number | null = null

    function loop(t: number) {
      rafId = requestAnimationFrame(loop)

      // ~8fps — intentionally choppy for CRT aesthetic, saves perf
      if (t - lastNoise < 125) return
      lastNoise = t

      const w = canvas.width
      const h = canvas.height
      const img = ctx.createImageData(w, h)
      const data = img.data
      for (let i = 0; i < data.length; i += 4) {
        const v = Math.random() * 255
        data[i]     = v
        data[i + 1] = v
        data[i + 2] = v
        data[i + 3] = 255
      }
      ctx.putImageData(img, 0, 0)
    }

    rafId = requestAnimationFrame(loop)

    return function stop() {
      if (rafId !== null) cancelAnimationFrame(rafId)
      window.removeEventListener('resize', resize)
      ctx.clearRect(0, 0, canvas.width, canvas.height)
    }
  }

  function initAnimations() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const logo    = document.getElementById('e404-logo')
    const number  = document.getElementById('e404-number')
    const heading = document.getElementById('e404-heading')
    const sub     = document.getElementById('e404-sub')
    const btns    = document.getElementById('e404-btns')

    // Find the constellation particles container to parallax it
    const particles = document.querySelector<HTMLElement>('.constellation-particles')

    if (reduced) {
      ;[logo, number, heading, sub, btns].forEach(el => {
        if (!el) return
        el.style.opacity = '1'
        el.style.transform = 'none'
      })
      return
    }

    noiseStop = startNoise()

    // Entrance timeline
    tl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    tl
      .fromTo(logo,    { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.5 }, 0.2)
      .fromTo(number,  { opacity: 0, scale: 0.88, y: 20 }, { opacity: 1, scale: 1, y: 0, duration: 0.75 }, 0.35)
      .fromTo(heading, { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.55 }, '-=0.3')
      .fromTo(sub,     { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.5 }, '-=0.3')
      .fromTo(btns,    { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.5 }, '-=0.25')

    // Easter egg: subtle particle parallax on mouse move
    if (particles) {
      mouseMoveController = new AbortController()
      const { signal } = mouseMoveController

      document.addEventListener('mousemove', (e: MouseEvent) => {
        const cx = window.innerWidth / 2
        const cy = window.innerHeight / 2
        const dx = (e.clientX - cx) / cx   // -1 to 1
        const dy = (e.clientY - cy) / cy   // -1 to 1
        const maxOffset = 10

        gsap.to(particles, {
          x: dx * maxOffset,
          y: dy * maxOffset,
          duration: 1.2,
          ease: 'power1.out',
          overwrite: 'auto',
        })
      }, { signal })
    }
  }

  document.addEventListener('astro:before-swap', () => {
    tl?.kill()
    tl = null
    mouseMoveController?.abort()
    mouseMoveController = null
    noiseStop?.()
    noiseStop = null
  })

  document.addEventListener('astro:page-load', initAnimations)
</script>
