---
import { Image } from 'astro:assets'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import GlassCard from '@/components/ui/GlassCard.astro'
import AuroraBackground from '@/components/ui/AuroraBackground.astro'
import ConstellationParticles from '@/components/ui/ConstellationParticles.astro'
import HudBrackets from '@/components/ui/HudBrackets.astro'
import contactSide from '@/assets/images/photos/contact-side.webp'
import logoCompleteWhite from '@/assets/images/logos/logo-complete-white.png'

const breadcrumbItems = [
  { name: 'Home', url: 'https://nightious.com' },
  { name: 'Contact', url: 'https://nightious.com/contact' },
]

---

<BaseLayout
  title="Get a Free Quote — Contact Nightious"
  description="Send us a message and we'll get back to you as soon as possible. No obligation. Start with a free quote from Nightious today."
  ogImage="/images/og/og-contact.png"
>
  <SchemaBreadcrumb items={breadcrumbItems} />

  <!-- ─── Hero ─────────────────────────────────────────────────────────────── -->
  <section
    class="contact-hero relative min-h-[52vh] flex flex-col items-center justify-center overflow-hidden pt-28 pb-12"
    aria-label="Contact hero"
    id="contact-hero-section"
  >
    <!-- Video background -->
    <video
      class="absolute inset-0 w-full h-full object-cover object-center pointer-events-none"
      style="z-index: 0;"
      autoplay muted loop playsinline
        data-autoplay-managed="true"
        data-video-upgrade="true"
      aria-hidden="true"
      tabindex="-1"
      preload="none"
    >
      <source src="/videos/hero-contact.webm" type="video/webm" />
      <source src="/videos/hero-contact.mp4" type="video/mp4" />
    </video>
    <!-- Video overlay -->
    <div class="absolute inset-0 pointer-events-none" style="background: rgba(2,0,10,0.6); z-index: 0;" aria-hidden="true"></div>

    <!-- Aurora -->
    <AuroraBackground variant="subtle" colors="purple-pink" />

    <!-- Particles -->
    <ConstellationParticles density="low" colors="purple-emerald" />

    <!-- HUD brackets -->
    <HudBrackets />

    <!-- Scan line -->
    <div class="scan-line" aria-hidden="true"></div>

    <!-- Grid overlay -->
    <div
      class="absolute inset-0 bg-grid pointer-events-none"
      style="z-index: 1; opacity: 0.3;"
      aria-hidden="true"
    ></div>

    <!-- Signal rings — concentric expanding circles radiating from center -->
    <div class="signal-rings" aria-hidden="true">
      <div class="signal-ring-3"></div>
    </div>

    <!-- Content -->
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="z-index: 20;">

      <!-- Headline -->
      <h1 id="ctc-h1" class="ctc-h1" style="opacity:0;">
        Let's <span class="gradient-text">Talk</span>
      </h1>

      <!-- Gradient divider -->
      <div
        id="ctc-divider"
        class="gradient-divider my-6"
        style="opacity:0; transform:scaleX(0); transform-origin:center;"
        aria-hidden="true"
      ></div>

      <!-- Lead -->
      <p id="ctc-lead" class="ctc-lead" style="opacity:0;">
        Describe your situation and we'll get back to you with a clear plan — no&nbsp;obligation.
      </p>

    </div>
  </section>

  <!-- ─── Form + Trust + Image ────────────────────────────────────────────── -->
  <section class="relative py-12 pb-24 overflow-hidden" aria-label="Contact options">

    <!-- Subtle ambient glow -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 70% 40% at 30% 20%, rgba(124,58,237,0.06) 0%, transparent 70%); z-index: 0;"
      aria-hidden="true"
    ></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" style="z-index: 1;">
      <div class="grid grid-cols-1 lg:grid-cols-7 gap-10">

        <!-- ── Direct contact options ── -->
        <div id="ctc-form-wrap" class="lg:col-span-3 xl:col-span-3" style="opacity:0; transform:translateY(24px);">
          <div class="glass-strong neon-top rounded-2xl p-8">
            <h2 class="font-display text-2xl mb-3" style="color: var(--color-text-primary);">Reach Nightious Directly</h2>
            <p class="text-sm mb-6" style="color: var(--color-text-muted);">
              We handle requests directly through email and live consultation. Choose the fastest path below and we’ll respond quickly.
            </p>

            <div class="flex flex-col gap-4">
              <a class="btn-primary justify-center" href="mailto:support@nightious.com?subject=New%20Project%20Request">
                Email support@nightious.com
              </a>
              <a class="btn-ghost justify-center text-sm" href="tel:+17727736004">
                Call (772) 773-6004
              </a>
            </div>
          </div>
        </div>

        <!-- ── Trust + Next steps ── -->
        <div class="lg:col-span-2 xl:col-span-2 flex flex-col gap-6">

          <!-- Why Nightious -->
          <div id="ctc-trust" class="glass p-6 flex flex-col gap-5 rounded-2xl" style="opacity:0; transform:translateX(20px);">
            <p class="font-display text-xs tracking-widest" style="color: var(--color-purple-mid);">WHY NIGHTIOUS</p>

            <ul class="flex flex-col gap-3 list-none">
              <li class="flex items-start gap-3">
                <span class="ctc-icon-wrap" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="rgba(168,85,247,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="text-sm" style="color: var(--color-text-muted);">We'll be in touch as soon as possible</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="ctc-icon-wrap" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="rgba(168,85,247,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="text-sm" style="color: var(--color-text-muted);">Your information is private and never shared</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="ctc-icon-wrap" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="rgba(168,85,247,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <address class="text-sm not-italic" style="color: var(--color-text-muted);">
                  7901 4th St N, Suite 300<br />
                  St. Petersburg, FL 33702
                </address>
              </li>
            </ul>
          </div>

          <!-- What Happens Next — 3-step timeline -->
          <div id="ctc-next" class="glass p-6 flex flex-col gap-5 rounded-2xl" style="opacity:0; transform:translateX(20px);">
            <p class="font-display text-xs tracking-widest" style="color: var(--color-purple-mid);">WHAT HAPPENS NEXT</p>
            <ol class="flex flex-col gap-0 list-none relative">

              <!-- Connecting line -->
              <div class="ctc-step-line" aria-hidden="true"></div>

              <li class="flex items-start gap-4 relative pb-6">
                <span class="ctc-step-num flex-shrink-0">1</span>
                <span class="text-sm pt-0.5" style="color: var(--color-text-muted);">We review your message and respond as soon as possible</span>
              </li>
              <li class="flex items-start gap-4 relative pb-6">
                <span class="ctc-step-num flex-shrink-0">2</span>
                <span class="text-sm pt-0.5" style="color: var(--color-text-muted);">You receive a clear breakdown of your options</span>
              </li>
              <li class="flex items-start gap-4 relative">
                <span class="ctc-step-num flex-shrink-0">3</span>
                <span class="text-sm pt-0.5" style="color: var(--color-text-muted);">We get to work — no long contracts required</span>
              </li>
            </ol>
          </div>
        </div>

        <!-- ── Image panel (xl+) with HUD overlay ── -->
        <div
          id="ctc-image"
          class="hidden xl:block xl:col-span-2 relative rounded-2xl overflow-hidden"
          style="min-height: 600px; opacity:0; transform:translateX(24px);"
        >
          <Image
            src={contactSide}
            alt=""
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            widths={[600, 900, 1200]}
            sizes="(max-width: 1280px) 0px, 300px"
            aria-hidden="true"
          />
          <!-- Dark + color overlay -->
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to bottom, rgba(2,0,10,0.35) 0%, rgba(120,58,237,0.18) 50%, rgba(2,0,10,0.82) 100%);"
            aria-hidden="true"
          ></div>

          <!-- HUD scan line on image panel -->
          <div class="scan-line" aria-hidden="true" style="z-index: 5;"></div>

          <!-- Corner HUD brackets (small) -->
          <HudBrackets size={20} inset={14} color="rgba(168,85,247,0.5)" />

          <!-- Logo overlay at bottom -->
          <div class="absolute bottom-8 left-0 right-0 flex flex-col items-center gap-3" style="z-index: 10;">
            <Image
              src={logoCompleteWhite}
              alt="Nightious"
              class="h-10 w-auto object-contain"
              width={300}
              height={72}
            />
            <p class="text-xs text-center px-4" style="color: rgba(233,213,255,0.6);">
              St. Petersburg, FL · Serving clients nationwide
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<noscript>
  <style>
    #ctc-h1, #ctc-divider, #ctc-lead,
    #ctc-form-wrap, #ctc-trust, #ctc-next, #ctc-image {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<style>
  /* ── Hero surface ── */
  .contact-hero {
    background: var(--color-bg-deep);
  }

  /* ── Headline ── */
  .ctc-h1 {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary-aurora);
    margin-bottom: 0;
  }

  /* ── Lead ── */
  .ctc-lead {
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.75;
    color: var(--text-muted-aurora);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── Icon wrap ── */
  .ctc-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    flex-shrink: 0;
    margin-top: 1px;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.18);
  }

  /* ── Step numbers with connecting line ── */
  .ctc-step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--color-purple-light);
    background: rgba(124, 58, 237, 0.2);
    border: 1px solid rgba(168, 85, 247, 0.35);
    position: relative;
    z-index: 2;
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.2);
  }

  .ctc-step-line {
    position: absolute;
    left: 13px;
    top: 28px;
    bottom: 14px;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(168, 85, 247, 0.4),
      rgba(168, 85, 247, 0.15),
      transparent
    );
    z-index: 1;
  }

  /* ── Signal rings ── */
  .signal-rings {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 3;
    overflow: hidden;
  }
  .signal-rings::before,
  .signal-rings::after {
    content: '';
    position: absolute;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    border: 1px solid rgba(168, 85, 247, 0.35);
    animation: signal-expand 5s ease-out infinite;
  }
  .signal-rings::after {
    animation-delay: 1.67s;
  }
  .signal-ring-3 {
    position: absolute;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    border: 1px solid rgba(168, 85, 247, 0.25);
    animation: signal-expand 5s ease-out infinite;
    animation-delay: 3.33s;
    pointer-events: none;
  }

  @keyframes signal-expand {
    0%   { transform: scale(0.2); opacity: 0.7; }
    100% { transform: scale(6); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .signal-rings::before,
    .signal-rings::after,
    .signal-ring-3 {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let tl: gsap.core.Timeline | null = null

  function initAnimations() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const h1       = document.getElementById('ctc-h1')
    const divider  = document.getElementById('ctc-divider')
    const lead     = document.getElementById('ctc-lead')
    const formWrap = document.getElementById('ctc-form-wrap')
    const trust    = document.getElementById('ctc-trust')
    const next     = document.getElementById('ctc-next')
    const image    = document.getElementById('ctc-image')

    if (reduced) {
      ;[h1, divider, lead, formWrap, trust, next, image].forEach(el => {
        if (!el) return
        el.style.opacity = '1'
        el.style.transform = 'none'
      })
      return
    }

    // Hero entrance
    tl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    tl
      .fromTo(h1,      { opacity: 0, y: 28, scale: 0.97 }, { opacity: 1, y: 0, scale: 1, duration: 0.8 })
      .fromTo(divider, { opacity: 0, scaleX: 0 }, { opacity: 1, scaleX: 1, duration: 0.45, ease: 'power2.out' }, '-=0.35')
      .fromTo(lead,    { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.55 }, '-=0.3')

    // Form section scroll reveals
    if (formWrap) {
      gsap.fromTo(formWrap,
        { opacity: 0, y: 24 },
        { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out',
          scrollTrigger: { trigger: formWrap, start: 'top 90%', once: true } }
      )
    }
    if (trust) {
      gsap.fromTo(trust,
        { opacity: 0, x: 20 },
        { opacity: 1, x: 0, duration: 0.55, ease: 'power2.out',
          scrollTrigger: { trigger: trust, start: 'top 90%', once: true } }
      )
    }
    if (next) {
      gsap.fromTo(next,
        { opacity: 0, x: 20 },
        { opacity: 1, x: 0, duration: 0.55, ease: 'power2.out', delay: 0.1,
          scrollTrigger: { trigger: next, start: 'top 90%', once: true } }
      )
    }
    if (image) {
      gsap.fromTo(image,
        { opacity: 0, x: 24 },
        { opacity: 1, x: 0, duration: 0.6, ease: 'power2.out', delay: 0.15,
          scrollTrigger: { trigger: image, start: 'top 90%', once: true } }
      )
    }
  }

  function initContact() {
    initAnimations()
  }

  document.addEventListener('astro:before-swap', () => {
    tl?.kill()
    tl = null
    ScrollTrigger.getAll().forEach(t => t.kill())
  })

  document.addEventListener('astro:page-load', initContact)
</script>
