const heroService = services.find(s => s.tier === 'hero')!
const standardServices = services.filter(s => s.tier === 'standard')
const compactServices = services.filter(s => s.tier === 'compact')

const crossSellBundles = [
  { href: '/for-creators', label: 'For Creators', accentRgb: '236, 72, 153', count: 9 },
  { href: '/for-individuals', label: 'For Individuals', accentRgb: '34, 197, 94', count: 5 },
]
---

<BundleLayout
  title="IT & Digital Solutions for Businesses | Nightious"
  description="10 services tailored to run, grow, and protect your business. AI integration, web development, marketing, IT support, and more."
  audience="Businesses"
  accentColor={accentColor}
  accentRgb={accentRgb}
  ogImage="/images/og/og-for-businesses.png"
>
  <BundleHero
    slot="hero"
    audience="Businesses"
    headline="Your complete tech stack"
    tagline="tailored to run, grow, and protect your business."
    accentRgb={accentRgb}
    serviceCount={services.length}
  />
  <LivingGrid
    slot="grid"
    heroService={heroService}
    standardServices={standardServices}
    compactServices={compactServices}
    accentRgb={accentRgb}
    columnCount={3}
  />
  <CrossSell slot="crosssell" bundles={crossSellBundles} />
</BundleLayout>
