---
import BundleLayout from '@/layouts/BundleLayout.astro'
import BundleHero from '@/components/sections/BundleHero.astro'
import { type WalkthroughSection } from '@/components/sections/BundleWalkthrough.astro'
import ServiceTour, { type TourStep } from '@/components/sections/ServiceTour.astro'
import CrossSell from '@/components/sections/CrossSell.astro'

const accentRgb = '34, 197, 94'
const accentColor = '#22c55e'

// 4 sections covering all 5 services
const sections: WalkthroughSection[] = [
  // ── 1. Online Privacy — cinematic flagship ───────────────────────
  {
    format: 'cinematic',
    bgImage: '/images/photos/service-online-privacy-hero.webp',
    problem: {
      headline: 'Your personal information is being sold without your knowledge',
      description:
        "Data brokers collect your name, address, phone number, relatives, employment, and more — then sell it to anyone who pays. You didn't opt in. There's no simple single opt-out. And the longer it stays online, the more it spreads to other services.",
      painPoints: [
        "Personal details on people-search sites you've never heard of",
        'No monitoring for data breaches affecting your accounts and passwords',
        'Accounts without proper 2FA or strong password management practices',
      ],
    },
    services: [
      {
        slug: 'online-privacy',
        title: 'Online Privacy',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />',
        image: '/images/photos/service-online-privacy-1.webp',
        solutionTagline:
          'Security audit, VPN setup, password manager installation, 2FA configuration, breach monitoring, and data broker removal — complete personal security, handled for you.',
        features: ['Full security audit', 'VPN & password manager', '2FA configuration', 'Data broker removal'],
      },
    ],
  },

  // ── 2. Computer Services — panel ────────────────────────────────
  {
    format: 'panel',
    problem: {
      headline: "Your device isn't running the way it should",
      description:
        "It boots slowly. Programs take too long to open. The battery barely lasts a morning. You've noticed it getting worse but don't know if it needs a repair, a clean reinstall, or something else entirely — and you don't want to make it worse by guessing.",
      painPoints: [
        'Slow startup and program load times affecting your daily work',
        'Unexpected crashes, freezes, or overheating with no obvious cause',
        "Worry that there's a virus or unwanted software running in the background",
      ],
    },
    services: [
      {
        slug: 'computer-services',
        title: 'Computer Services',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 7.409A2.25 2.25 0 0 1 2.25 5.493V5.25" />',
        image: '/images/photos/service-computer-services-1.webp',
        solutionTagline:
          'Remote diagnostics, virus and malware removal, performance optimisation, driver updates, and startup repair — your personal devices running fast, clean, and reliably again.',
        features: ['Virus & malware removal', 'Performance optimization', 'Startup repair'],
      },
    ],
  },

  // ── 3. Email Solutions + AI Integration — bundle ─────────────────
  {
    format: 'bundle',
    problem: {
      headline: "Your daily digital setup is underpowered and costing you time",
      description:
        "Important messages mixed in with newsletters from a free consumer address. Spending hours on tasks that AI could handle in minutes. Your digital life shouldn't feel like this much work — it can be made simpler.",
      painPoints: [
        'No professional email address for freelance work, clients, or job applications',
        'Spending hours on tasks that could be automated with the right setup',
        'Calendar and contacts not properly synced and accessible across all your devices',
      ],
    },
    services: [
      {
        slug: 'email-solutions',
        title: 'Email Solutions',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />',
        image: '/images/photos/service-email-solutions-1.webp',
        solutionTagline:
          'Professional email on your own domain, fully configured with SPF/DKIM/DMARC, spam filtering set up, and calendar sync working across every device.',
        features: ['Custom domain email', 'Calendar sync', 'Multi-device access'],
      },
      {
        slug: 'ai-integration',
        title: 'AI Integration',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" />',
        image: '/images/photos/service-ai-integration-1.webp',
        solutionTagline:
          "We identify the AI tools that fit how you actually work, set them up properly, and walk you through using them — no jargon, no unnecessary complexity, no startup pitch.",
        features: ['AI assistant setup', 'Task automation', 'Tool configuration'],
      },
    ],
  },

  // ── 4. Custom Services — panel ───────────────────────────────────
  {
    format: 'panel',
    problem: {
      headline: "Your problem doesn't fit a standard service",
      description:
        "You've looked at what's available and none of it quite covers what you need. Maybe it's a specific technical task, a one-off integration, or a decision you want a second opinion on before committing. Those are the projects we take on.",
      painPoints: [
        'Technical tasks that fall between standard service categories',
        'One-off projects that need a custom scope rather than a recurring plan',
        'Technology decisions you want an expert perspective on before committing',
      ],
    },
    services: [
      {
        slug: 'custom-services',
        title: 'Custom Services',
        icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 0 1-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 1 1-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 0 1 6.336-4.486l-3.276 3.276a3.004 3.004 0 0 0 2.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852Z" />',
        image: '/images/photos/service-custom-services-1.webp',
        solutionTagline:
          "Custom integrations, hybrid solutions, and consulting for problems that don't fit a pre-packaged service. Describe what you need — we'll figure out the scope together.",
        features: ['Custom integrations', 'Consulting', 'Unique solutions'],
      },
    ],
  },
]

// Flatten sections into tour steps
const tourSteps: TourStep[] = sections.flatMap(section =>
  section.services.map(service => ({
    slug: service.slug,
    title: service.title,
    icon: service.icon,
    image: service.image,
    tagline: service.solutionTagline,
    features: service.features,
  }))
)

const crossSellBundles = [
  { href: '/for-businesses', label: 'For Businesses', accentRgb: '59, 130, 246', count: 10 },
  { href: '/for-creators', label: 'For Creators', accentRgb: '236, 72, 153', count: 9 },
]
---

<BundleLayout
  title="Personal Tech Support & Privacy | Nightious"
  description="5 services for personal tech: privacy protection, device support, professional email, AI automation, and custom solutions."
  audience="Individuals"
  accentColor={accentColor}
  accentRgb={accentRgb}
  ogImage="/images/og/og-for-individuals.png"
>
  <BundleHero
    slot="hero"
    audience="Individuals"
    headline="Tech that just works"
    tagline={`built to keep <span class="accent-italic">your</span> personal devices secure and running smooth.`}
    accentRgb={accentRgb}
    serviceCount={5}
    animStyle="orbs"
    bgImage="/images/bundles/for-individuals-hero.webp"
  />
  <ServiceTour slot="grid" steps={tourSteps} accentRgb={accentRgb} />
  <CrossSell slot="crosssell" bundles={crossSellBundles} />
</BundleLayout>
