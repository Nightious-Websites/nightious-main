---
import ServiceLayout from '@/layouts/ServiceLayout.astro'
import GlassCard from '@/components/ui/GlassCard.astro'
import CtaSection from '@/components/sections/CtaSection.astro'
import AuroraBackground from '@/components/ui/AuroraBackground.astro'
import ConstellationParticles from '@/components/ui/ConstellationParticles.astro'
import HudBrackets from '@/components/ui/HudBrackets.astro'
import { getAllServices, entrySlug } from '@/utils/services'
import { getServiceTheme, serviceThemes } from '@/utils/serviceTheme'
import { getCollection } from 'astro:content'
import ServiceEditorial from '@/components/services/ServiceEditorial.astro'

export async function getStaticPaths() {
  const services = await getCollection('services')
  return services.map(service => ({
    params: { slug: entrySlug(service.id) },
    props: { entry: service },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()
const slug = entrySlug(entry.id)
const theme = getServiceTheme(slug)

// Get related services
const allServices = await getAllServices()
const related = allServices.filter(s => entry.data.relatedSlugs.includes(entrySlug(s.id)))

const categoryEmoji: Record<string, string> = {
  Website: '🌐',
  Email: '✉️',
  Domain: '🔗',
  AI: '🤖',
  Marketing: '📈',
  Computers: '💻',
  Streaming: '🎙️',
  Privacy: '🔒',
  Operations: '⚙️',
  Software: '🖥️',
  Custom: '✨',
  Training: '📚',
}

const emoji = categoryEmoji[entry.data.category] ?? '🔧'

---

<ServiceLayout
  title={entry.data.title}
  description={entry.data.description}
  slug={slug}
  category={entry.data.category}
  serviceImage={entry.data.images?.img1}
  keywords={entry.data.sections?.whatWeDo?.wideCard?.chips}
  accentRgb={theme.colorRgb}
>
  <div style={`--btn-from: ${theme.colorDark}; --btn-to: ${theme.colorDark}; --btn-ghost-hover-bg: rgba(${theme.colorRgb}, 0.10); --btn-ghost-hover-border: rgba(${theme.colorRgb}, 0.55); --scan-color-mid: rgba(${theme.colorRgb}, 0.40); --scan-color-end: rgba(${theme.colorRgb}, 0.25);`}>
  {/* ═══════════════════════════════════════════════════════════
      HERO — Unified: Split — left hook + CTAs / right stat cards
     ═══════════════════════════════════════════════════════════ */}
  <section
    class="svc-hero relative overflow-hidden"
    style={`min-height: 680px;`}
    aria-label={`${entry.data.title} hero`}
  >
    {/* Image background */}
    <img
      src={theme.heroImage}
      class="hero-motion-bg"
      style="z-index: 0;"
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
      transition:name={`svc-hero-image-${slug}`}
      transition:animate="none"
    />
    {/* Image overlay */}
    <div class="absolute inset-0 pointer-events-none" style="background: rgba(2,0,10,0.62); z-index: 0;" aria-hidden="true"></div>

    {/* Deep bg base */}
    <div class="absolute inset-0" style="background: var(--color-bg-deep); z-index: -1;" aria-hidden="true"></div>

    {/* Aurora base layer */}
    <AuroraBackground variant="subtle" colors="accent" accentRgb={theme.colorRgb} zIndex={0} />

    {/* Particles */}
    <ConstellationParticles density="low" colors="accent" accentRgb={theme.colorRgb} zIndex={2} />

    {/* HUD brackets */}
    <HudBrackets color={`rgba(${theme.colorRgb}, 0.35)`} zIndex={20} />

    {/* Scan line */}
    <div class="scan-line" style="z-index: 4;" aria-hidden="true"></div>

    {/* ── Content layer: offset by navbar height (h-16 = 4rem) so justify-center works on visible area ── */}
    <div class="absolute left-0 right-0 bottom-0 flex flex-col" style="top: 4rem; z-index: 10;">

      {/* Main content: left text + right context card */}
      <div class="flex-1 max-w-7xl mx-auto px-6 lg:px-12 w-full grid svc-hero-grid">

        {/* Left column */}
        <div class="flex flex-col justify-center py-12 pr-10">

          {/* Service icon badge */}
          <div
            class="svc-hero-el"
            style={`opacity: 0; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; width: 44px; height: 44px; background: rgba(${theme.colorRgb}, 0.10); border: 1px solid rgba(${theme.colorRgb}, 0.28); border-radius: 12px; box-shadow: 0 0 18px rgba(${theme.colorRgb}, 0.18);`}
            aria-hidden="true"
          >
            <span style="font-size: 1.25rem; line-height: 1;">{emoji}</span>
          </div>

          {/* Hook — h1, dominant type */}
          <h1
            class="svc-hero-el font-display"
            style={`opacity: 0; font-size: clamp(2.1rem, 4.8vw, 3.2rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.03em; color: #f0e6ff; margin-bottom: 1.2rem; text-shadow: 0 0 50px rgba(${theme.colorRgb}, 0.35);`}
          >
            {entry.data.sections?.hero?.hook ?? entry.data.title}
          </h1>

          {/* Accent rule */}
          <div
            class="svc-hero-el svc-hero-rule"
            style={`opacity: 0; background: linear-gradient(90deg, rgba(${theme.colorRgb}, 0.6), transparent); margin-bottom: 1.2rem;`}
            aria-hidden="true"
          ></div>

          {/* Tagline */}
          <p
            class="svc-hero-el"
            style={`opacity: 0; font-size: 0.925rem; color: var(--color-text-muted); line-height: 1.72; max-width: 36ch; margin-bottom: 2rem;`}
          >
            {entry.data.tagline}
          </p>

          {/* CTAs */}
          <div class="svc-hero-el flex flex-wrap items-center gap-3" style="opacity: 0;">
            <a href="/contact" class="btn-primary">
              Get a Free Quote
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#what-we-do" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.35); color: ${theme.colorLight};`}>
              What's included &darr;
            </a>
          </div>


        </div>

        {/* Right column: "What's included" feature preview */}
        {entry.data.sections?.whatWeDo?.features && (
          <div class="svc-hero-el flex flex-col justify-center py-12 pl-8" style="opacity: 0;">
            <div
              class="svc-feat-panel"
              style={`border-color: rgba(${theme.colorRgb}, 0.22);`}
            >
              <div
                class="svc-feat-panel-line"
                style={`background: linear-gradient(90deg, rgba(${theme.colorRgb}, 0.75), transparent 65%);`}
                aria-hidden="true"
              ></div>
              <p class="svc-feat-panel-title" style={`color: rgba(${theme.colorRgb}, 0.60);`}>What's included</p>
              <ul class="svc-feat-list">
                {entry.data.sections.whatWeDo.features.map(feat => (
                  <li class="svc-feat-item">
                    <span aria-hidden="true">{feat.icon}</span>
                    <span>{feat.title}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        )}

      </div>

    </div>
  </section>
  {/* ═══════════════════════════════════════════════════════════
      SECTION BRIDGE — Gradient transition from hero to content
     ═══════════════════════════════════════════════════════════ */}
  {/* ═══════════════════════════════════════════════════════════
      EDITORIAL BODY — E2 layout with left-rail nav + content stage
      Renders when entry.data.sections is present (ported services).
      Falls back to legacy sections for unported services.
     ═══════════════════════════════════════════════════════════ */}
  {entry.data.sections ? (
    <ServiceEditorial
      accentRgb={theme.colorRgb}
      sections={entry.data.sections}
      images={entry.data.images}
      relatedServices={related}
    />
  ) : (
  <>
  {/* ── LEGACY: SERVICE OVERVIEW ── */}
  <section class="svc-overview relative py-16 overflow-hidden" aria-label="Service overview">
    {/* Minimal aurora behind this section */}
    <AuroraBackground variant="minimal" colors="accent" accentRgb={theme.colorRgb} zIndex={0} />

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" style="z-index: 1;">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-center">
        {/* Text content — 3/5 */}
        <div class="lg:col-span-3 svc-overview-el" style="opacity: 0;">
          <div class="glass-strong neon-top p-8 md:p-10">
            <span
              class="font-display text-xs tracking-widest py-1 px-3 rounded-full inline-block mb-6"
              style={`background: rgba(${theme.colorRgb}, 0.1); color: ${theme.colorLight}; border: 1px solid rgba(${theme.colorRgb}, 0.2);`}
            >
              Overview
            </span>
            <h2 class="font-display text-2xl md:text-3xl mb-6" style="color: var(--color-text-primary);">
              {entry.data.description}
            </h2>
            <div class="flex flex-wrap gap-3">
              <a href="#service-details" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.4); color: ${theme.colorLight};`}>
                See what's included &darr;
              </a>
              <a href="/contact" class="btn-primary text-sm">
                Get a Free Quote &rarr;
              </a>
            </div>
          </div>
        </div>

        {/* Stats accent panel — 2/5 */}
        <div class="lg:col-span-2 svc-overview-el flex flex-col gap-4" style="opacity: 0;">
          {/* Three HUD-stat mini-panels */}
          {[
            { label: 'Tailored to you', detail: 'Every engagement scoped around your goals.' },
            { label: 'Clear delivery', detail: 'Regular updates so you always know where things stand.' },
            { label: 'Ongoing support', detail: 'Full handoff documentation plus post-launch assistance.' },
          ].map((item, i) => (
            <div
              class="glass card-hover px-5 py-4 flex items-start gap-3"
              style={`border-left: 2px solid rgba(${theme.colorRgb}, 0.5); border-color: rgba(${theme.colorRgb}, 0.15);`}
            >
              <span
                class="glow-number font-display text-xl flex-shrink-0 mt-0.5"
                style={`color: rgba(${theme.colorRgb}, 0.7); text-shadow: 0 0 16px rgba(${theme.colorRgb}, 0.5);`}
              >0{i + 1}</span>
              <div>
                <p class="text-sm font-semibold mb-1" style="color: var(--color-text-primary);">{item.label}</p>
                <p class="text-xs leading-relaxed" style="color: var(--text-dim-aurora);">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════
      SERVICE DETAILS — Aurora-backed markdown content
     ═══════════════════════════════════════════════════════════ */}
  <section id="service-details" class="section-alt relative py-20 overflow-hidden reveal-section" aria-label="Service details">
    {/* Background glow effects */}
    <div
      class="absolute inset-0 pointer-events-none"
      style={`background: radial-gradient(ellipse 70% 50% at 80% 30%, rgba(${theme.colorRgb}, 0.05) 0%, transparent 70%);`}
      aria-hidden="true"
    ></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style={`background: radial-gradient(ellipse 50% 60% at 10% 80%, rgba(${theme.colorRgb}, 0.03) 0%, transparent 60%);`}
      aria-hidden="true"
    ></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Section header */}
      <div class="mb-12 svc-content-el" style="opacity: 0;">
        <span
          class="font-display text-xs tracking-widest py-1 px-3 rounded-full inline-block mb-4"
          style={`background: rgba(${theme.colorRgb}, 0.1); color: ${theme.colorLight}; border: 1px solid rgba(${theme.colorRgb}, 0.2);`}
        >
          Service Details
        </span>
        <h2 class="font-display text-3xl md:text-4xl" style="color: var(--color-text-primary);">
          Everything you get with {entry.data.title}
        </h2>
      </div>

      {/* Content glass panel */}
      <div class="svc-content-el" style="opacity: 0;">
        <GlassCard class="svc-details-card p-8 md:p-12">
          <div class="service-content">
            <Content />
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════
      WHY NIGHTIOUS — Premium stat-style cards with accent borders
     ═══════════════════════════════════════════════════════════ */}
  <section class="svc-why relative py-20 overflow-hidden" aria-label={`Why choose Nightious for ${entry.data.title}`}>
    {/* Background effects */}
    <div
      class="absolute inset-0 pointer-events-none"
      style={`background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(${theme.colorRgb}, 0.06) 0%, transparent 70%);`}
      aria-hidden="true"
    ></div>

    {/* Geometric SVG accent */}
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none"
      style="opacity: 0.05;"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <circle cx="15%" cy="30%" r="12%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin" style="transform-origin: 15% 30%;" />
      <circle cx="85%" cy="70%" r="10%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin-reverse" style="transform-origin: 85% 70%;" />
    </svg>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Section heading — full width */}
      <div class="mb-10 svc-why-el" style="opacity: 0;">
        <span
          class="font-display text-xs tracking-widest py-1 px-3 rounded-full inline-block mb-4"
          style={`background: rgba(${theme.colorRgb}, 0.1); color: ${theme.colorLight}; border: 1px solid rgba(${theme.colorRgb}, 0.2);`}
        >
          Why Nightious
        </span>
        <h2 class="font-display text-3xl md:text-4xl mb-3" style="color: var(--color-text-primary);">
          Why choose Nightious for {entry.data.title}?
        </h2>
        <p class="text-base leading-relaxed max-w-2xl" style="color: var(--color-text-muted);">
          We don't do cookie-cutter. Every {entry.data.category.toLowerCase()} engagement is scoped around your goals, your timeline, and your budget.
        </p>
      </div>

      {/* Three premium differentiator cards + CTA in a grid */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
        {/* Card 1 */}
        <div
          class="svc-why-card glass card-hover p-6 flex flex-col gap-4"
          style={`opacity: 0; border-left: 2px solid rgba(${theme.colorRgb}, 0.55); box-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.06), inset 0 0 20px rgba(${theme.colorRgb}, 0.02);`}
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
            style={`background: rgba(${theme.colorRgb}, 0.12); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
            aria-hidden="true"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke={theme.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-sm font-bold mb-2" style="color: var(--color-text-primary);">Built for your business</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Every solution is scoped around your specific goals and challenges — no generic packages.</p>
          </div>
          <div class="mt-auto neon-divider" aria-hidden="true"></div>
        </div>

        {/* Card 2 */}
        <div
          class="svc-why-card glass card-hover p-6 flex flex-col gap-4"
          style={`opacity: 0; border-left: 2px solid rgba(${theme.colorRgb}, 0.55); box-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.06), inset 0 0 20px rgba(${theme.colorRgb}, 0.02);`}
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
            style={`background: rgba(${theme.colorRgb}, 0.12); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
            aria-hidden="true"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke={theme.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-sm font-bold mb-2" style="color: var(--color-text-primary);">Fast, transparent delivery</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Clear milestones and regular updates so you always know exactly where your project stands.</p>
          </div>
          <div class="mt-auto neon-divider" aria-hidden="true"></div>
        </div>

        {/* Card 3 */}
        <div
          class="svc-why-card glass card-hover p-6 flex flex-col gap-4"
          style={`opacity: 0; border-left: 2px solid rgba(${theme.colorRgb}, 0.55); box-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.06), inset 0 0 20px rgba(${theme.colorRgb}, 0.02);`}
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
            style={`background: rgba(${theme.colorRgb}, 0.12); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
            aria-hidden="true"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke={theme.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-sm font-bold mb-2" style="color: var(--color-text-primary);">Post-launch support</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Full documentation handoff and ongoing support — we don't disappear once the work ships.</p>
          </div>
          <div class="mt-auto neon-divider" aria-hidden="true"></div>
        </div>
      </div>

      {/* CTA row */}
      <div class="svc-why-el flex flex-wrap gap-4" style="opacity: 0;">
        <a href="/contact" class="btn-primary text-base">
          Start a Conversation &rarr;
        </a>
        <a href="/services" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.3); color: ${theme.colorLight};`}>
          Browse All Services
        </a>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════
      RELATED SERVICES — Accent glow cards with aurora color headers
     ═══════════════════════════════════════════════════════════ */}
  {related.length > 0 && (
    <section class="svc-related section-alt py-16 overflow-hidden" aria-label="Related services">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* Section header */}
        <div class="mb-8 svc-related-header" style="opacity: 0;">
          <h2 class="font-display text-2xl mb-2" style="color: var(--color-text-primary);">
            Related services
          </h2>
          <div class="neon-divider" style="width: 40px; margin: 0;" aria-hidden="true"></div>
        </div>

        <ul class="grid grid-cols-1 sm:grid-cols-3 gap-5 list-none">
          {related.map(rel => {
            const relSlug = entrySlug(rel.id)
            const relTheme = serviceThemes[relSlug] ?? serviceThemes['website-solutions']
            const relEmoji = categoryEmoji[rel.data.category] ?? '🔧'
            return (
              <li class="svc-related-card" style="opacity: 0;">
                <a
                  href={`/services/${relSlug}`}
                  class="svc-related-link glass card-hover flex flex-col h-full overflow-hidden"
                  style={`--rel-color-rgb: ${relTheme.colorRgb};`}
                >
                  {/* Aurora color header — replaces photo */}
                  <div
                    class="svc-related-card-header relative overflow-hidden flex-shrink-0"
                    style={`height: 120px; background: linear-gradient(135deg, rgba(2,0,10,0.9) 0%, rgba(${relTheme.colorRgb}, 0.18) 50%, rgba(2,0,10,0.7) 100%);`}
                  >
                    {/* Animated accent glow */}
                    <div
                      class="svc-related-glow"
                      style={`background: radial-gradient(ellipse at 50% 100%, rgba(${relTheme.colorRgb}, 0.35) 0%, transparent 70%);`}
                      aria-hidden="true"
                    ></div>

                    {/* Geometric mini SVG */}
                    <svg class="absolute inset-0 w-full h-full pointer-events-none" style="opacity: 0.15;" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
                      <circle cx="80%" cy="50%" r="30%" fill="none" stroke={relTheme.color} stroke-width="0.6" class="geo-spin" style={`transform-origin: 80% 50%;`} />
                      <circle cx="20%" cy="50%" r="20%" fill="none" stroke={relTheme.color} stroke-width="0.4" class="geo-spin-reverse" style={`transform-origin: 20% 50%;`} />
                    </svg>

                    {/* Service icon — large, centered */}
                    <div class="absolute inset-0 flex items-center justify-center">
                      <span
                        class="text-3xl"
                        style={`filter: drop-shadow(0 0 12px rgba(${relTheme.colorRgb}, 0.6));`}
                        aria-hidden="true"
                      >{relEmoji}</span>
                    </div>

                    {/* Category badge — bottom left */}
                    <span
                      class="absolute bottom-3 left-3 font-display text-xs tracking-widest px-2 py-1 rounded-full"
                      style={`background: rgba(${relTheme.colorRgb}, 0.15); color: ${relTheme.colorLight}; border: 1px solid rgba(${relTheme.colorRgb}, 0.25); font-size: 8px; letter-spacing: 0.18em;`}
                    >{rel.data.category}</span>
                  </div>

                  <div class="p-5 flex flex-col gap-2 flex-1">
                    <h3 class="font-display text-sm" style="color: var(--color-text-primary);">{rel.data.title}</h3>
                    <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">{rel.data.tagline}</p>
                    <span
                      class="text-xs font-semibold mt-1 flex items-center gap-1"
                      style={`color: ${relTheme.colorLight};`}
                    >
                      Learn more
                      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    </section>
  )}
  </>
  )}

  <CtaSection
    heading={`Ready to talk about ${entry.data.title}?`}
    sub={`Tell us what you need. We'll get back to you as soon as possible with a clear plan.`}
    image={theme.ctaImage}
    transitionName={`svc-cta-img-${slug}`}
  />
  </div>
</ServiceLayout>

<noscript>
  <style>
    .svc-hero-el, .svc-overview-el, .svc-content-el,
    .svc-why-el, .svc-why-card, .svc-related-card, .svc-related-header {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<style is:global>
  /* ── Service markdown content ── */
  .service-content h2 {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .service-content ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .service-content li {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    position: relative;
  }

  .service-content li::before {
    content: '\203A';
    position: absolute;
    left: 0;
    color: var(--color-purple-mid);
    font-weight: 600;
  }

  .service-content strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .service-content p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  /* Details card clearfix */
  .svc-details-card::after {
    content: '';
    display: table;
    clear: both;
  }

  /* ── Geometric overlay animations ── */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes spin-slow-reverse {
    from { transform: rotate(360deg); }
    to   { transform: rotate(0deg); }
  }
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.08; }
    50%       { opacity: 0.2; }
  }

  .geo-spin         { animation: spin-slow 90s linear infinite; }
  .geo-spin-reverse { animation: spin-slow-reverse 120s linear infinite; }
  .geo-pulse        { animation: pulse-glow 4s ease-in-out infinite; }

  /* ── Related card hover glow (uses CSS var set on the <a> element) ── */
  .svc-related-link {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .svc-related-link:hover,
  .svc-related-link:focus-within {
    transform: translateY(-5px) scale(1.015);
    box-shadow:
      0 0 48px rgba(var(--rel-color-rgb), 0.22),
      0 0 0 1px rgba(var(--rel-color-rgb), 0.18);
  }
  .svc-related-glow {
    position: absolute;
    inset: 0;
    transition: opacity 0.3s ease;
    opacity: 0.8;
  }
  .svc-related-link:hover .svc-related-glow {
    opacity: 1;
  }

  /* ── Unified hero layout ── */
  .svc-hero-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    align-items: stretch;
  }

  .svc-hero-rule {
    height: 2px;
    width: 3rem;
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .svc-hero-grid {
      grid-template-columns: 1fr;
    }
    .svc-hero-grid > :last-child {
      display: none;
    }
  }

  /* ── Right column: glass feature preview panel ── */
  .svc-feat-panel {
    background: rgba(8, 4, 22, 0.52);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    padding: 1.25rem 1.4rem;
  }

  .svc-feat-panel-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
  }

  .svc-feat-panel-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 0.85rem;
  }

  .svc-feat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .svc-feat-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--color-text-primary);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .geo-spin,
    .geo-spin-reverse,
    .geo-pulse {
      animation: none;
    }

    .svc-hero-el,
    .svc-overview-el,
    .svc-content-el,
    .svc-why-el,
    .svc-why-card,
    .svc-related-card,
    .svc-related-header {
      opacity: 1 !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  let svcTl: gsap.core.Timeline | null = null

  function initServiceAnimations() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const hero = document.querySelector('.svc-hero')
    if (!hero) return

    // If reduced motion, just show everything immediately
    if (reduced) {
      document.querySelectorAll(
        '.svc-hero-el, .svc-overview-el, .svc-content-el, .svc-why-el, .svc-why-card, .svc-related-card, .svc-related-header'
      ).forEach(el => {
        ;(el as HTMLElement).style.opacity = '1'
        ;(el as HTMLElement).style.transform = 'none'
      })
      return
    }

    // ── Hero entrance timeline ──────────────────────────────────────────────
    const heroEls = hero.querySelectorAll('.svc-hero-el')
    svcTl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    const tl = svcTl

    heroEls.forEach((el, i) => {
      const fromVars: gsap.TweenVars = { opacity: 0, y: 20 }
      const toVars: gsap.TweenVars   = { opacity: 1, y: 0, duration: 0.55 }

      // Vary entry direction for visual interest
      if (i === 0) {
        fromVars.y = 8  // breadcrumb — subtle
      } else if (i % 3 === 0) {
        fromVars.x = -20
        delete fromVars.y
      }

      tl.fromTo(el, fromVars, toVars, i === 0 ? 0 : '-=0.3')
    })

    // ── Service overview reveal — from left ─────────────────────────────────
    const overview = document.querySelector('.svc-overview')
    if (overview) {
      const overviewEls = overview.querySelectorAll('.svc-overview-el')
      if (overviewEls.length > 0) {
        gsap.fromTo(
          overviewEls,
          { opacity: 0, x: -30 },
          {
            opacity: 1,
            x: 0,
            duration: 0.7,
            stagger: 0.18,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: overview,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          }
        )
      }
    }

    // ── Service details reveal — scale up ────────────────────────────────────
    const contentEls = document.querySelectorAll('.svc-content-el')
    if (contentEls.length > 0) {
      gsap.fromTo(
        contentEls,
        { opacity: 0, scale: 0.96, y: 20 },
        {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 0.75,
          stagger: 0.18,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '#service-details',
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        }
      )
    }

    // ── Why Nightious section heading — from right ────────────────────────
    const whySection = document.querySelector('.svc-why')
    if (whySection) {
      const whyHeadings = whySection.querySelectorAll('.svc-why-el')
      if (whyHeadings.length > 0) {
        gsap.fromTo(
          whyHeadings,
          { opacity: 0, x: 30 },
          {
            opacity: 1,
            x: 0,
            duration: 0.65,
            stagger: 0.15,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: whySection,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          }
        )
      }

      // Why cards — stagger up from below with individual delays
      const whyCards = whySection.querySelectorAll('.svc-why-card')
      if (whyCards.length > 0) {
        gsap.fromTo(
          whyCards,
          { opacity: 0, y: 40 },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.14,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: whySection,
              start: 'top 72%',
              toggleActions: 'play none none none',
            },
          }
        )
      }
    }

    // ── Related services — stagger scale from center ─────────────────────
    const relatedSection = document.querySelector('.svc-related')
    if (relatedSection) {
      const relatedHeader = relatedSection.querySelector('.svc-related-header')
      if (relatedHeader) {
        gsap.fromTo(
          relatedHeader,
          { opacity: 0, y: -20 },
          {
            opacity: 1,
            y: 0,
            duration: 0.5,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: relatedSection,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          }
        )
      }

      const relatedCards = relatedSection.querySelectorAll('.svc-related-card')
      if (relatedCards.length > 0) {
        gsap.fromTo(
          relatedCards,
          { opacity: 0, scale: 0.93, y: 20 },
          {
            opacity: 1,
            scale: 1,
            y: 0,
            duration: 0.55,
            stagger: 0.12,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: relatedSection,
              start: 'top 82%',
              toggleActions: 'play none none none',
            },
          }
        )
      }
    }
  }

  // Kill all ScrollTriggers before page swap to prevent memory leaks
  document.addEventListener('astro:before-swap', () => {
    svcTl?.kill(); svcTl = null
    ScrollTrigger.getAll().forEach(t => t.kill())
  })

  // Init after navigation (also fires on first load)
  document.addEventListener('astro:page-load', initServiceAnimations)
</script>
