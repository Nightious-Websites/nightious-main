          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════
      WHY NIGHTIOUS — Themed glass panel CTA section
     ═══════════════════════════════════════════════════════════ */}
  <section class="svc-why relative py-20" aria-label={`Why choose Nightious for ${entry.data.title}`}>
    {/* Background effects */}
    <div
      class="absolute inset-0 pointer-events-none"
      style={`background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(${theme.colorRgb}, 0.06) 0%, transparent 70%);`}
      aria-hidden="true"
    ></div>

    {/* Geometric SVG accent */}
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none"
      style="opacity: 0.04;"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <circle cx="15%" cy="30%" r="12%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin" style="transform-origin: 15% 30%;" />
      <circle cx="85%" cy="70%" r="10%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin-reverse" style="transform-origin: 85% 70%;" />
      <circle cx="50%" cy="50%" r="2" fill={theme.color} fill-opacity="0.2" class="geo-pulse" />
      <circle cx="20%" cy="75%" r="1.5" fill={theme.color} fill-opacity="0.15" class="geo-pulse" />
      <circle cx="80%" cy="25%" r="1.5" fill={theme.color} fill-opacity="0.15" class="geo-pulse" />
    </svg>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        {/* Left column — heading + CTA */}
        <div class="svc-why-el" style="opacity: 0;">
          <span
            class="font-display text-xs tracking-widest py-1 px-3 rounded-full inline-block mb-6"
            style={`background: rgba(${theme.colorRgb}, 0.1); color: ${theme.colorLight}; border: 1px solid rgba(${theme.colorRgb}, 0.2);`}
          >
            Why Nightious
          </span>
          <h2 class="font-display text-3xl md:text-4xl mb-6" style="color: var(--color-text-primary);">
            Why choose Nightious for {entry.data.title}?
          </h2>
          <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
            We don't do cookie-cutter. Every {entry.data.category.toLowerCase()} engagement is scoped around your goals, your timeline, and your budget.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary text-base">
              Start a Conversation &rarr;
            </a>
            <a href="/services" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.3); color: ${theme.colorLight};`}>
              Browse All Services
            </a>
          </div>
        </div>

        {/* Right column — value cards */}
        <div class="flex flex-col gap-4 svc-why-el" style="opacity: 0;">
          <div
            class="glass p-6 flex items-start gap-4 card-hover"
            style={`border-color: rgba(${theme.colorRgb}, 0.2);`}
          >
            <div
              class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-lg"
              style={`background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
              aria-hidden="true"
            >&#9989;</div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: var(--color-text-primary);">Tailored to your business</p>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Every solution is scoped around your specific goals and challenges — no generic packages.</p>
            </div>
          </div>

          <div
            class="glass p-6 flex items-start gap-4 card-hover"
            style={`border-color: rgba(${theme.colorRgb}, 0.2);`}
          >
            <div
              class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-lg"
              style={`background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
              aria-hidden="true"
            >&#9889;</div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: var(--color-text-primary);">Fast, transparent delivery</p>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Clear milestones and regular updates so you always know exactly where your project stands.</p>
            </div>
          </div>

          <div
            class="glass p-6 flex items-start gap-4 card-hover"
            style={`border-color: rgba(${theme.colorRgb}, 0.2);`}
          >
            <div
              class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-lg"
              style={`background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.25);`}
              aria-hidden="true"
            >&#128172;</div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: var(--color-text-primary);">Post-launch support</p>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">Full documentation handoff and ongoing support — we don't disappear once the work ships.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════
      RELATED SERVICES (shared across all variants)
     ═══════════════════════════════════════════════════════════ */}
  {related.length > 0 && (
    <section class="svc-related py-16" aria-label="Related services">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl mb-8" style="color: var(--color-text-primary);">
          Related services
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-3 gap-5 list-none">
          {related.map(rel => {
            const relSlug = entrySlug(rel.id)
            const relTheme = serviceThemes[relSlug] ?? serviceThemes['website-solutions']
            return (
              <li class="svc-related-card" style="opacity: 0;">
                <a
                  href={`/services/${relSlug}`}
                  class="glass card-hover flex flex-col h-full overflow-hidden"
                >
                  <div class="relative overflow-hidden" style="height: 140px; flex-shrink: 0;">
                    <img
                      src={relTheme.heroImage}
                      alt=""
                      aria-hidden="true"
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    <div
                      class="absolute inset-0"
                      style={`background: linear-gradient(to bottom, rgba(${relTheme.colorRgb}, 0.2) 0%, rgba(2,0,10,0.6) 100%);`}
                      aria-hidden="true"
                    ></div>
                    <span
                      class="absolute bottom-3 left-3 text-xl"
                      aria-hidden="true"
                    >{categoryEmoji[rel.data.category] ?? '🔧'}</span>
