                    >Learn more &rarr;</span>
                  </div>
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    </section>
  )}

  <CtaSection
    heading={`Ready to talk about ${entry.data.title}?`}
    sub={`Tell us what you need. We'll reply within 4 business hours with a clear plan.`}
  />
</ServiceLayout>

<style is:global>
  .service-content h2 {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .service-content ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .service-content li {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    position: relative;
  }

  .service-content li::before {
    content: '\203A';
    position: absolute;
    left: 0;
    color: var(--color-purple-mid);
    font-weight: 600;
  }

  .service-content strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .service-content p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  /* Details card — clear float after content */
  .svc-details-card::after {
    content: '';
    display: table;
    clear: both;
  }

  /* Float image responsive behaviour */
  @media (max-width: 1023px) {
    .svc-details-image-float .lg\:float-right {
      float: none !important;
      width: 100% !important;
      margin-left: 0 !important;
    }
  }

  /* Geometric overlay animations */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes spin-slow-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.08; }
    50% { opacity: 0.18; }
  }

  .geo-spin {
    animation: spin-slow 90s linear infinite;
  }

  .geo-spin-reverse {
    animation: spin-slow-reverse 120s linear infinite;
  }

  .geo-pulse {
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .geo-spin,
    .geo-spin-reverse,
    .geo-pulse {
      animation: none;
    }

    /* Ensure animated elements are visible even if JS fails */
    .svc-hero-el,
    .svc-overview-el,
    .svc-content-el,
    .svc-why-el,
    .svc-related-card {
      opacity: 1 !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  function initServiceAnimations() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const hero = document.querySelector('.svc-hero')
    if (!hero) return

    const heroEls = hero.querySelectorAll('.svc-hero-el')

    // If reduced motion, just show everything
    if (reduced) {
      document.querySelectorAll('.svc-hero-el, .svc-overview-el, .svc-content-el, .svc-why-el, .svc-related-card').forEach(el => {
        ;(el as HTMLElement).style.opacity = '1'
      })
      return
    }

    // Hero text entrance — sequential fade-in
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    heroEls.forEach((el, i) => {
      tl.fromTo(
        el,
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.5 },
        i === 0 ? 0 : `-=0.3`
      )
    })

    // Hero background parallax
    const heroBg = hero.querySelector('.svc-hero-bg')
    if (heroBg) {
      gsap.to(heroBg, {
        y: -50,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      })
    }

    // Service overview section reveal
    const overview = document.querySelector('.svc-overview')
    if (overview) {
      const overviewEls = overview.querySelectorAll('.svc-overview-el')
      if (overviewEls.length > 0) {
        gsap.fromTo(
          overviewEls,
          { opacity: 0, y: 30 },
          {
            opacity: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.2,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: overview,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          }
        )
      }
    }

    // Service details content reveal
    const contentEls = document.querySelectorAll('.svc-content-el')
    if (contentEls.length > 0) {
      gsap.fromTo(
        contentEls,
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          stagger: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '#service-details',
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        }
      )
    }

    // Why Nightious section reveal
    const whySection = document.querySelector('.svc-why')
    if (whySection) {
      const whyEls = whySection.querySelectorAll('.svc-why-el')
      if (whyEls.length > 0) {
        gsap.fromTo(
          whyEls,
          { opacity: 0, y: 30 },
          {
            opacity: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.2,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: whySection,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          }
        )
      }
    }

    // Related services stagger reveal
    const relatedCards = document.querySelectorAll('.svc-related-card')
    if (relatedCards.length > 0) {
      gsap.fromTo(
        relatedCards,
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.12,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.svc-related',
            start: 'top 85%',
            toggleActions: 'play none none none',
          },
        }
      )
    }
  }

  // Kill all ScrollTriggers before page swap to prevent memory leaks
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach(t => t.kill())
  })

  // Init after navigation
  document.addEventListener('astro:page-load', initServiceAnimations)
</script>
