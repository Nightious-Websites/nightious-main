              class="w-full h-auto object-cover rounded-xl"
              loading="lazy"
              style="aspect-ratio: 21/9; max-height: 320px;"
            />
            <div
              class="absolute inset-0 rounded-xl"
              style={`background: linear-gradient(to right, rgba(2,0,10,0.6) 0%, rgba(${theme.colorRgb}, 0.12) 50%, rgba(2,0,10,0.6) 100%);`}
              aria-hidden="true"
            ></div>
            <div
              class="absolute inset-0 flex items-center justify-center px-8"
            >
              <p
                class="font-display text-lg md:text-xl text-center max-w-2xl"
                style="color: var(--color-text-primary); text-shadow: 0 2px 16px rgba(0,0,0,0.7);"
              >
                {entry.data.description}
              </p>
