---
import ServiceLayout from '@/layouts/ServiceLayout.astro'
import GlassCard from '@/components/ui/GlassCard.astro'
import CtaSection from '@/components/sections/CtaSection.astro'
import AuroraBackground from '@/components/ui/AuroraBackground.astro'
import ConstellationParticles from '@/components/ui/ConstellationParticles.astro'
import HudBrackets from '@/components/ui/HudBrackets.astro'
import { getAllServices, entrySlug } from '@/utils/services'
import { getServiceTheme, serviceThemes } from '@/utils/serviceTheme'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const services = await getCollection('services')
  return services.map(service => ({
    params: { slug: entrySlug(service.id) },
    props: { entry: service },
  }))
}

const { entry } = Astro.props
const { Content } = await entry.render()
const slug = entrySlug(entry.id)
const theme = getServiceTheme(slug)

// Compute layout variant from alphabetical index
const allSlugs = [
  'ai-integration',
  'computer-services',
  'custom-services',
  'digital-marketing',
  'domain-solutions',
  'email-solutions',
  'online-privacy',
  'organizational-effectiveness',
  'software-services',
  'streaming-consultation',
  'training-documentation',
  'website-solutions',
]
const slugIndex = allSlugs.indexOf(slug)
const layoutVariant = (slugIndex >= 0 ? slugIndex : 0) % 4

// Get related services
const allServices = await getAllServices()
const related = allServices.filter(s => entry.data.relatedSlugs.includes(entrySlug(s.id)))

const categoryEmoji: Record<string, string> = {
  Website: '🌐',
  Email: '✉️',
  Domain: '🔗',
  AI: '🤖',
  Marketing: '📈',
  Computers: '💻',
  Streaming: '🎙️',
  Privacy: '🔒',
  Operations: '⚙️',
  Software: '🖥️',
  Custom: '✨',
  Training: '📚',
}

const emoji = categoryEmoji[entry.data.category] ?? '🔧'

// Stat bar items for variant 3
const statItems = [
  { label: 'Delivery', value: 'Fast' },
  { label: 'Support', value: '24/7' },
  { label: 'Approach', value: 'Custom' },
  { label: 'Clients', value: '50+' },
]
---

<ServiceLayout
  title={entry.data.title}
  description={entry.data.description}
  slug={slug}
  category={entry.data.category}
>
  {/* ═══════════════════════════════════════════════════════════
      HERO — Variant 0: Split Hero Left
      Aurora fills full section. Left: glass-strong content panel.
      Right: geometric SVGs floating over aurora.
     ═══════════════════════════════════════════════════════════ */}
  {layoutVariant === 0 && (
    <section
      class="svc-hero relative overflow-hidden"
      style="min-height: 560px;"
      aria-label={`${entry.data.title} hero`}
      data-variant="0"
    >
      {/* Aurora base layer */}
      <AuroraBackground variant="subtle" colors="accent" accentRgb={theme.colorRgb} zIndex={0} />

      {/* Deep bg base */}
      <div class="absolute inset-0" style="background: var(--color-bg-deep); z-index: -1;" aria-hidden="true"></div>

      {/* Particles */}
      <ConstellationParticles density="low" colors="purple-only" zIndex={2} />

      {/* HUD brackets */}
      <HudBrackets color={`rgba(${theme.colorRgb}, 0.35)`} zIndex={20} />

      {/* Scan line */}
      <div class="scan-line" style="z-index: 4;" aria-hidden="true"></div>

      <div class="relative grid grid-cols-1 lg:grid-cols-2" style="min-height: 560px; z-index: 10;">

        {/* Left — glass-strong content panel */}
        <div class="relative flex items-center" style="z-index: 10;">
          {/* Subtle tinted glass backdrop on the left half */}
          <div
            class="absolute inset-0 glass-strong"
            style={`border-radius: 0; background: rgba(2,0,10,0.55); backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);`}
            aria-hidden="true"
          ></div>
          {/* Accent edge glow on right border */}
          <div
            class="absolute top-0 right-0 bottom-0"
            style={`width: 1px; background: linear-gradient(to bottom, transparent, rgba(${theme.colorRgb}, 0.5) 40%, rgba(${theme.colorRgb}, 0.5) 60%, transparent); z-index: 1;`}
            aria-hidden="true"
          ></div>

          <div class="relative pt-28 pb-16 px-6 sm:px-10 lg:px-14 w-full" style="z-index: 10;">
            {/* Breadcrumb */}
            <nav aria-label="Breadcrumb" class="mb-8 svc-hero-el" style="opacity: 0;">
              <ol class="flex items-center gap-2 text-xs" style="color: var(--color-text-muted);">
                <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
                <li aria-hidden="true">/</li>
                <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
                <li aria-hidden="true">/</li>
                <li style={`color: ${theme.colorLight};`} aria-current="page">{entry.data.title}</li>
              </ol>
            </nav>

            <div class="max-w-lg">
              {/* Status pill */}
              <div
                class="svc-hero-el svc-status-pill"
                style={`opacity: 0; border-color: rgba(${theme.colorRgb}, 0.25); color: rgba(${theme.colorRgb}, 0.85); background: rgba(${theme.colorRgb}, 0.08);`}
              >
                <span class="svc-live-dot" style={`background: rgba(${theme.colorRgb}, 0.9); box-shadow: 0 0 8px rgba(${theme.colorRgb}, 0.7);`} aria-hidden="true"></span>
                <span class="font-display" style="font-size: 9px; letter-spacing: 0.22em;">{entry.data.title.toUpperCase()} &bull; ACTIVE</span>
              </div>

              {/* Service icon */}
              <div
                class="svc-hero-el w-14 h-14 rounded-xl flex items-center justify-center text-2xl mb-5 mt-4"
                style={`opacity: 0; background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.3); box-shadow: 0 0 24px rgba(${theme.colorRgb}, 0.15);`}
                aria-hidden="true"
              >
                {emoji}
              </div>

              {/* Category eyebrow */}
              <span class="svc-hero-el glass-pill mb-4 inline-flex" style={`opacity: 0; color: rgba(${theme.colorRgb}, 0.8); background: rgba(${theme.colorRgb}, 0.08); border-color: rgba(${theme.colorRgb}, 0.2);`}>
                <span class="glass-pill-dot" style={`background: rgba(${theme.colorRgb}, 0.8);`} aria-hidden="true"></span>
                {entry.data.category}
              </span>

              {/* Headline */}
              <h1
                class="svc-hero-el font-display text-glow text-4xl md:text-5xl mb-4"
                style={`opacity: 0; color: var(--text-primary-aurora); font-weight: 900; line-height: 1.08; letter-spacing: -0.025em; text-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.4), 0 0 80px rgba(168,85,247,0.2);`}
              >
                {entry.data.title}
              </h1>

              {/* Gradient divider */}
              <div class="svc-hero-el gradient-divider mb-5 ml-0" style={`opacity: 0; background: linear-gradient(90deg, rgba(${theme.colorRgb}, 0.8), rgba(168,85,247,0.3)); margin-left: 0; transform-origin: left;`} aria-hidden="true"></div>

              {/* Tagline */}
              <p class="svc-hero-el text-lg leading-relaxed mb-8" style="opacity: 0; color: var(--text-muted-aurora);">
                {entry.data.tagline}
              </p>

              {/* CTA */}
              <div class="svc-hero-el flex flex-wrap items-center gap-4" style="opacity: 0;">
                <a href="/contact" class="btn-primary text-base">
                  Get a Free Quote
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="#service-details" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.35); color: ${theme.colorLight};`}>
                  What's included &darr;
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* Right — geometric SVGs floating over aurora */}
        <div class="relative overflow-hidden svc-hero-geo-panel" style="min-height: 320px;">
          {/* Extra accent glow from the right */}
          <div
            class="absolute inset-0 pointer-events-none"
            style={`background: radial-gradient(ellipse at 65% 50%, rgba(${theme.colorRgb}, 0.14) 0%, transparent 65%);`}
            aria-hidden="true"
          ></div>

          {/* Geometric overlay — floating circles */}
          <svg
            class="absolute inset-0 w-full h-full pointer-events-none svc-geo-overlay"
            style="z-index: 3; opacity: 0.18;"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid slice"
          >
            <circle cx="70%" cy="30%" r="18%" fill="none" stroke={theme.color} stroke-width="0.8" class="geo-spin" style="transform-origin: 70% 30%;" />
            <circle cx="80%" cy="60%" r="12%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin-reverse" style="transform-origin: 80% 60%;" />
            <circle cx="55%" cy="70%" r="8%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin" style="transform-origin: 55% 70%;" />
            <circle cx="65%" cy="45%" r="3%" fill={theme.color} fill-opacity="0.15" class="geo-pulse" />
            <circle cx="85%" cy="25%" r="2%" fill={theme.color} fill-opacity="0.1" class="geo-pulse" />
            <line x1="40%" y1="0" x2="100%" y2="80%" stroke={theme.color} stroke-width="0.4" stroke-dasharray="6 14" opacity="0.5" />
            <line x1="20%" y1="100%" x2="90%" y2="10%" stroke={theme.color} stroke-width="0.3" stroke-dasharray="4 16" opacity="0.3" />
          </svg>

          {/* HUD corner annotation */}
          <div
            class="absolute bottom-8 right-8 font-display text-xs tracking-widest"
            style={`color: rgba(${theme.colorRgb}, 0.5); z-index: 5; letter-spacing: 0.2em; font-size: 9px;`}
            aria-hidden="true"
          >
            {entry.data.category.toUpperCase()} / SYS
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ═══════════════════════════════════════════════════════════
      HERO — Variant 1: Centered Hero
      Full-width aurora with particles and concentric ring SVGs.
     ═══════════════════════════════════════════════════════════ */}
  {layoutVariant === 1 && (
    <section
      class="svc-hero relative overflow-hidden"
      style="min-height: 560px;"
      aria-label={`${entry.data.title} hero`}
      data-variant="1"
    >
      {/* Deep bg base */}
      <div class="absolute inset-0" style="background: var(--color-bg-deep); z-index: -1;" aria-hidden="true"></div>

      {/* Aurora base layer */}
      <AuroraBackground variant="subtle" colors="accent" accentRgb={theme.colorRgb} zIndex={0} />

      {/* Particles */}
      <ConstellationParticles density="low" colors="purple-only" zIndex={2} />

      {/* HUD brackets */}
      <HudBrackets color={`rgba(${theme.colorRgb}, 0.35)`} zIndex={20} />

      {/* Scan line */}
      <div class="scan-line" style="z-index: 4;" aria-hidden="true"></div>

      {/* Geometric SVG — concentric rings from top */}
      <svg
        class="absolute inset-0 w-full h-full pointer-events-none svc-geo-overlay"
        style="z-index: 3; opacity: 0.14;"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid slice"
      >
        <defs>
          <radialGradient id={`rg-v1-${slug}`} cx="50%" cy="0%" r="70%">
            <stop offset="0%" stop-color={theme.color} stop-opacity="0.6" />
            <stop offset="100%" stop-color={theme.color} stop-opacity="0" />
          </radialGradient>
        </defs>
        <circle cx="50%" cy="-10%" r="45%" fill="none" stroke={theme.color} stroke-width="1" class="geo-spin" style="transform-origin: 50% -10%;" />
        <circle cx="50%" cy="-10%" r="30%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin-reverse" style="transform-origin: 50% -10%;" />
        <circle cx="50%" cy="-10%" r="15%" fill="none" stroke={theme.color} stroke-width="0.5" class="geo-spin" style="transform-origin: 50% -10%;" />
        <line x1="0" y1="60%" x2="100%" y2="60%" stroke={theme.color} stroke-width="0.5" stroke-dasharray="4 8" opacity="0.5" />
        <line x1="50%" y1="0" x2="50%" y2="100%" stroke={theme.color} stroke-width="0.5" stroke-dasharray="4 16" opacity="0.4" />
        <polyline points="0,0 60,0 60,60" fill="none" stroke={theme.color} stroke-width="1" />
        <line x1="100%" y1="0" x2="100%" y2="60" stroke={theme.color} stroke-width="1" />
        <line x1="100%" y1="0" x2="94%" y2="0" stroke={theme.color} stroke-width="1" />
      </svg>

      <div class="relative pt-32 pb-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="z-index: 10;">
        {/* Breadcrumb */}
        <nav aria-label="Breadcrumb" class="mb-8 svc-hero-el" style="opacity: 0;">
          <ol class="flex items-center justify-center gap-2 text-xs" style="color: var(--color-text-muted);">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
            <li aria-hidden="true">/</li>
            <li style={`color: ${theme.colorLight};`} aria-current="page">{entry.data.title}</li>
          </ol>
        </nav>

        <div class="max-w-3xl mx-auto">
          {/* Status pill */}
          <div
            class="svc-hero-el svc-status-pill inline-flex mb-4"
            style={`opacity: 0; border-color: rgba(${theme.colorRgb}, 0.25); color: rgba(${theme.colorRgb}, 0.85); background: rgba(${theme.colorRgb}, 0.08);`}
          >
            <span class="svc-live-dot" style={`background: rgba(${theme.colorRgb}, 0.9); box-shadow: 0 0 8px rgba(${theme.colorRgb}, 0.7);`} aria-hidden="true"></span>
            <span class="font-display" style="font-size: 9px; letter-spacing: 0.22em;">{entry.data.title.toUpperCase()} &bull; ACTIVE</span>
          </div>

          {/* Service icon */}
          <div
            class="svc-hero-el w-16 h-16 rounded-2xl flex items-center justify-center text-3xl mb-5 mx-auto"
            style={`opacity: 0; background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.3); box-shadow: 0 0 32px rgba(${theme.colorRgb}, 0.2);`}
            aria-hidden="true"
          >
            {emoji}
          </div>

          {/* Category eyebrow */}
          <span class="svc-hero-el glass-pill mb-6 inline-flex" style={`opacity: 0; color: rgba(${theme.colorRgb}, 0.8); background: rgba(${theme.colorRgb}, 0.08); border-color: rgba(${theme.colorRgb}, 0.2);`}>
            <span class="glass-pill-dot" style={`background: rgba(${theme.colorRgb}, 0.8);`} aria-hidden="true"></span>
            {entry.data.category}
          </span>

          {/* Headline */}
          <h1
            class="svc-hero-el font-display text-glow text-4xl md:text-5xl lg:text-6xl mb-5"
            style={`opacity: 0; color: var(--text-primary-aurora); font-weight: 900; line-height: 1.06; letter-spacing: -0.03em; text-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.45), 0 0 80px rgba(168,85,247,0.2);`}
          >
            {entry.data.title}
          </h1>

          {/* Gradient divider — centered */}
          <div class="svc-hero-el gradient-divider mb-6" style={`opacity: 0; background: linear-gradient(90deg, rgba(${theme.colorRgb}, 0.8), rgba(168,85,247,0.3)); transform-origin: center;`} aria-hidden="true"></div>

          {/* Tagline */}
          <p class="svc-hero-el text-lg md:text-xl leading-relaxed mb-8" style="opacity: 0; color: var(--text-muted-aurora);">
            {entry.data.tagline}
          </p>

          {/* CTA */}
          <div class="svc-hero-el flex flex-wrap items-center justify-center gap-4" style="opacity: 0;">
            <a href="/contact" class="btn-primary text-base">
              Get a Free Quote
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#service-details" class="btn-ghost text-sm" style={`border-color: rgba(${theme.colorRgb}, 0.35); color: ${theme.colorLight};`}>
              What's included &darr;
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ═══════════════════════════════════════════════════════════
      HERO — Variant 2: Split Hero Right (mirror of Variant 0)
      Left: geometric SVGs over aurora. Right: glass-strong content.
     ═══════════════════════════════════════════════════════════ */}
  {layoutVariant === 2 && (
    <section
      class="svc-hero relative overflow-hidden"
      style="min-height: 560px;"
      aria-label={`${entry.data.title} hero`}
      data-variant="2"
    >
      {/* Deep bg base */}
      <div class="absolute inset-0" style="background: var(--color-bg-deep); z-index: -1;" aria-hidden="true"></div>

      {/* Aurora base layer */}
      <AuroraBackground variant="subtle" colors="accent" accentRgb={theme.colorRgb} zIndex={0} />

      {/* Particles */}
      <ConstellationParticles density="low" colors="purple-only" zIndex={2} />

      {/* HUD brackets */}
      <HudBrackets color={`rgba(${theme.colorRgb}, 0.35)`} zIndex={20} />

      {/* Scan line */}
      <div class="scan-line" style="z-index: 4;" aria-hidden="true"></div>

      <div class="relative grid grid-cols-1 lg:grid-cols-2" style="min-height: 560px; z-index: 10;">

        {/* Left — geometric SVGs floating over aurora */}
        <div class="relative overflow-hidden order-2 lg:order-1" style="min-height: 320px;">
          {/* Accent glow left side */}
          <div
            class="absolute inset-0 pointer-events-none"
            style={`background: radial-gradient(ellipse at 35% 50%, rgba(${theme.colorRgb}, 0.14) 0%, transparent 65%);`}
            aria-hidden="true"
          ></div>

          {/* Geometric overlay — diagonal lines and dots */}
          <svg
            class="absolute inset-0 w-full h-full pointer-events-none svc-geo-overlay"
            style="z-index: 3; opacity: 0.18;"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid slice"
          >
            <line x1="0" y1="0" x2="100%" y2="100%" stroke={theme.color} stroke-width="0.5" stroke-dasharray="6 10" />
            <line x1="20%" y1="0" x2="100%" y2="80%" stroke={theme.color} stroke-width="0.5" stroke-dasharray="6 10" />
            <line x1="0" y1="20%" x2="80%" y2="100%" stroke={theme.color} stroke-width="0.5" stroke-dasharray="6 10" />
            <line x1="40%" y1="0" x2="100%" y2="60%" stroke={theme.color} stroke-width="0.3" stroke-dasharray="4 12" />
            <circle cx="25%" cy="35%" r="3" fill={theme.color} fill-opacity="0.3" class="geo-pulse" />
            <circle cx="45%" cy="55%" r="2.5" fill={theme.color} fill-opacity="0.25" class="geo-pulse" />
            <circle cx="15%" cy="70%" r="2" fill={theme.color} fill-opacity="0.2" class="geo-pulse" />
            <circle cx="60%" cy="25%" r="2" fill={theme.color} fill-opacity="0.2" class="geo-pulse" />
          </svg>

          {/* HUD corner annotation */}
          <div
            class="absolute bottom-8 left-8 font-display text-xs tracking-widest"
            style={`color: rgba(${theme.colorRgb}, 0.5); z-index: 5; letter-spacing: 0.2em; font-size: 9px;`}
            aria-hidden="true"
          >
            SYS / {entry.data.category.toUpperCase()}
          </div>
        </div>

        {/* Right — glass-strong content panel */}
        <div class="relative flex items-center order-1 lg:order-2" style="z-index: 10;">
          {/* Glass backdrop */}
          <div
            class="absolute inset-0"
            style={`background: rgba(2,0,10,0.55); backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);`}
            aria-hidden="true"
          ></div>
          {/* Accent edge glow on left border */}
          <div
            class="absolute top-0 left-0 bottom-0"
            style={`width: 1px; background: linear-gradient(to bottom, transparent, rgba(${theme.colorRgb}, 0.5) 40%, rgba(${theme.colorRgb}, 0.5) 60%, transparent); z-index: 1;`}
            aria-hidden="true"
          ></div>

          <div class="relative pt-28 pb-16 px-6 sm:px-10 lg:px-14 w-full" style="z-index: 10;">
            {/* Breadcrumb */}
            <nav aria-label="Breadcrumb" class="mb-8 svc-hero-el" style="opacity: 0;">
              <ol class="flex items-center gap-2 text-xs" style="color: var(--color-text-muted);">
                <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
                <li aria-hidden="true">/</li>
                <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
                <li aria-hidden="true">/</li>
                <li style={`color: ${theme.colorLight};`} aria-current="page">{entry.data.title}</li>
              </ol>
            </nav>

            <div class="max-w-lg">
              {/* Status pill */}
              <div
                class="svc-hero-el svc-status-pill"
                style={`opacity: 0; border-color: rgba(${theme.colorRgb}, 0.25); color: rgba(${theme.colorRgb}, 0.85); background: rgba(${theme.colorRgb}, 0.08);`}
              >
                <span class="svc-live-dot" style={`background: rgba(${theme.colorRgb}, 0.9); box-shadow: 0 0 8px rgba(${theme.colorRgb}, 0.7);`} aria-hidden="true"></span>
                <span class="font-display" style="font-size: 9px; letter-spacing: 0.22em;">{entry.data.title.toUpperCase()} &bull; ACTIVE</span>
              </div>

              {/* Service icon */}
              <div
                class="svc-hero-el w-14 h-14 rounded-xl flex items-center justify-center text-2xl mb-5 mt-4"
                style={`opacity: 0; background: rgba(${theme.colorRgb}, 0.15); border: 1px solid rgba(${theme.colorRgb}, 0.3); box-shadow: 0 0 24px rgba(${theme.colorRgb}, 0.15);`}
                aria-hidden="true"
              >
                {emoji}
              </div>

              {/* Category eyebrow */}
              <span class="svc-hero-el glass-pill mb-4 inline-flex" style={`opacity: 0; color: rgba(${theme.colorRgb}, 0.8); background: rgba(${theme.colorRgb}, 0.08); border-color: rgba(${theme.colorRgb}, 0.2);`}>
                <span class="glass-pill-dot" style={`background: rgba(${theme.colorRgb}, 0.8);`} aria-hidden="true"></span>
                {entry.data.category}
              </span>

              {/* Headline */}
              <h1
                class="svc-hero-el font-display text-glow text-4xl md:text-5xl mb-4"
                style={`opacity: 0; color: var(--text-primary-aurora); font-weight: 900; line-height: 1.08; letter-spacing: -0.025em; text-shadow: 0 0 40px rgba(${theme.colorRgb}, 0.4), 0 0 80px rgba(168,85,247,0.2);`}
              >
                {entry.data.title}
              </h1>

              {/* Gradient divider */}
