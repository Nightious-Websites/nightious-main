      {/* Full-width content with inline image accents */}
      <div class="svc-content-el" style="opacity: 0;">
        <GlassCard class="svc-details-card p-8 md:p-12">
          {/* Inline image — floated on desktop */}
          <div class="svc-details-image-float">
            <div class="relative rounded-xl overflow-hidden mb-6 lg:mb-0 lg:float-right lg:ml-8 lg:w-2/5">
              <img
                src={theme.contentImage1}
                alt={`${entry.data.title} details`}
                class="w-full h-auto object-cover rounded-xl"
                loading="lazy"
                style="aspect-ratio: 16/10;"
              />
              <div
                class="absolute inset-0 rounded-xl"
                style={`background: linear-gradient(180deg, transparent 50%, rgba(${theme.colorRgb}, 0.15) 100%);`}
                aria-hidden="true"
              ></div>
            </div>
          </div>

          <div class="service-content">
            <Content />
