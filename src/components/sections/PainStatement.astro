---
const comparisons = [
  {
    them: "We'll perform a comprehensive network infrastructure assessment and remediate all identified threat vectors.",
    us: "We'll check everything and fix what's broken. We'll explain every step.",
  },
  {
    them: 'Leveraging AI-driven automation to optimize your GTM strategy across omnichannel touchpoints.',
    us: "We'll help you get more customers online without wasting your marketing budget.",
  },
  {
    them: 'Provisioning SSO with SAML 2.0 federation and MFA enforcement across your identity provider.',
    us: "We'll set up secure logins so your team can work safely from anywhere.",
  },
]
---

<section
  class="py-20 reveal-section overflow-hidden"
  aria-label="Jargon-Free Zone"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left column: Jargon-Free Zone comparisons -->
      <div>
        <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">THE JARGON-FREE ZONE</p>
        <h2 class="font-display text-3xl md:text-4xl mb-10" style="color: var(--color-text-primary);">
          What other IT companies say.
          <br />
          <span class="gradient-text">What we say.</span>
        </h2>

        <ul class="flex flex-col gap-5 list-none">
          {comparisons.map(comp => (
            <li class="glass card-hover p-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- THEM column -->
                <div class="sm:border-r sm:pr-4" style="border-color: rgba(168, 85, 247, 0.15);">
                  <p class="font-display text-xs tracking-widest mb-2" style="color: rgba(239, 68, 68, 1);">THEM</p>
                  <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{comp.them}</p>
                </div>
                <!-- US column -->
                <div>
                  <p class="font-display text-xs tracking-widest mb-2" style="color: var(--color-purple-mid);">US</p>
                  <p class="text-sm leading-relaxed" style="color: var(--color-text-primary);">{comp.us}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right column: Photo panel -->
      <div class="relative rounded-2xl overflow-hidden" style="min-height: 480px;">
        <img
          src="/images/photos/home-pain.webp"
          alt="Small business owner working on their digital presence"
          class="w-full h-full object-cover absolute inset-0"
          loading="lazy"
          width="1200"
          height="800"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(135deg, rgba(2,0,10,0.5) 0%, rgba(120,81,169,0.2) 100%);"
          aria-hidden="true"
        ></div>

        <!-- Floating quote card -->
        <div class="absolute bottom-6 right-6 left-6 glass p-5">
          <p class="text-sm italic leading-relaxed mb-3" style="color: var(--color-text-muted);">
            "First IT company that didn't talk down to me. I finally understand what I'm paying for."
          </p>
          <div class="flex items-center gap-2">
            <img
              src="/images/logos/icon-color.png"
              alt=""
              width="24"
              height="24"
              class="w-6 h-6 object-contain"
              aria-hidden="true"
            />
            <span class="text-xs font-semibold" style="color: var(--color-purple-light); font-family: 'Exo 2', sans-serif;">
              Sarah M. &middot; TechStart Inc.
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
