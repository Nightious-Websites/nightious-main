---
import GradientBlobs from '@/components/ui/GradientBlobs.astro'
---

<section
  class="relative min-h-dvh flex flex-col items-center justify-center overflow-hidden pt-16"
  aria-label="Hero"
>
  <!-- Particle field background -->
  <div
    class="absolute inset-0 z-0 pointer-events-none"
    style="background-color: var(--color-bg-deep);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 z-0 pointer-events-none"
    style="background-image: radial-gradient(circle, rgba(168, 85, 247, 0.4) 1px, transparent 1px); background-size: 28px 28px; opacity: 0.15;"
    aria-hidden="true"
  ></div>

  <!-- Futuristic grid overlay -->
  <div class="absolute inset-0 bg-grid pointer-events-none" style="z-index: 3;" aria-hidden="true"></div>

  <!-- Scan line -->
  <div class="scan-line" aria-hidden="true"></div>

  <!-- Gradient blobs -->
  <div class="absolute inset-0 z-10" aria-hidden="true">
    <GradientBlobs />
  </div>

  <!-- Large icon watermark -->
  <div class="absolute inset-0 z-10 flex items-center justify-end pointer-events-none" aria-hidden="true">
    <img
      src="/images/logos/icon-color.png"
      alt=""
      width="1123"
      height="1123"
      class="opacity-5 w-[520px] h-auto select-none"
      aria-hidden="true"
    />
  </div>

  <!-- HUD corner brackets -->
  <div class="absolute inset-0 z-20 pointer-events-none" aria-hidden="true">
    <div class="absolute top-8 left-8 w-10 h-10" style="border-top: 1px solid rgba(168,85,247,0.5); border-left: 1px solid rgba(168,85,247,0.5);"></div>
    <div class="absolute top-8 right-8 w-10 h-10" style="border-top: 1px solid rgba(168,85,247,0.5); border-right: 1px solid rgba(168,85,247,0.5);"></div>
    <div class="absolute bottom-8 left-8 w-10 h-10" style="border-bottom: 1px solid rgba(168,85,247,0.5); border-left: 1px solid rgba(168,85,247,0.5);"></div>
    <div class="absolute bottom-8 right-8 w-10 h-10" style="border-bottom: 1px solid rgba(168,85,247,0.5); border-right: 1px solid rgba(168,85,247,0.5);"></div>
  </div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- System status indicator -->
    <div id="hero-status" class="inline-flex items-center gap-2 mb-5 opacity-0">
      <span class="pulse-dot" aria-hidden="true"></span>
      <span class="font-display text-xs tracking-[0.25em]" style="color: rgba(34, 197, 94, 0.8);">SYSTEM OPERATIONAL</span>
    </div>

    <!-- Eyebrow -->
    <p
      id="hero-eyebrow"
      class="font-display text-xs sm:text-sm tracking-[0.3em] mb-6 opacity-0"
      style="color: var(--color-purple-mid);"
    >
      ● IT &amp; DIGITAL SOLUTIONS
    </p>

    <!-- H1 -->
    <h1
      id="hero-h1"
      class="font-display text-5xl sm:text-6xl tracking-widest text-glow mb-6 opacity-0"
      style="color: var(--color-text-primary);"
    >
      Technology made simple.<br />
      <span class="gradient-text">Support made personal.</span>
    </h1>

    <!-- Neon divider -->
    <div class="neon-divider max-w-md mx-auto mb-6 opacity-0" id="hero-divider" aria-hidden="true"></div>

    <!-- Subheadline -->
    <p
      id="hero-sub"
      class="text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-8 opacity-0"
      style="color: var(--color-text-primary);"
    >
      We take care of all your tech, so you can focus on running your business.
    </p>

    <!-- CTA -->
    <div id="hero-cta" class="mb-10 opacity-0">
      <a href="/contact" class="btn-primary text-base cursor-pointer">
        See how we can help &rarr;
      </a>
    </div>

    <!-- Social proof -->
    <p id="hero-proof" class="text-sm opacity-0" style="color: var(--color-text-muted);">
      <span aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      &nbsp;Trusted by businesses &amp; creators nationwide
    </p>
  </div>

  <!-- Scroll cue -->
  <div
    id="hero-scroll"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 z-20"
    aria-hidden="true"
  >
    <span class="font-display text-xs tracking-[0.25em]" style="color: var(--color-purple-mid);">SCROLL TO EXPLORE</span>
    <svg class="scroll-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-purple-mid);"/>
    </svg>
  </div>
</section>

<style>
  .scroll-arrow {
    animation: bounce 2s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-arrow { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap'

  let heroTl: gsap.core.Timeline | null = null

  function initHero() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const els = ['hero-status', 'hero-eyebrow', 'hero-h1', 'hero-divider', 'hero-sub', 'hero-cta', 'hero-proof', 'hero-scroll']
      .map(id => document.getElementById(id))

    if (reduced) {
      els.forEach(el => { if (el) el.style.opacity = '1' })
      return
    }

    const [status, eyebrow, h1, divider, sub, cta, proof, scroll] = els

    heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    heroTl
      .fromTo(status,  { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 })
      .fromTo(eyebrow, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.2')
      .fromTo(h1,      { opacity: 0, y: 30, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 0.8 }, '-=0.3')
      .fromTo(divider, { opacity: 0, scaleX: 0 }, { opacity: 1, scaleX: 1, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .fromTo(sub,     { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.3')
      .fromTo(cta,     { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5 }, '-=0.3')
      .fromTo(proof,   { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.2')
      .fromTo(scroll,  { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.2')
  }

  document.addEventListener('astro:before-swap', () => { heroTl?.kill(); heroTl = null })
  document.addEventListener('astro:page-load', initHero)
</script>
