---
---

<section
  class="relative min-h-dvh flex flex-col items-center justify-center overflow-hidden pt-24 pb-20"
  aria-label="Hero"
  id="hero-section"
>
  <!-- Video background -->
  <video
    class="hero-video"
    autoplay
    muted
    loop
    playsinline
    data-autoplay-managed="true"
    data-video-upgrade="true"
    aria-hidden="true"
    tabindex="-1"
    poster="/images/hero-poster.webp"
  >
    <source src="/videos/hero-bg.webm" type="video/webm" />
    <source src="/videos/hero-bg.mp4" type="video/mp4" />
  </video>

  <!-- Deep overlay — brings video into our dark palette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: rgba(2,0,10,0.62); z-index: 1;"
    aria-hidden="true"
  ></div>

  <!-- Video edge fades -->
  <div class="video-fade-top" aria-hidden="true"></div>
  <div class="video-fade-bottom" aria-hidden="true"></div>

  <!-- Aurora blobs — outer wrapper receives GSAP parallax, inner keeps CSS drift -->
  <div class="hero-aurora" aria-hidden="true">
    <div data-parallax-a style="position:absolute; width:700px; height:500px; top:-100px; left:-100px; pointer-events:none;">
      <div class="aurora-blob aurora-purple" style="position:absolute; inset:0; width:100%; height:100%;"></div>
    </div>
    <div data-parallax-b style="position:absolute; width:500px; height:400px; bottom:-80px; right:-80px; pointer-events:none;">
      <div class="aurora-blob aurora-emerald" style="position:absolute; inset:0; width:100%; height:100%;"></div>
    </div>
  </div>

  <!-- Constellation particles (JS-populated) -->
  <div class="hero-particles" id="hero-particles" aria-hidden="true"></div>

  <!-- HUD corner brackets -->
  <div class="absolute inset-0 pointer-events-none" style="z-index: 20;" aria-hidden="true">
    <div class="hud-bracket hud-tl"></div>
    <div class="hud-bracket hud-tr"></div>
    <div class="hud-bracket hud-bl"></div>
    <div class="hud-bracket hud-br"></div>
  </div>

  <!-- Main content -->
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="z-index: 20;">

    <!-- Headline -->
    <h1 id="hero-h1" class="hero-h1">
      Technology made simple.<br />
      <span class="hero-grad">Support made personal.</span>
    </h1>

    <!-- Thin divider -->
    <div id="hero-divider" class="hero-divider" aria-hidden="true"></div>

    <!-- Subtext -->
    <p id="hero-sub" class="hero-sub">
      We take care of all your tech, so you can focus on running your business.
    </p>

    <!-- CTA -->
    <div id="hero-cta" class="hero-cta-row">
      <a href="/contact" class="hero-btn-primary">
        See how we can help
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#clientele-section" class="hero-btn-ghost">Who we help</a>
    </div>

    <!-- Social proof -->
    <div id="hero-proof" class="hero-proof">
      <div class="avatar-stack" aria-hidden="true">
        <div class="hero-avatar" style="background: linear-gradient(135deg, rgba(168,85,247,0.7), rgba(34,197,94,0.5));">SM</div>
        <div class="hero-avatar" style="background: linear-gradient(135deg, rgba(34,197,94,0.6), rgba(168,85,247,0.6));">JR</div>
        <div class="hero-avatar" style="background: linear-gradient(135deg, rgba(168,85,247,0.8), rgba(192,132,252,0.5));">EC</div>
        <div class="hero-avatar" style="background: linear-gradient(135deg, rgba(34,197,94,0.7), rgba(168,85,247,0.4));">MT</div>
      </div>
      <span><strong>50+</strong> businesses already served</span>
    </div>
  </div>

  <!-- Scroll cue -->
  <div
    id="hero-scroll"
    class="hero-scroll-cue"
    aria-hidden="true"
  >
    <span>SCROLL</span>
    <div class="hero-scroll-line"></div>
  </div>

  <noscript>
    <style>
      .hero-h1, .hero-divider,
      .hero-sub, .hero-cta-row, .hero-proof, .hero-scroll-cue {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</section>

<style>
  /* ── Video ── */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  /* ── Aurora blobs ── */
  .hero-aurora {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .aurora-purple {
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(168, 85, 247, 0.18) 0%, transparent 65%);
    animation: aurora-drift-a 10s ease-in-out infinite;
  }
  .aurora-emerald {
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(34, 197, 94, 0.1) 0%, transparent 65%);
    animation: aurora-drift-b 12s ease-in-out infinite;
  }
  @keyframes aurora-drift-a {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.7; }
    50% { transform: translate(60px, 40px) scale(1.12); opacity: 1; }
  }
  @keyframes aurora-drift-b {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(-40px, -30px) scale(1.08); opacity: 0.85; }
  }

  /* ── Particles ── */
  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }
  /* Individual particles styled via JS inline style */

  /* ── HUD brackets ── */
  .hud-bracket {
    position: absolute;
    width: 36px;
    height: 36px;
  }
  .hud-tl { top: 24px; left: 24px; border-top: 1px solid rgba(168,85,247,0.45); border-left: 1px solid rgba(168,85,247,0.45); }
  .hud-tr { top: 24px; right: 24px; border-top: 1px solid rgba(168,85,247,0.45); border-right: 1px solid rgba(168,85,247,0.45); }
  .hud-bl { bottom: 24px; left: 24px; border-bottom: 1px solid rgba(168,85,247,0.45); border-left: 1px solid rgba(168,85,247,0.45); }
  .hud-br { bottom: 24px; right: 24px; border-bottom: 1px solid rgba(168,85,247,0.45); border-right: 1px solid rgba(168,85,247,0.45); }

  /* ── H1 ── */
  .hero-h1 {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
    margin-bottom: 20px;
    opacity: 0;
  }
  .hero-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 20px rgba(168, 85, 247, 0.45));
  }

  /* ── Divider ── */
  .hero-divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.7), rgba(34, 197, 94, 0.4));
    margin: 0 auto 24px;
    opacity: 0;
    transform: scaleX(0);
    transform-origin: center;
  }

  /* ── Subtext ── */
  .hero-sub {
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.7;
    color: rgba(233, 213, 255, 0.6);
    max-width: 520px;
    margin: 0 auto 36px;
    opacity: 0;
  }

  /* ── CTAs ── */
  .hero-cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    opacity: 0;
  }
  .hero-btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 10px;
    background: rgba(168, 85, 247, 0.12);
    color: var(--text-primary-aurora);
    font-family: 'Exo 2', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.25s, box-shadow 0.25s, gap 0.2s;
  }
  .hero-btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.8), rgba(34, 197, 94, 0.4));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .hero-btn-primary:hover {
    background: rgba(168, 85, 247, 0.2);
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.3);
    gap: 12px;
  }

  .hero-btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(233, 213, 255, 0.55);
    font-family: 'Exo 2', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .hero-btn-ghost:hover {
    color: var(--text-primary-aurora);
    border-color: rgba(168, 85, 247, 0.35);
    background: rgba(168, 85, 247, 0.06);
  }

  /* ── Social proof ── */
  .hero-proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: rgba(233, 213, 255, 0.55);
    opacity: 0;
  }
  .avatar-stack {
    display: flex;
  }
  .hero-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-bg-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    margin-left: -8px;
  }
  .hero-avatar:first-child {
    margin-left: 0;
  }

  /* ── Scroll cue ── */
  .hero-scroll-cue {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--text-dim-aurora);
  }
  .hero-scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(168, 85, 247, 0.4), transparent);
  }

  @media (min-height: 900px) {
    section { padding-bottom: 10vh; }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora-purple, .aurora-emerald {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'

  let heroTl: gsap.core.Timeline | null = null
  let abortCtrl: AbortController | null = null

  function spawnParticles() {
    const container = document.getElementById('hero-particles')
    if (!container) return
    // Clear any existing particles
    while (container.firstChild) container.removeChild(container.firstChild)

    const count = 28
    for (let i = 0; i < count; i++) {
      const dot = document.createElement('span')
      const size = Math.random() < 0.3 ? 2 : 1
      const x = Math.random() * 100
      const y = Math.random() * 100
      const opacity = 0.15 + Math.random() * 0.4
      const delay = Math.random() * 6
      const dur = 3 + Math.random() * 4

      dot.style.cssText = [
        'position:absolute',
        `left:${x}%`,
        `top:${y}%`,
        `width:${size}px`,
        `height:${size}px`,
        'border-radius:50%',
        `background:${Math.random() > 0.6 ? 'rgba(34,197,94,' + opacity + ')' : 'rgba(168,85,247,' + opacity + ')'}`,
        `animation:hero-twinkle ${dur}s ease-in-out ${delay}s infinite`,
      ].join(';')
      container.appendChild(dot)
    }
  }

  function initHero() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    spawnParticles()

    const ids = ['hero-h1', 'hero-divider', 'hero-sub', 'hero-cta', 'hero-proof', 'hero-scroll']
    const els = ids.map(id => document.getElementById(id))

    if (reduced) {
      els.forEach(el => {
        if (el) {
          el.style.opacity = '1'
          el.style.transform = 'none'
        }
      })
      return
    }

    const [h1, divider, sub, cta, proof, scroll] = els

    heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    heroTl
      .fromTo(h1,      { opacity: 0, y: 30, scale: 0.97 }, { opacity: 1, y: 0, scale: 1, duration: 0.85 })
      .fromTo(divider, { opacity: 0, scaleX: 0 }, { opacity: 1, scaleX: 1, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .fromTo(sub,     { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.3')
      .fromTo(cta,     { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5 }, '-=0.3')
      .fromTo(proof,   { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.2')
      .fromTo(scroll,  { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.2')

    // Cursor-tracking parallax on aurora wrappers
    const wA = document.querySelector('[data-parallax-a]')
    const wB = document.querySelector('[data-parallax-b]')
    if (wA && wB) {
      abortCtrl = new AbortController()
      document.addEventListener('mousemove', (e) => {
        const nx = (e.clientX / window.innerWidth - 0.5) * 80
        const ny = (e.clientY / window.innerHeight - 0.5) * 60
        gsap.to(wA, { x: nx, y: ny, duration: 2, ease: 'power2.out', overwrite: 'auto' })
        gsap.to(wB, { x: -nx * 0.6, y: -ny * 0.6, duration: 2.5, ease: 'power2.out', overwrite: 'auto' })
      }, { signal: abortCtrl.signal })
    }
  }

  document.addEventListener('astro:before-swap', () => {
    heroTl?.kill()
    heroTl = null
    abortCtrl?.abort()
    abortCtrl = null
  })

  document.addEventListener('astro:page-load', initHero)
</script>

<style is:global>
  @keyframes hero-twinkle {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.5); }
  }
</style>
