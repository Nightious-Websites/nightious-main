---
const faqs = [
  {
    q: 'Do you require long-term contracts?',
    a: "No. We do project-based work and flexible retainers. If it's not working out, you walk. Most clients stick around anyway.",
  },
  {
    q: 'How quickly can you start?',
    a: "We respond as soon as possible and can typically start discovery the same week. Fast turnaround is how we work, not a premium add-on.",
  },
  {
    q: 'Do I need to be technical to work with you?',
    a: "No. You tell us the problem, we handle the rest. If you have questions about what we did, we walk you through it.",
  },
  {
    q: "What if I'm not sure what I need?",
    a: "That's what the free consultation is for. Tell us your goal and we'll map out the options. No pressure toward the expensive one.",
  },
  {
    q: 'How much does it cost?',
    a: "Depends on what you need. A one-off fix is a flat fee. Ongoing support is a retainer. We give you a clear quote upfront — no surprise invoices.",
  },
  {
    q: 'What do you actually do?',
    a: "Web design, IT support, AI automation, cybersecurity, and digital strategy. Most clients start with one problem and end up working with us across all of it.",
  },
  {
    q: 'How do I get started?',
    a: "Book a free call and tell us what's going on. We'll tell you what we can do and what it costs. No commitment required.",
  },
]
---

<section class="faq-section py-20" aria-label="Frequently asked questions">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">

      <!-- Left sticky label -->
      <div class="flex-shrink-0 lg:w-52">
        <div class="faq-eyebrow">FAQ</div>
        <h2 class="faq-headline">
          Common <span class="faq-grad">questions.</span>
        </h2>
      </div>

      <!-- Right: flip card grid -->
      <div class="flex-1">
        <div class="faq-grid">

          {faqs.map((faq, i) => (
            <div
              class="flip-card"
              role="button"
              tabindex="0"
              aria-expanded="false"
              aria-label={`Question ${i + 1}: ${faq.q}`}
              data-index={String(i)}
            >
              <div class="flip-card-inner">
                <!-- Front face -->
                <div class="flip-front">
                  <div class="ghost-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
                  <p class="question">{faq.q}</p>
                  <span class="flip-hint" aria-hidden="true">FLIP ↻</span>
                </div>
                <!-- Back face -->
                <div class="flip-back" aria-hidden="true">
                  <p class="answer">{faq.a}</p>
                  <span class="flip-back-hint" aria-hidden="true">↩ FLIP BACK</span>
                </div>
              </div>
            </div>
          ))}

          <!-- CTA card -->
          <a href="/contact" class="cta-card" aria-label="Book a free consultation call">
            <p class="cta-label">STILL CURIOUS?</p>
            <p class="cta-action">Book a free call →</p>
          </a>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .faq-section {
    background-color: var(--color-bg-section);
    position: relative;
  }

  /* Eyebrow */
  .faq-eyebrow {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.6);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .faq-eyebrow::before {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    background: rgba(168, 85, 247, 0.4);
  }

  /* Headline */
  .faq-headline {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.0;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
  }
  .faq-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 12px rgba(168, 85, 247, 0.4));
  }

  /* Grid */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (max-width: 639px) {
    .faq-grid { grid-template-columns: 1fr; }
  }

  /* Flip card shell */
  .flip-card {
    height: 128px;
    cursor: pointer;
    perspective: 1000px;
    outline: 2px solid transparent;
    outline-offset: 2px;
  }
  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1);
    border-radius: 12px;
  }
  .flip-card.flipped .flip-card-inner { transform: rotateY(180deg); }
  /* backdrop-filter breaks backface-visibility in composited layers — hide explicitly */
  .flip-card.flipped .flip-front { visibility: hidden; }

  /* Shared face */
  .flip-front,
  .flip-back {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
  }

  /* Front face */
  .flip-front {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(168, 85, 247, 0.14);
    gap: 8px;
    transition: border-color 0.2s;
  }
  .flip-front::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(160deg, rgba(168,85,247,0.2) 0%, transparent 60%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .flip-card:hover .flip-front,
  .flip-card:focus-visible .flip-front { border-color: rgba(168, 85, 247, 0.32); }
  .flip-card:hover .flip-front::before,
  .flip-card:focus-visible .flip-front::before { opacity: 1; }
  .flip-card:focus-visible { outline-color: rgba(168, 85, 247, 0.7); }

  /* Back face */
  .flip-back {
    background: rgba(168, 85, 247, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(168, 85, 247, 0.45);
    box-shadow: inset 0 0 30px rgba(168, 85, 247, 0.07), 0 0 18px rgba(168, 85, 247, 0.12);
    transform: rotateY(180deg);
    justify-content: space-between;
    gap: 8px;
    overflow: hidden;
  }

  /* Front contents */
  .ghost-num {
    font-family: 'Orbitron', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1;
    color: rgba(168, 85, 247, 0.12);
    flex-shrink: 0;
  }
  .question {
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary-aurora);
    line-height: 1.4;
    flex: 1;
    letter-spacing: -0.01em;
  }
  .flip-hint {
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    letter-spacing: 0.15em;
    color: rgba(168, 85, 247, 0.4);
  }

  /* Back contents */
  .answer {
    font-family: 'Exo 2', sans-serif;
    font-size: 12px;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(233, 213, 255, 0.65);
    flex: 1;
  }
  .flip-back-hint {
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    color: rgba(168, 85, 247, 0.5);
    align-self: flex-end;
  }

  /* CTA card */
  .cta-card {
    height: 128px;
    background: rgba(168, 85, 247, 0.06);
    border: 1px dashed rgba(168, 85, 247, 0.28);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    text-align: center;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .cta-card:hover {
    border-color: rgba(168, 85, 247, 0.5);
    background: rgba(168, 85, 247, 0.12);
  }
  .cta-card:focus-visible {
    border-color: rgba(168, 85, 247, 0.5);
    background: rgba(168, 85, 247, 0.12);
    outline: 2px solid rgba(168, 85, 247, 0.7);
    outline-offset: 2px;
  }
  .cta-label {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: rgba(168, 85, 247, 0.55);
  }
  .cta-action {
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: rgba(192, 132, 252, 0.9);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .flip-card-inner { transform-style: flat; transition: none; }
    .flip-card.flipped .flip-card-inner { transform: none; }
    .flip-front { backface-visibility: visible; transition: none; }
    .flip-back { backface-visibility: visible; transform: none; opacity: 0; transition: opacity 0s; }
    .flip-card.flipped .flip-front { opacity: 0; pointer-events: none; }
    .flip-card.flipped .flip-back  { opacity: 1; pointer-events: auto; }
  }

  /* ── Glitch ── */
  @keyframes glitch-rgbsplit {
    0%   { text-shadow: none; }
    15%  { text-shadow: -2px 0 0 rgba(0,255,255,0.7), 2px 0 0 rgba(255,0,255,0.7); }
    35%  { text-shadow:  2px 0 0 rgba(0,255,255,0.5), -2px 0 0 rgba(255,0,255,0.5); }
    55%  { text-shadow: -1px 0 0 rgba(0,255,255,0.3),  1px 0 0 rgba(255,0,255,0.3); }
    100% { text-shadow: none; }
  }
  @keyframes glitch-slice {
    0%   { clip-path: inset(0 0 100% 0); transform: translate(0); }
    15%  { clip-path: inset(20% 0 50% 0); transform: translate(-3px, 0); }
    30%  { clip-path: inset(50% 0 20% 0); transform: translate(3px, 0); }
    55%  { clip-path: inset(5% 0 70% 0);  transform: translate(-2px, 0); }
    75%  { clip-path: inset(70% 0 5% 0);  transform: translate(2px, 0); }
    100% { clip-path: inset(0 0 0 0);     transform: translate(0); }
  }
  .flip-card.glitching .flip-card-inner {
    animation: glitch-rgbsplit 0.22s ease-out forwards;
  }
  .flip-card.glitching .flip-card-inner::before,
  .flip-card.glitching .flip-card-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    pointer-events: none;
    z-index: 10;
  }
  .flip-card.glitching .flip-card-inner::before {
    background: rgba(0, 255, 255, 0.05);
    animation: glitch-slice 0.18s steps(1) forwards;
    transform: translateX(-2px);
  }
  .flip-card.glitching .flip-card-inner::after {
    background: rgba(255, 0, 255, 0.04);
    animation: glitch-slice 0.18s steps(1) 0.04s forwards;
    transform: translateX(2px);
  }
  .flip-card.glitching .flip-front,
  .flip-card.glitching .flip-back {
    border-color: rgba(0, 255, 255, 0.55) !important;
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .flip-card.glitching .flip-card-inner,
    .flip-card.glitching .flip-card-inner::before,
    .flip-card.glitching .flip-card-inner::after { animation: none; }
    .flip-card.glitching .flip-front,
    .flip-card.glitching .flip-back { border-color: inherit !important; transition: none; }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let destroyed = false
  let cardAc: AbortController | null = null

  function initFaq() {
    destroyed = false

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const flipCards = document.querySelectorAll<HTMLElement>('.flip-card')
    const section = document.querySelector<HTMLElement>('section[aria-label="Frequently asked questions"]')

    if (!reduced && section && flipCards.length) {
      const allCards = section.querySelectorAll<HTMLElement>('.flip-card, .cta-card')
      gsap.fromTo(
        allCards,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: 'power2.out',
          scrollTrigger: {
            id: 'faq-entrance',
            trigger: section,
            start: 'top 85%',
            once: true,
          },
        }
      )
    }

    cardAc?.abort()
    cardAc = new AbortController()
    const sig = { signal: cardAc.signal }

    flipCards.forEach(card => {
      function handleFlip() {
        const isFlipped = card.classList.contains('flipped')
        card.classList.toggle('flipped')
        card.setAttribute('aria-expanded', String(!isFlipped))

        const front = card.querySelector<HTMLElement>('.flip-front')
        const back  = card.querySelector<HTMLElement>('.flip-back')
        if (front) front.setAttribute('aria-hidden', String(!isFlipped))
        if (back)  back.setAttribute('aria-hidden',  String(isFlipped))

        if (!reduced) {
          setTimeout(() => {
            if (destroyed) return
            card.classList.add('glitching')
            setTimeout(() => {
              if (destroyed) return
              card.classList.remove('glitching')
            }, 220)
          }, 275)
        }
      }

      card.addEventListener('click', handleFlip, sig)
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          handleFlip()
        }
      }, sig)
    })
  }

  document.addEventListener('astro:before-swap', () => {
    destroyed = true
    ScrollTrigger.getById('faq-entrance')?.kill()
    cardAc?.abort()
    cardAc = null
  })
  document.addEventListener('astro:page-load', initFaq)
</script>
