---
const faqs = [
  {
    q: 'Do you require long-term contracts?',
    a: 'No. We do project-based work and flexible retainers. If it\'s not working out, you walk. Most clients stick around anyway.',
  },
  {
    q: 'How quickly can you start?',
    a: 'We usually respond within 4 hours and can start discovery the same week. Fast turnaround is how we work, not a premium add-on.',
  },
  {
    q: 'Do I need to be technical to work with you?',
    a: 'No. You tell us the problem, we handle the rest. If you have questions about what we did, we walk you through it.',
  },
  {
    q: 'What if I\'m not sure what I need?',
    a: 'That\'s what the free consultation is for. Tell us your goal and we\'ll map out the options. No pressure toward the expensive one.',
  },
  {
    q: 'Do you work with businesses outside the US?',
    a: 'Yes. We work with clients worldwide. All communication is async-friendly, so time zones are never a problem.',
  },
]
---

<section class="section-alt py-20 reveal-section" aria-label="Frequently asked questions">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Split: label left / accordion right on lg+ -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">

      <!-- Left label column -->
      <div class="flex-shrink-0 lg:w-48">
        <p class="font-display text-xs tracking-[0.25em] mb-2" style="color: var(--color-purple-mid);">FAQ</p>
        <h2 class="font-display text-3xl" style="color: var(--color-text-primary);">Common questions</h2>
      </div>

      <!-- Right accordion column -->
      <div class="flex-1">
        <dl class="flex flex-col gap-4">
          {faqs.map((faq, i) => (
            <div class="glass overflow-hidden">
              <dt>
                <button
                  type="button"
                  class="w-full flex items-center justify-between gap-4 px-6 py-5 text-left cursor-pointer"
                  aria-expanded="false"
                  aria-controls={`faq-answer-${i}`}
                  id={`faq-btn-${i}`}
                >
                  <span class="text-sm font-semibold" style="color: var(--color-text-primary); font-family: 'Exo 2', sans-serif;">
                    {faq.q}
                  </span>
                  <!-- Neon indicator bar (replaces chevron arrow) -->
                  <span
                    class="faq-indicator flex-shrink-0"
                    aria-hidden="true"
                    style="width: 2px; height: 20px; background: var(--color-purple-mid); transform: scaleY(0); transform-origin: top; transition: none;"
                  ></span>
                </button>
              </dt>
              <dd
                id={`faq-answer-${i}`}
                role="region"
                aria-labelledby={`faq-btn-${i}`}
                class="faq-answer px-6 pb-5"
                style="height: 0; overflow: hidden; padding-top: 0; padding-bottom: 0;"
              >
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{faq.a}</p>
              </dd>
            </div>
          ))}
        </dl>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'

  function initFaq() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[id^="faq-btn-"]')

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true'
        const answerId = btn.getAttribute('aria-controls')
        const answer = answerId ? document.getElementById(answerId) : null
        const indicator = btn.querySelector<HTMLElement>('.faq-indicator')

        btn.setAttribute('aria-expanded', String(!expanded))

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        if (reduced) {
          if (answer) {
            answer.style.height = !expanded ? 'auto' : '0'
            answer.style.paddingBottom = !expanded ? '20px' : '0'
          }
          if (indicator) indicator.style.transform = !expanded ? 'scaleY(1)' : 'scaleY(0)'
          return
        }

        if (answer) {
          if (!expanded) {
            gsap.to(answer, {
              height: 'auto',
              paddingBottom: 20,
              duration: 0.3,
              ease: 'power2.out',
            })
          } else {
            gsap.to(answer, {
              height: 0,
              paddingBottom: 0,
              duration: 0.25,
              ease: 'power2.in',
            })
          }
        }

        if (indicator) {
          gsap.to(indicator, {
            scaleY: !expanded ? 1 : 0,
            duration: 0.25,
            ease: 'power2.out',
          })
        }

        // Brighten the card border when expanded
        const card = btn.closest('.glass')
        if (card instanceof HTMLElement) {
          if (!expanded) {
            gsap.to(card, { borderColor: 'rgba(168,85,247,0.3)', duration: 0.2 })
          } else {
            gsap.to(card, { borderColor: 'rgba(255,255,255,0.1)', duration: 0.2 })
          }
        }
      })
    })
  }

  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll<HTMLElement>('.faq-indicator, .faq-answer').forEach(el => {
      gsap.killTweensOf(el)
    })
  })
  document.addEventListener('astro:page-load', initFaq)
</script>
