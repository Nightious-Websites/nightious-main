---
import AuroraBackground from '@/components/ui/AuroraBackground.astro'
import ConstellationParticles from '@/components/ui/ConstellationParticles.astro'
import HudBrackets from '@/components/ui/HudBrackets.astro'

interface Props {
  audience: string
  headline: string
  tagline: string
  accentRgb: string
  serviceCount: number
  animStyle?: 'network' | 'waveform' | 'orbs'
  bgVideo?: string
}

const { audience, headline, tagline, accentRgb, serviceCount, animStyle, bgVideo } = Astro.props
---

<section
  class="bh-section relative flex flex-col items-center justify-center overflow-hidden"
  aria-label={`Services for ${audience}`}
  id="bundle-hero-section"
>
  {/* Video background */}
  {bgVideo && (
    <>
      <video
        class="absolute inset-0 w-full h-full object-cover pointer-events-none"
        style="z-index: 0;"
        autoplay muted loop playsinline
        aria-hidden="true"
        tabindex="-1"
        preload="none"
      >
        <source src={bgVideo} type="video/webm" />
        <source src={bgVideo.replace('.webm', '.mp4')} type="video/mp4" />
      </video>
      <div class="absolute inset-0 pointer-events-none" style="background: rgba(2,0,10,0.62); z-index: 1;" aria-hidden="true"></div>
    </>
  )}

  <!-- Aurora background: accent-colored per bundle -->
  <AuroraBackground variant="subtle" colors="accent" accentRgb={accentRgb} zIndex={2} />

  <!-- Constellation particles or canvas animation -->
  {animStyle ? (
    <canvas
      class="bh-canvas"
      data-anim-style={animStyle}
      data-accent-rgb={accentRgb}
      aria-hidden="true"
      style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:3;"
    ></canvas>
  ) : (
    <ConstellationParticles density="medium" colors="purple-emerald" zIndex={3} />
  )}

  <!-- Grid texture overlay -->
  <div class="absolute inset-0 bg-grid pointer-events-none" style="z-index: 4;" aria-hidden="true"></div>

  <!-- Scan line -->
  <div class="scan-line" style="z-index: 5;" aria-hidden="true"></div>

  <!-- HUD corner brackets: accent-colored -->
  <HudBrackets color={`rgba(${accentRgb}, 0.35)`} zIndex={20} />

  <!-- Main content -->
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="z-index: 20;">

    <!-- Status pill -->
    <div id="bh-status" class="bh-status-pill" style={`opacity:0; background: rgba(${accentRgb}, 0.07); border-color: rgba(${accentRgb}, 0.2); color: rgba(${accentRgb}, 0.8);`}>
      <span
        class="bh-pulse-dot"
        style={`background: rgba(${accentRgb}, 0.9); box-shadow: 0 0 6px rgba(${accentRgb}, 0.8);`}
        aria-hidden="true"
      ></span>
      <span>FOR {audience.toUpperCase()} &bull; {serviceCount} SERVICES</span>
    </div>

    <!-- Eyebrow glass-pill -->
    <span
      id="bh-eyebrow"
      class="glass-pill bh-eyebrow"
      style={`opacity:0; color: rgba(${accentRgb}, 0.75); background: rgba(${accentRgb}, 0.10); border-color: rgba(${accentRgb}, 0.15);`}
      aria-hidden="true"
    >
      FOR {audience.toUpperCase()}
    </span>

    <!-- Headline -->
    <h1 id="bh-h1" class="bh-h1">
      <span class="bh-h1-main gradient-text">{headline}</span><br />
      <span class="bh-h1-sub accent-italic">{tagline}</span>
    </h1>

    <!-- Gradient divider: accent-colored -->
    <div
      id="bh-divider"
      class="bh-divider"
      style={`background: linear-gradient(90deg, rgba(${accentRgb}, 0.7), rgba(168, 85, 247, 0.4)); opacity:0; transform:scaleX(0);`}
      aria-hidden="true"
    ></div>

  </div>

  <!-- Scroll cue -->
  <div id="bh-scroll" class="bh-scroll-cue" aria-hidden="true">
    <span>EXPLORE SERVICES</span>
    <div class="bh-scroll-line" style={`background: linear-gradient(to bottom, rgba(${accentRgb}, 0.5), transparent);`}></div>
  </div>

  <noscript>
    <style>
      #bh-status, #bh-eyebrow, #bh-h1, #bh-divider, #bh-scroll {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</section>

<style>
  /* ── Section ── */
  .bh-section {
    min-height: 80vh;
    min-height: 80dvh;
    padding-top: 9rem;
    padding-bottom: 5rem;
    background-color: var(--color-bg-deep);
  }

  /* ── Canvas ── */
  .bh-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ── Status pill ── */
  .bh-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 40px;
    border: 1px solid transparent;
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .bh-pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: bh-dot-pulse 2s ease-in-out infinite;
  }
  @keyframes bh-dot-pulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  /* ── Eyebrow ── */
  .bh-eyebrow {
    display: block;
    width: fit-content;
    margin: 0 auto 20px;
  }

  /* ── Headline ── */
  .bh-h1 {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
    margin-bottom: 24px;
    opacity: 0;
  }

  .bh-h1-main {
    /* gradient-text from global.css handles this */
  }

  .bh-h1-sub {
    /* accent-italic from global.css: Instrument Serif italic */
    font-size: 0.88em;
    color: var(--text-muted-aurora);
    -webkit-text-fill-color: var(--text-muted-aurora);
    background: none;
  }

  /* ── Divider ── */
  .bh-divider {
    width: 60px;
    height: 1px;
    margin: 0 auto 0;
    transform-origin: center;
  }

  /* ── Scroll cue ── */
  .bh-scroll-cue {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--text-dim-aurora);
    white-space: nowrap;
  }

  .bh-scroll-line {
    width: 1px;
    height: 36px;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .bh-pulse-dot { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap'

  let bundleHeroTl: gsap.core.Timeline | null = null
  let bhStop: (() => void) | null = null

  // ── Canvas: Network (For Businesses) ───────────────────────────────────────
  function startNetwork(canvas: HTMLCanvasElement, rgb: string) {
    const ctx = canvas.getContext('2d')
    if (!ctx) return null

    const dpr = Math.min(window.devicePixelRatio || 1, 2)

    function resize() {
      canvas.width  = canvas.offsetWidth  * dpr
      canvas.height = canvas.offsetHeight * dpr
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0)
    }
    resize()
    const ro = new ResizeObserver(resize)
    ro.observe(canvas)

    const N = 14
    const nodes = Array.from({ length: N }, () => ({
      x: 0.05 + Math.random() * 0.9,
      y: 0.05 + Math.random() * 0.9,
      vx: (Math.random() - 0.5) * 0.000025,
      vy: (Math.random() - 0.5) * 0.000025,
      phase: Math.random() * Math.PI * 2,
      speed: 0.0003 + Math.random() * 0.0002,
    }))

    const packets: { a: number; b: number; t: number; speed: number }[] = []
    let lastPacket = 0

    function spawnPacket() {
      const a = Math.floor(Math.random() * N)
      let b = Math.floor(Math.random() * N)
      while (b === a) b = Math.floor(Math.random() * N)
      packets.push({ a, b, t: 0, speed: 0.0008 + Math.random() * 0.0004 })
    }

    let lastT = 0
    let rafId: number | null = null

    function loop(t: number) {
      const dt = lastT === 0 ? 16 : t - lastT
      lastT = t

      const w = canvas.offsetWidth
      const h = canvas.offsetHeight
      ctx!.clearRect(0, 0, w, h)

      // Update node positions (slow sine drift)
      for (const n of nodes) {
        n.phase += n.speed * dt
        n.x += Math.sin(n.phase * 0.7) * 0.00015
        n.y += Math.cos(n.phase * 0.5) * 0.00012
        if (n.x < 0.02) n.x = 0.02
        if (n.x > 0.98) n.x = 0.98
        if (n.y < 0.02) n.y = 0.02
        if (n.y > 0.98) n.y = 0.98
      }

      // Draw edges between nearby nodes
      ctx!.lineWidth = 0.6
      for (let i = 0; i < N; i++) {
        for (let j = i + 1; j < N; j++) {
          const dx = (nodes[i].x - nodes[j].x) * w
          const dy = (nodes[i].y - nodes[j].y) * h
          const dist = Math.sqrt(dx * dx + dy * dy)
          if (dist < 180) {
            const alpha = (1 - dist / 180) * 0.35
            ctx!.strokeStyle = `rgba(${rgb}, ${alpha})`
            ctx!.beginPath()
            ctx!.moveTo(nodes[i].x * w, nodes[i].y * h)
            ctx!.lineTo(nodes[j].x * w, nodes[j].y * h)
            ctx!.stroke()
          }
        }
      }

      // Draw nodes
      for (const n of nodes) {
        ctx!.beginPath()
        ctx!.arc(n.x * w, n.y * h, 2, 0, Math.PI * 2)
        ctx!.fillStyle = `rgba(${rgb}, 0.6)`
        ctx!.fill()
      }

      // Spawn data packet every 2.5s
      if (t - lastPacket > 2500) {
        spawnPacket()
        lastPacket = t
      }

      // Draw + advance packets
      for (let i = packets.length - 1; i >= 0; i--) {
        const p = packets[i]
        p.t += p.speed * dt
        if (p.t >= 1) { packets.splice(i, 1); continue }
        const ax = nodes[p.a].x * w
        const ay = nodes[p.a].y * h
        const bx = nodes[p.b].x * w
        const by = nodes[p.b].y * h
        const px = ax + (bx - ax) * p.t
        const py = ay + (by - ay) * p.t
        ctx!.beginPath()
        ctx!.arc(px, py, 3, 0, Math.PI * 2)
        ctx!.fillStyle = `rgba(${rgb}, 0.95)`
        ctx!.shadowColor = `rgba(${rgb}, 0.8)`
        ctx!.shadowBlur = 8
        ctx!.fill()
        ctx!.shadowBlur = 0
      }

      rafId = requestAnimationFrame(loop)
    }

    rafId = requestAnimationFrame(loop)

    return function stop() {
      if (rafId) cancelAnimationFrame(rafId)
      ro.disconnect()
      ctx!.clearRect(0, 0, canvas.width, canvas.height)
    }
  }

  // ── Canvas: Waveform (For Creators) ────────────────────────────────────────
  function startWaveform(canvas: HTMLCanvasElement, rgb: string) {
    const ctx = canvas.getContext('2d')
    if (!ctx) return null

    const dpr = Math.min(window.devicePixelRatio || 1, 2)
    function resize() {
      canvas.width  = canvas.offsetWidth  * dpr
      canvas.height = canvas.offsetHeight * dpr
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0)
    }
    resize()
    const ro = new ResizeObserver(resize)
    ro.observe(canvas)

    const waves = [
      { amp: 45, freq: 0.004, phaseSpeed: 0.0012, yFrac: 0.28, opacity: 0.22 },
      { amp: 28, freq: 0.007, phaseSpeed: 0.0019, yFrac: 0.42, opacity: 0.18 },
      { amp: 55, freq: 0.003, phaseSpeed: 0.0008, yFrac: 0.56, opacity: 0.14 },
      { amp: 20, freq: 0.009, phaseSpeed: 0.0025, yFrac: 0.70, opacity: 0.10 },
    ].map(w => ({ ...w, phase: Math.random() * Math.PI * 2 }))

    let lastT = 0
    let rafId: number | null = null

    function loop(t: number) {
      const dt = lastT === 0 ? 16 : t - lastT
      lastT = t

      const w = canvas.offsetWidth
      const h = canvas.offsetHeight
      ctx!.clearRect(0, 0, w, h)

      for (const wave of waves) {
        wave.phase += wave.phaseSpeed * dt
        ctx!.beginPath()
        ctx!.strokeStyle = `rgba(${rgb}, ${wave.opacity})`
        ctx!.lineWidth = 1.5
        for (let x = 0; x <= w; x += 2) {
          const y = wave.yFrac * h + Math.sin(x * wave.freq + wave.phase) * wave.amp
          if (x === 0) ctx!.moveTo(x, y)
          else ctx!.lineTo(x, y)
        }
        ctx!.stroke()
      }

      rafId = requestAnimationFrame(loop)
    }

    rafId = requestAnimationFrame(loop)

    return function stop() {
      if (rafId) cancelAnimationFrame(rafId)
      ro.disconnect()
      ctx!.clearRect(0, 0, canvas.width, canvas.height)
    }
  }

  // ── Canvas: Orbs (For Individuals) ─────────────────────────────────────────
  function startOrbs(canvas: HTMLCanvasElement, rgb: string) {
    const ctx = canvas.getContext('2d')
    if (!ctx) return null

    const dpr = Math.min(window.devicePixelRatio || 1, 2)
    function resize() {
      canvas.width  = canvas.offsetWidth  * dpr
      canvas.height = canvas.offsetHeight * dpr
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0)
    }
    resize()
    const ro = new ResizeObserver(resize)
    ro.observe(canvas)

    const orbs = Array.from({ length: 7 }, () => ({
      bx: 0.1 + Math.random() * 0.8,
      by: 0.1 + Math.random() * 0.8,
      r:  35 + Math.random() * 55,
      px: Math.random() * Math.PI * 2,
      py: Math.random() * Math.PI * 2,
      sx: 0.00008 + Math.random() * 0.00008,
      sy: 0.00006 + Math.random() * 0.00008,
      ax: 0.06 + Math.random() * 0.08,
      ay: 0.05 + Math.random() * 0.07,
    }))

    let lastT = 0
    let rafId: number | null = null

    function loop(t: number) {
      const dt = lastT === 0 ? 16 : t - lastT
      lastT = t

      const w = canvas.offsetWidth
      const h = canvas.offsetHeight
      ctx!.clearRect(0, 0, w, h)

      for (const o of orbs) {
        o.px += o.sx * dt
        o.py += o.sy * dt
        const x = (o.bx + Math.sin(o.px) * o.ax) * w
        const y = (o.by + Math.cos(o.py) * o.ay) * h

        const g = ctx!.createRadialGradient(x, y, 0, x, y, o.r)
        g.addColorStop(0,   `rgba(${rgb}, 0.28)`)
        g.addColorStop(0.5, `rgba(${rgb}, 0.08)`)
        g.addColorStop(1,   `rgba(${rgb}, 0)`)

        ctx!.beginPath()
        ctx!.arc(x, y, o.r, 0, Math.PI * 2)
        ctx!.fillStyle = g
        ctx!.fill()
      }

      rafId = requestAnimationFrame(loop)
    }

    rafId = requestAnimationFrame(loop)

    return function stop() {
      if (rafId) cancelAnimationFrame(rafId)
      ro.disconnect()
      ctx!.clearRect(0, 0, canvas.width, canvas.height)
    }
  }

  // ── Init ───────────────────────────────────────────────────────────────────
  function initBundleHero() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const ids = ['bh-status', 'bh-eyebrow', 'bh-h1', 'bh-divider', 'bh-scroll']
    const els = ids.map(id => document.getElementById(id))

    if (reduced) {
      els.forEach(el => {
        if (el) {
          el.style.opacity = '1'
          el.style.transform = 'none'
        }
      })
      return
    }

    const [status, eyebrow, h1, divider, scroll] = els
    if (!status) return // not on a bundle page

    bundleHeroTl = gsap.timeline({ defaults: { ease: 'power3.out' } })
    bundleHeroTl
      .fromTo(status,  { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 })
      .fromTo(eyebrow, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.2')
      .fromTo(h1,      { opacity: 0, y: 30, scale: 0.97 }, { opacity: 1, y: 0, scale: 1, duration: 0.85 }, '-=0.3')
      .fromTo(divider, { opacity: 0, scaleX: 0 }, { opacity: 1, scaleX: 1, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .fromTo(scroll,  { opacity: 0 }, { opacity: 1, duration: 0.5 }, '-=0.2')

    // Start canvas animation if canvas element exists
    const canvas = document.querySelector('.bh-canvas') as HTMLCanvasElement | null
    if (canvas) {
      const style = canvas.dataset.animStyle
      const rgb   = canvas.dataset.accentRgb || '168, 85, 247'
      if (style === 'network')  bhStop = startNetwork(canvas, rgb)
      if (style === 'waveform') bhStop = startWaveform(canvas, rgb)
      if (style === 'orbs')     bhStop = startOrbs(canvas, rgb)
    }
  }

  document.addEventListener('astro:before-swap', () => {
    bundleHeroTl?.kill()
    bundleHeroTl = null
    bhStop?.()
    bhStop = null
  })

  document.addEventListener('astro:page-load', initBundleHero)
</script>
