---
const testimonials = [
  {
    quote: "Nightious is the first IT company that didn't make me feel stupid. They explained everything in plain English, and I finally understand what I'm actually paying for.",
    name: 'Sarah Mitchell',
    role: 'CEO, TechStart Inc.',
    stars: 5,
  },
  {
    quote: "They reduced our tech overhead by 40% AND explained every decision. No surprises on the invoice, no jargon in the emails. That's rare.",
    name: 'James Rodriguez',
    role: 'Operations Director, CloudNine Systems',
    stars: 5,
  },
  {
    quote: "I used to Google every tech term my old IT company used. With Nightious, I never have to. They just explain it. Our team loves them.",
    name: 'Emily Chen',
    role: 'Owner, DataFlow Analytics',
    stars: 5,
  },
]

const rotations = ['-1deg', '0.5deg', '-0.5deg']
const offsets   = ['0', '-16px', '0']
---

<section class="py-20 relative overflow-hidden" aria-label="Client testimonials">
  <!-- Ambient glow behind cluster -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.12) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">CLIENT RESULTS</p>
      <h2 class="font-display text-3xl md:text-4xl" style="color: var(--color-text-primary);">
        Real results for real businesses
      </h2>
    </div>

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none">
      {testimonials.map((t, i) => (
        <li
          class="testimonial-card opacity-0"
          style={`
            transform: rotate(${rotations[i]}) translateY(${offsets[i]});
          `}
        >
          <article class="glass p-7 flex flex-col gap-5 h-full">
            <div aria-label={`${t.stars} out of 5 stars`} class="text-base" style="color: var(--color-purple-mid);">
              {'★'.repeat(t.stars)}
            </div>
            <blockquote class="text-sm leading-relaxed flex-1 italic" style="color: var(--color-text-primary);">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <footer>
              <p class="text-sm font-semibold" style="color: var(--color-text-primary);">{t.name}</p>
              <p class="text-xs" style="color: var(--color-text-muted);">{t.role}</p>
            </footer>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Remove rotations on mobile — looks broken at narrow widths */
  @media (max-width: 767px) {
    .testimonial-card {
      transform: none !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let proofTl: gsap.core.Timeline | null = null

  function initProof() {
    const cards = document.querySelectorAll<HTMLElement>('.testimonial-card')
    if (!cards.length) return

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) {
      cards.forEach(c => { c.style.opacity = '1' })
      return
    }

    proofTl = gsap.timeline({
      scrollTrigger: { trigger: cards[0], start: 'top 85%', once: true },
    })

    proofTl.fromTo(
      cards,
      { opacity: 0, y: 40 },
      { opacity: 1, y: 0, stagger: 0.12, duration: 0.6, ease: 'power2.out' }
    )
  }

  document.addEventListener('astro:before-swap', () => { proofTl?.kill(); proofTl = null })
  document.addEventListener('astro:page-load', initProof)
</script>
