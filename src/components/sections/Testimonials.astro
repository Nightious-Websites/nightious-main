---
const testimonials = [
  { quote: "They redesigned our site in two weeks. Traffic doubled the next month.", name: "Sarah M.", company: "Mitchell & Co. Accounting", initials: "SM" },
  { quote: "Set up our entire AI pipeline in a week. We've saved 20+ hours a month since.", name: "James R.", company: "Riverside Auto Services", initials: "JR" },
  { quote: "Finally, an IT company that picks up the phone. Fixed our email issues same day.", name: "Emily C.", company: "Chen's Catering Co.", initials: "EC" },
  { quote: "They built custom automation for our booking system. No one else even understood what we needed.", name: "Marcus T.", company: "Clearview Dental", initials: "MT" },
  { quote: "My stream setup went from amateur to professional in one session. Worth every penny.", name: "Alex K.", company: "Content Creator", initials: "AK" },
  { quote: "Got us off GoDaddy, set up Cloudflare, migrated our email — zero downtime.", name: "Priya N.", company: "Northside Legal Group", initials: "PN" },
  { quote: "The privacy audit found three accounts that had been breached. They locked everything down that afternoon.", name: "David L.", company: "Freelance Photographer", initials: "DL" },
  { quote: "We needed a site, email, and marketing plan. They handled all of it and came in under budget.", name: "Rachel W.", company: "Bloom Beauty Studio", initials: "RW" },
]

const avatarGradients = [
  'linear-gradient(135deg, rgba(168,85,247,0.7), rgba(34,197,94,0.5))',
  'linear-gradient(135deg, rgba(34,197,94,0.6), rgba(168,85,247,0.6))',
  'linear-gradient(135deg, rgba(168,85,247,0.8), rgba(192,132,252,0.5))',
  'linear-gradient(135deg, rgba(34,197,94,0.7), rgba(168,85,247,0.4))',
]
---

<section class="testi-section py-20 relative overflow-hidden" aria-label="Client testimonials">
  <!-- Emerald aurora -->
  <div class="testi-aurora" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="glass-pill glass-pill--emerald" aria-hidden="true"><span class="glass-pill-dot"></span> Client Results</span>
      <h2 class="testi-headline">
        Don't take <span class="accent-italic">our</span> <span class="testi-grad">word for it.</span>
      </h2>
    </div>
  </div>

  <!-- Carousel -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="carousel-overflow overflow-hidden">
      <div class="carousel-track flex gap-4" id="testimonial-track">
        {testimonials.map((t, i) => (
          <article class="testimonial-card flex-shrink-0 flex flex-col gap-3 p-6">
            <div class="testi-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote class="testi-quote flex-1">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <footer class="flex items-center gap-3">
              <div
                class="testi-avatar flex-shrink-0 flex items-center justify-center rounded-full text-xs font-bold text-white"
                style={`background: ${avatarGradients[i % 4]};`}
                aria-hidden="true"
              >
                {t.initials}
              </div>
              <div>
                <p class="testi-name">{t.name}</p>
                <p class="testi-company">{t.company}</p>
              </div>
            </footer>
          </article>
        ))}
      </div>
    </div>

    <!-- Edge fades -->
    <div class="testi-fade-left" aria-hidden="true"></div>
    <div class="testi-fade-right" aria-hidden="true"></div>
  </div>
</section>

<style>
  .testi-section {
    background-color: var(--color-bg-section);
    position: relative;
  }

  /* Emerald aurora blob */
  .testi-aurora {
    position: absolute;
    width: 500px;
    height: 360px;
    background: radial-gradient(ellipse, rgba(34, 197, 94, 0.1) 0%, transparent 65%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
    pointer-events: none;
    animation: testi-breathe 7s ease-in-out infinite;
    z-index: 0;
  }
  @keyframes testi-breathe {
    0%, 100% { opacity: 0.5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: 0.9; transform: translate(-50%,-50%) scale(1.18); }
  }

  /* Headline */
  .testi-headline {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
  }
  .testi-grad {
    background: linear-gradient(120deg, #86efac 0%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 14px rgba(34, 197, 94, 0.35));
  }

  /* Testimonial cards */
  .testimonial-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-radius: 14px;
    transition: box-shadow 0.25s;
    width: 100%;
    flex-shrink: 0;
  }
  .testimonial-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1px;
    background: linear-gradient(160deg, rgba(168, 85, 247, 0.28) 0%, rgba(255,255,255,0.04) 50%, rgba(34,197,94,0.14) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    transition: background 0.25s;
  }
  .testimonial-card:hover {
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.14);
  }
  .testimonial-card:hover::before {
    background: linear-gradient(160deg, rgba(168, 85, 247, 0.5) 0%, rgba(255,255,255,0.06) 50%, rgba(34,197,94,0.22) 100%);
  }

  @media (min-width: 640px) {
    .testimonial-card { width: calc(50% - 8px); }
  }
  @media (min-width: 1024px) {
    .testimonial-card { width: calc(25% - 12px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .carousel-track { flex-wrap: wrap; }
    .testimonial-card { width: calc(50% - 8px); }
  }

  /* Card content */
  .testi-stars {
    font-size: 13px;
    color: rgba(34, 197, 94, 0.85);
    letter-spacing: 2px;
  }
  .testi-quote {
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-primary-aurora);
    font-style: normal;
  }
  .testi-avatar {
    width: 34px;
    height: 34px;
    font-family: 'Exo 2', sans-serif;
    font-size: 10px;
    font-weight: 700;
  }
  .testi-name {
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary-aurora);
  }
  .testi-company {
    font-family: 'Exo 2', sans-serif;
    font-size: 11px;
    font-weight: 300;
    color: var(--text-muted-aurora);
  }

  /* Edge fades */
  .testi-fade-left,
  .testi-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    pointer-events: none;
    z-index: 10;
  }
  .testi-fade-left {
    left: 16px;
    background: linear-gradient(to right, var(--color-bg-section), transparent);
  }
  .testi-fade-right {
    right: 16px;
    background: linear-gradient(to left, var(--color-bg-section), transparent);
  }
  @media (min-width: 640px) {
    .testi-fade-left { left: 24px; width: 80px; }
    .testi-fade-right { right: 24px; width: 80px; }
  }
  @media (min-width: 1024px) {
    .testi-fade-left { left: 32px; }
    .testi-fade-right { right: 32px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .testi-aurora { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap'

  let scrollTween: gsap.core.Tween | null = null
  let resizeHandler: (() => void) | null = null
  let listenerAc: AbortController | null = null

  function initCarousel() {
    scrollTween?.kill()
    scrollTween = null
    if (resizeHandler) {
      window.removeEventListener('resize', resizeHandler)
      resizeHandler = null
    }
    listenerAc?.abort()
    listenerAc = new AbortController()
    const sig = { signal: listenerAc.signal }

    const track = document.getElementById('testimonial-track') as HTMLElement | null
    if (!track) return

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) return

    track.querySelectorAll('[data-cloned]').forEach(el => el.remove())

    const originals = Array.from(track.querySelectorAll<HTMLElement>('.testimonial-card'))
    if (originals.length === 0) return

    originals.forEach(card => {
      const clone = card.cloneNode(true) as HTMLElement
      clone.setAttribute('data-cloned', 'true')
      clone.setAttribute('aria-hidden', 'true')
      track.appendChild(clone)
    })

    gsap.set(track, { x: 0 })

    const cardWidth = originals[0].offsetWidth
    const gap = 16
    const loopDistance = originals.length * (cardWidth + gap)

    scrollTween = gsap.to(track, {
      x: -loopDistance,
      duration: originals.length * 5,
      ease: 'none',
      repeat: -1,
    })

    const overflow = track.closest('.carousel-overflow') as HTMLElement | null
    overflow?.addEventListener('mouseenter', () => scrollTween?.pause(), sig)
    overflow?.addEventListener('mouseleave', () => scrollTween?.resume(), sig)
    overflow?.addEventListener('touchstart', () => scrollTween?.pause(), { passive: true, signal: listenerAc!.signal })
    overflow?.addEventListener('touchend',   () => scrollTween?.resume(), { passive: true, signal: listenerAc!.signal })
    overflow?.addEventListener('focusin',    () => scrollTween?.pause(), sig)
    overflow?.addEventListener('focusout',   () => scrollTween?.resume(), sig)

    resizeHandler = () => initCarousel()
    window.addEventListener('resize', resizeHandler, { passive: true })
  }

  document.addEventListener('astro:before-swap', () => {
    scrollTween?.kill()
    scrollTween = null
    if (resizeHandler) {
      window.removeEventListener('resize', resizeHandler)
      resizeHandler = null
    }
    listenerAc?.abort()
    listenerAc = null
  })
  document.addEventListener('astro:page-load', initCarousel)
</script>
