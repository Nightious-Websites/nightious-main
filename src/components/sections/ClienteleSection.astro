---
const bundles = [
  {
    id: 'biz',
    href: '/for-businesses',
    label: 'For businesses',
    titlePre: 'IT that works ',
    titleGrad: 'quietly.',
    desc: 'We handle the infrastructure so your team never has to think about it. From managed support to cloud migrations and security \u2014 everything your business needs to stay online and protected.',
    tags: ['Managed IT', 'Cloud Ops', 'Cybersecurity', '24/7 Support'],
    explore: 'Explore For Businesses',
    pairs: [
      { q: 'Our IT keeps going down mid-shift \u2014 it\u2019s costing us hours.', a: 'We\u2019ll set up proactive monitoring so issues get caught before they hit your team.' },
      { q: 'We need to move to the cloud but have no idea where to start.', a: 'We\u2019ve done cloud migrations for teams your size. Full plan, zero downtime.' },
      { q: 'How do we know if our data is actually secure?', a: 'A proper security audit will tell you exactly where you stand. We can run one this week.' }
    ]
  },
  {
    id: 'cre',
    href: '/for-creators',
    label: 'For creators',
    titlePre: 'Your setup, finally ',
    titleGrad: 'working.',
    desc: 'Whether you\u2019re streaming, editing 4K footage, or running a studio \u2014 we build and support the tech that keeps your creative output flowing without interruption.',
    tags: ['Studio Builds', 'Network Setup', 'Remote Support', 'Equipment Advice'],
    explore: 'Explore For Creators',
    pairs: [
      { q: 'My stream keeps dropping mid-session and I\u2019m losing viewers.', a: 'Nine times out of ten it\u2019s a network configuration issue. We can diagnose it remotely.' },
      { q: 'I need a proper editing rig but every recommendation contradicts the last.', a: 'Tell us what you edit and your budget. We\u2019ll spec exactly what you need \u2014 nothing more.' },
      { q: 'Can someone just set everything up so it works together?', a: 'Yes. That\u2019s exactly what we do. One visit, everything configured and tested.' }
    ]
  },
  {
    id: 'ind',
    href: '/for-individuals',
    label: 'For individuals',
    titlePre: 'Tech help that ',
    titleGrad: 'respects you.',
    desc: 'Clear explanations, no condescension. Whether your laptop is slow, your home network is unreliable, or you just need someone you trust to sort it out \u2014 we\u2019ve got you.',
    tags: ['Home Networking', 'Device Setup', 'Repairs', 'Plain English'],
    explore: 'Explore For Individuals',
    pairs: [
      { q: 'My laptop is so slow I dread opening it every morning.', a: 'A cleanup and a few setting changes usually fixes this. Takes about an hour, remotely.' },
      { q: 'Our home Wi-Fi drops out constantly and nobody can fix it.', a: 'We\u2019ll run a full network check, find what\u2019s causing it, and sort it properly.' },
      { q: 'I just want someone to explain what\u2019s wrong without jargon.', a: 'That\u2019s exactly how we work. Plain English, every time. No exceptions.' }
    ]
  }
]

const firstBundle = bundles[0]
---

<noscript>
  <style>
    .cs-chat-window { display: none; }
    .cs-noscript-questions { display: block !important; }
  </style>
</noscript>

<section
  id="clientele-section"
  class="relative py-24 overflow-hidden"
  aria-label="Who we work with"
  style="background-color: var(--color-bg-deep);"
>
  <!-- Background ambient glows -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 60% 50% at 20% 30%, rgba(168,85,247,0.1) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 80% 70%, rgba(34,197,94,0.07) 0%, transparent 55%);"
  ></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Eyebrow -->
    <div class="cs-eyebrow" aria-hidden="true">How we help</div>

    <!-- Headline -->
    <h2 class="cs-headline">
      Who we <span class="cs-grad">work with.</span>
    </h2>

    <!-- Tabs -->
    <div class="cs-tabs" id="cs-tabs" role="tablist" aria-label="Audience">
      {bundles.map((b, i) => (
        <button
          class:list={['cs-tab', { active: i === 0 }]}
          data-key={b.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls="cs-panel"
          type="button"
        >
          {b.label.replace('For ', 'For ')}
        </button>
      ))}
    </div>

    <!-- Glass panel -->
    <div class="cs-panel" id="cs-panel" role="tabpanel">
      <div class="cs-aurora" aria-hidden="true"></div>

      <!-- LEFT: Live chat -->
      <div class="cs-col-left">
        <div class="cs-chat-label" aria-hidden="true">
          <div class="cs-live-dot"></div>
          Live conversation
        </div>
        <div class="cs-chat-window" id="cs-chat-window" aria-live="polite">
          <!-- Typing indicator — always in DOM, toggled via class -->
          <div class="cs-typing" id="cs-typing" aria-label="Typing">
            <div class="cs-dot"></div>
            <div class="cs-dot"></div>
            <div class="cs-dot"></div>
          </div>
        </div>

        <!-- Noscript fallback: show static questions -->
        <ul class="cs-noscript-questions" style="display:none;" aria-label="Common questions">
          {firstBundle.pairs.map(p => (
            <li>{p.q}</li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: Description -->
      <div class="cs-col-right" id="cs-col-right">
        <div class="cs-right-label" id="cs-right-label">{firstBundle.label}</div>
        <div class="cs-right-title">
          <span class="cs-title-pre" id="cs-title-pre">{firstBundle.titlePre}</span><span
            class="cs-title-grad"
            id="cs-title-grad">{firstBundle.titleGrad}</span>
        </div>
        <p class="cs-right-desc" id="cs-right-desc">{firstBundle.desc}</p>
        <div class="cs-tags" id="cs-tags">
          {firstBundle.tags.map(t => (
            <span class="cs-tag">{t}</span>
          ))}
        </div>
        <a
          class="cs-explore"
          id="cs-explore-link"
          href={firstBundle.href}
          aria-label={`${firstBundle.explore} page`}
        >
          <span id="cs-explore-text">{firstBundle.explore}</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Eyebrow ── */
  .cs-eyebrow {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.6);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .cs-eyebrow::before,
  .cs-eyebrow::after {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    background: rgba(168, 85, 247, 0.4);
  }

  /* ── Headline ── */
  .cs-headline {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(34px, 4.5vw, 52px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
    margin-bottom: 36px;
  }
  .cs-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.4));
  }

  /* ── Tabs ── */
  .cs-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .cs-tab {
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 10px 22px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(233, 213, 255, 0.42);
    user-select: none;
  }
  .cs-tab:hover {
    color: var(--text-primary-aurora);
    border-color: rgba(168, 85, 247, 0.25);
    background: rgba(168, 85, 247, 0.06);
  }
  .cs-tab.active {
    color: var(--text-primary-aurora);
    background: rgba(168, 85, 247, 0.1);
    border-color: transparent;
  }
  .cs-tab.active::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.7), rgba(34, 197, 94, 0.35));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .cs-tab.active::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 9px;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.2);
    pointer-events: none;
  }

  /* ── Glass panel ── */
  .cs-panel {
    position: relative;
    background: var(--glass-aurora-bg);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    height: 360px;
  }
  .cs-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 18px;
    padding: 1px;
    background: linear-gradient(160deg, rgba(168, 85, 247, 0.35) 0%, rgba(255, 255, 255, 0.06) 40%, rgba(34, 197, 94, 0.18) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 10;
  }
  .cs-panel::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.6) 0%, rgba(34, 197, 94, 0.3) 60%, transparent 100%);
    z-index: 11;
  }
  .cs-aurora {
    position: absolute;
    width: 420px;
    height: 320px;
    background: radial-gradient(ellipse, rgba(168, 85, 247, 0.1) 0%, transparent 65%);
    top: -100px;
    right: -80px;
    filter: blur(55px);
    pointer-events: none;
    animation: cs-aurora-pulse 6s ease-in-out infinite;
  }
  @keyframes cs-aurora-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.1); }
  }

  /* ── Left col: chat ── */
  .cs-col-left {
    flex: 0 0 46%;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
  }
  .cs-col-left::before {
    content: '';
    position: absolute;
    left: 0;
    top: 32px;
    bottom: 32px;
    width: 2px;
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.6) 0%, rgba(34, 197, 94, 0.35) 50%, rgba(168, 85, 247, 0.1) 100%);
  }

  .cs-chat-label {
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.45);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0;
  }
  .cs-live-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.8);
    animation: cs-live-pulse 2s ease-in-out infinite;
  }
  @keyframes cs-live-pulse {
    0%, 100% { opacity: 0.4; box-shadow: none; }
    50% { opacity: 1; box-shadow: 0 0 6px rgba(34, 197, 94, 0.6); }
  }

  .cs-chat-window {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: flex-end;
    overflow: hidden;
    position: relative;
  }
  .cs-chat-window::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(180deg, rgba(2, 0, 10, 0.9) 0%, transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

  /* Bubbles */
  .cs-bubble {
    max-width: 86%;
    padding: 10px 14px;
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.5;
    border-radius: 12px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    position: relative;
    z-index: 1;
  }
  .cs-bubble.visible { opacity: 1; transform: translateY(0); }

  .cs-bubble-q {
    align-self: flex-end;
    background: rgba(168, 85, 247, 0.12);
    border: 1px solid rgba(168, 85, 247, 0.28);
    border-radius: 14px 14px 3px 14px;
    color: rgba(233, 213, 255, 0.88);
    font-weight: 500;
  }
  .cs-bubble-a {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px 14px 14px 3px;
    color: rgba(233, 213, 255, 0.55);
    font-weight: 300;
    display: flex;
    gap: 9px;
    align-items: flex-start;
  }
  .cs-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.6), rgba(34, 197, 94, 0.4));
    margin-top: 1px;
  }

  /* Typing indicator */
  .cs-typing {
    align-self: flex-start;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px 14px 14px 3px;
    display: flex;
    gap: 4px;
    align-items: center;
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 1;
  }
  .cs-typing.visible { opacity: 1; }
  .cs-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    animation: cs-typing-bounce 1.4s ease-in-out infinite;
  }
  .cs-dot:nth-child(1) { background: rgba(168, 85, 247, 0.6); animation-delay: 0s; }
  .cs-dot:nth-child(2) { background: rgba(140, 85, 247, 0.55); animation-delay: 0.18s; }
  .cs-dot:nth-child(3) { background: rgba(34, 197, 94, 0.55); animation-delay: 0.36s; }
  @keyframes cs-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); }
  }

  /* ── Right col ── */
  .cs-col-right {
    flex: 1;
    padding: 44px 44px 44px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 18px;
    transition: opacity 0.18s ease;
  }
  .cs-right-label {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(34, 197, 94, 0.6);
  }
  .cs-right-title {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: 24px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 280px;
  }
  .cs-title-pre { color: var(--text-primary-aurora); }
  .cs-title-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 10px rgba(168, 85, 247, 0.35));
  }
  .cs-right-desc {
    font-family: 'Exo 2', sans-serif;
    font-weight: 200;
    font-size: 14px;
    line-height: 1.75;
    color: var(--text-muted-aurora);
    max-width: 330px;
    border-left: 1px solid rgba(168, 85, 247, 0.22);
    padding-left: 14px;
    margin: 0;
  }
  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .cs-tag {
    font-family: 'Exo 2', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 5px 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    color: var(--text-dim-aurora);
  }
  .cs-explore {
    font-family: 'Exo 2', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(34, 197, 94, 0.75);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    transition: color 0.2s, gap 0.2s;
    text-decoration: none;
  }
  .cs-explore:hover { color: rgba(34, 197, 94, 1); gap: 10px; }

  /* ── Mobile stack ── */
  @media (max-width: 640px) {
    .cs-panel {
      flex-direction: column;
      height: auto;
    }
    .cs-col-left {
      flex: none;
      height: 260px;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .cs-col-right {
      padding: 32px 28px;
    }
  }
</style>

<script define:vars={{ bundles }}>
  var _csTimers = []
  var _csCurrentKey = null

  function csClearTimers() {
    _csTimers.forEach(function(t) { clearTimeout(t) })
    _csTimers = []
  }

  function csLater(fn, ms) {
    var t = setTimeout(fn, ms)
    _csTimers.push(t)
    return t
  }

  function csClearChat() {
    var win = document.getElementById('cs-chat-window')
    if (!win) return
    var typing = document.getElementById('cs-typing')
    var children = Array.prototype.slice.call(win.children)
    children.forEach(function(child) {
      if (child.id !== 'cs-typing') win.removeChild(child)
    })
    if (typing) typing.classList.remove('visible')
  }

  function csAddBubble(type, text, delay) {
    csLater(function() {
      var win = document.getElementById('cs-chat-window')
      var typing = document.getElementById('cs-typing')
      if (!win || !typing) return

      if (type === 'typing') {
        typing.classList.add('visible')
        win.appendChild(typing)
        return
      }

      typing.classList.remove('visible')

      var el = document.createElement('div')
      el.className = 'cs-bubble ' + (type === 'q' ? 'cs-bubble-q' : 'cs-bubble-a')

      if (type === 'a') {
        var av = document.createElement('div')
        av.className = 'cs-avatar'
        el.appendChild(av)
        var txt = document.createElement('span')
        txt.textContent = text
        el.appendChild(txt)
      } else {
        el.textContent = text
      }

      win.insertBefore(el, typing)
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          el.classList.add('visible')
        })
      })
      win.appendChild(typing)
    }, delay)
  }

  function csRunPair(pairs, index) {
    var pair = pairs[index % pairs.length]
    var d = 0
    csAddBubble('q', pair.q, d)
    d += 600
    csAddBubble('typing', null, d)
    d += 1100
    csAddBubble('a', pair.a, d)
    d += 1800
    var nextIndex = (index + 1) % pairs.length
    csLater(function() {
      csRunPair(pairs, nextIndex)
    }, d)
  }

  function csRenderRight(bundle) {
    var right = document.getElementById('cs-col-right')
    if (!right) return
    right.style.opacity = '0'
    csLater(function() {
      var labelEl = document.getElementById('cs-right-label')
      var preEl = document.getElementById('cs-title-pre')
      var gradEl = document.getElementById('cs-title-grad')
      var descEl = document.getElementById('cs-right-desc')
      var exploreText = document.getElementById('cs-explore-text')
      var exploreLink = document.getElementById('cs-explore-link')
      var tagsEl = document.getElementById('cs-tags')

      if (labelEl) labelEl.textContent = bundle.label
      if (preEl) preEl.textContent = bundle.titlePre
      if (gradEl) gradEl.textContent = bundle.titleGrad
      if (descEl) descEl.textContent = bundle.desc
      if (exploreText) exploreText.textContent = bundle.explore
      if (exploreLink) exploreLink.setAttribute('href', bundle.href)

      if (tagsEl) {
        while (tagsEl.firstChild) tagsEl.removeChild(tagsEl.firstChild)
        bundle.tags.forEach(function(t) {
          var span = document.createElement('span')
          span.className = 'cs-tag'
          span.textContent = t
          tagsEl.appendChild(span)
        })
      }

      if (right) right.style.opacity = '1'
    }, 160)
  }

  function csSwitchTo(key) {
    if (key === _csCurrentKey) return
    _csCurrentKey = key
    var bundle = bundles.find(function(b) { return b.id === key })
    if (!bundle) return
    csClearTimers()
    csClearChat()
    csRenderRight(bundle)
    csLater(function() {
      csRunPair(bundle.pairs, 0)
    }, 200)
  }

  function csInit() {
    var tabsEl = document.getElementById('cs-tabs')
    if (!tabsEl) return

    tabsEl.addEventListener('click', function(e) {
      var tab = e.target.closest('.cs-tab')
      if (!tab) return
      document.querySelectorAll('.cs-tab').forEach(function(t) {
        t.classList.remove('active')
        t.setAttribute('aria-selected', 'false')
      })
      tab.classList.add('active')
      tab.setAttribute('aria-selected', 'true')
      csSwitchTo(tab.getAttribute('data-key'))
    })

    // Start with first tab
    _csCurrentKey = null
    csSwitchTo(bundles[0].id)
  }

  document.addEventListener('astro:before-swap', function() {
    csClearTimers()
    _csCurrentKey = null
  })

  document.addEventListener('astro:page-load', csInit)
</script>
