---
const bundles = [
  {
    id: 'biz',
    href: '/for-businesses',
    label: 'For businesses',
    titlePre: 'IT that works ',
    titleGrad: 'quietly.',
    desc: 'We handle the infrastructure so your team never has to think about it. From managed support to cloud migrations and security \u2014 everything your business needs to stay online and protected.',
    tags: ['Managed IT', 'Cloud Ops', 'Cybersecurity', '7-Day Support'],
    explore: 'Explore For Businesses',
    img: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=480&q=80&fit=crop',
    imgWash: 'linear-gradient(160deg,rgba(59,130,246,.4) 0%,rgba(168,85,247,.25) 100%)',
    pairs: [
      { q: 'Our IT keeps going down mid-shift \u2014 it\u2019s costing us hours.', a: 'We\u2019ll set up proactive monitoring so issues get caught before they hit your team.' },
      { q: 'We need to move to the cloud but have no idea where to start.', a: 'We\u2019ve done cloud migrations for teams your size. Full plan, zero downtime.' },
      { q: 'How do we know if our data is actually secure?', a: 'A proper security audit will tell you exactly where you stand. We can run one this week.' }
    ]
  },
  {
    id: 'cre',
    href: '/for-creators',
    label: 'For creators',
    titlePre: 'Your setup, finally ',
    titleGrad: 'working.',
    desc: 'Whether you\u2019re streaming, editing 4K footage, or running a studio \u2014 we build and support the tech that keeps your creative output flowing without interruption.',
    tags: ['Studio Builds', 'Network Setup', 'Remote Support', 'Equipment Advice'],
    explore: 'Explore For Creators',
    img: 'https://images.unsplash.com/photo-1593642632559-0c6d3fc62b89?w=480&q=80&fit=crop',
    imgWash: 'linear-gradient(160deg,rgba(236,72,153,.4) 0%,rgba(168,85,247,.25) 100%)',
    pairs: [
      { q: 'My stream keeps dropping mid-session and I\u2019m losing viewers.', a: 'Nine times out of ten it\u2019s a network configuration issue. We can diagnose it remotely.' },
      { q: 'I need a proper editing rig but every recommendation contradicts the last.', a: 'Tell us what you edit and your budget. We\u2019ll spec exactly what you need \u2014 nothing more.' },
      { q: 'Can someone just set everything up so it works together?', a: 'Yes. That\u2019s exactly what we do. One visit, everything configured and tested.' }
    ]
  },
  {
    id: 'ind',
    href: '/for-individuals',
    label: 'For individuals',
    titlePre: 'Tech help that ',
    titleGrad: 'respects you.',
    desc: 'Clear explanations, no condescension. Whether your laptop is slow, your home network is unreliable, or you just need someone you trust to sort it out \u2014 we\u2019ve got you.',
    tags: ['Home Networking', 'Device Setup', 'Repairs', 'Plain English'],
    explore: 'Explore For Individuals',
    img: 'https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=480&q=80&fit=crop',
    imgWash: 'linear-gradient(160deg,rgba(34,197,94,.4) 0%,rgba(96,165,250,.25) 100%)',
    pairs: [
      { q: 'My laptop is so slow I dread opening it every morning.', a: 'A cleanup and a few setting changes usually fixes this. Takes about an hour, remotely.' },
      { q: 'Our home Wi-Fi drops out constantly and nobody can fix it.', a: 'We\u2019ll run a full network check, find what\u2019s causing it, and sort it properly.' },
      { q: 'I just want someone to explain what\u2019s wrong without jargon.', a: 'That\u2019s exactly how we work. Plain English, every time. No exceptions.' }
    ]
  }
]

const firstBundle = bundles[0]
---

<noscript>
  <style>
    .cs-chat-body { display: none; }
    .cs-noscript-questions { display: block !important; }
    .cs-content { max-height: none !important; opacity: 1 !important; overflow: visible !important; }
  </style>
</noscript>

<section id="clientele-section" class="cs section-alt relative overflow-hidden" aria-label="Who we work with">
  <!-- Ambient section-local glows only — no solid background, global blobs show through -->
  <div class="cs-glow absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="cs-wrap relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Eyebrow -->
    <span class="glass-pill" aria-hidden="true">How We Help</span>

    <!-- Headline -->
    <h2 class="cs-headline">Who <span class="accent-italic">we</span> <span class="cs-grad">work with.</span></h2>

    <!-- 3-card audience selector grid -->
    <div class="cs-selectors" id="cs-selectors" role="tablist" aria-label="Audience">
      {bundles.map((b, i) => (
        <div
          class="cs-sel"
          data-key={b.id}
          role="tab"
          aria-selected="false"
          aria-controls="cs-content"
          tabindex="0"
        >
          <div class="cs-sel-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="cs-accent-bar" data-audience={b.id} aria-hidden="true"></div>
          <div class="cs-sel-title">{b.label}</div>
          <div class="cs-sel-sub">{b.desc.slice(0, 80)}...</div>
          <span class="cs-sel-tag">{b.tags[0]}</span>
          <div class="cs-sel-cta">Select</div>
        </div>
      ))}
    </div>

    <!-- Content area: glass chat window + desc card side by side -->
    <div class="cs-content" id="cs-content">
      <!-- LEFT: macOS Glass Chat Window -->
      <div class="cs-window">
        <div class="cs-titlebar">
          <div class="cs-trafficlights">
            <div class="cs-dot-close"></div>
            <div class="cs-dot-min"></div>
            <div class="cs-dot-max"></div>
          </div>
          <div class="cs-window-title">
            <div class="cs-live-dot"></div>
            Live conversation
          </div>
        </div>
        <div class="cs-chat-body" id="cs-chat" aria-live="polite">
          <div class="cs-typ" id="cs-typ">
            <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          </div>
        </div>
        <!-- Noscript fallback -->
        <ul class="cs-noscript-questions" style="display:none;" aria-label="Common questions">
          {firstBundle.pairs.map(p => (
            <li>{p.q}</li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: Description card with image column -->
      <div class="cs-desc-card" id="cs-desc-card">
        <div class="cs-img-col" id="cs-img-col">
          <img id="cs-img" src={firstBundle.img} alt="" aria-hidden="true" />
        </div>
        <div class="cs-text-col">
          <div class="cs-text-aurora" aria-hidden="true"></div>
          <div class="cs-desc-label" id="cs-label">{firstBundle.label}</div>
          <div class="cs-desc-title">
            <span class="cs-title-pre" id="cs-pre">{firstBundle.titlePre}</span><span class="cs-title-grad" id="cs-tgrad">{firstBundle.titleGrad}</span>
          </div>
          <p class="cs-desc-body" id="cs-body">{firstBundle.desc}</p>
          <div class="cs-tags" id="cs-tags">
            {firstBundle.tags.map(t => <span class="cs-tag">{t}</span>)}
          </div>
          <a class="cs-explore" id="cs-explore-link" href={firstBundle.href} aria-label={`${firstBundle.explore} page`}>
            <span id="cs-explore-text">{firstBundle.explore}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- Fake demo cursor — absolute within section so it scrolls with content -->
  <div id="fake-cursor" aria-hidden="true">
    <svg class="cur-svg" width="26" height="30" viewBox="0 0 26 30" fill="none">
      <defs>
        <linearGradient id="cur-glass" x1="2" y1="2" x2="18" y2="26" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="rgba(255,255,255,0.92)"/>
          <stop offset="45%" stop-color="rgba(220,180,255,0.75)"/>
          <stop offset="100%" stop-color="rgba(168,85,247,0.45)"/>
        </linearGradient>
        <linearGradient id="cur-shine" x1="4" y1="2" x2="8" y2="10" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="rgba(255,255,255,0.9)"/>
          <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
        </linearGradient>
      </defs>
      <path d="M4 2L4 22L8.5 17L12.5 25.5L16 24L12 15.5L19 15.5Z" fill="url(#cur-glass)" stroke="rgba(168,85,247,0.6)" stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M5.5 4L5.5 13L7.5 11L5.5 4Z" fill="url(#cur-shine)"/>
    </svg>
  </div>
</section>

<style>
  /* ── Section ── */
  .cs {
    padding: 96px 0 112px;
  }
  .cs-glow {
    background:
      radial-gradient(ellipse 60% 50% at 50% 15%, rgba(168,85,247,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 35% 35% at 10% 80%, rgba(34,197,94,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 30% 35% at 90% 70%, rgba(96,165,250,0.05) 0%, transparent 55%);
  }

  /* ── Headline ── */
  .cs-headline {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(36px, 4.8vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
    margin-bottom: 60px;
    text-align: center;
  }
  .cs-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 14px rgba(168,85,247,0.35));
  }

  /* ── Audience selector cards ── */
  .cs-selectors {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }
  .cs-sel {
    position: relative;
    padding: 26px 28px 38px;
    border-radius: 14px;
    cursor: pointer;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: all 0.25s ease;
    overflow: hidden;
    user-select: none;
  }
  /* Per-audience accent variables */
  .cs-sel[data-key="biz"] { --ag: linear-gradient(90deg,rgba(59,130,246,.8),rgba(96,165,250,.4)); --ag2: rgba(59,130,246,.1); --ar: 59,130,246; }
  .cs-sel[data-key="cre"] { --ag: linear-gradient(90deg,rgba(236,72,153,.8),rgba(232,121,249,.4)); --ag2: rgba(236,72,153,.1); --ar: 236,72,153; }
  .cs-sel[data-key="ind"] { --ag: linear-gradient(90deg,rgba(34,197,94,.8),rgba(52,211,153,.4)); --ag2: rgba(34,197,94,.1); --ar: 34,197,94; }

  /* Animated top accent border */
  .cs-sel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--ag);
    opacity: 0.35;
    transition: opacity 0.25s;
  }
  .cs-sel:hover::before, .cs-sel.active::before { opacity: 1; }

  .cs-sel[data-key="biz"] { --shimmer-delay: 0s; }
  .cs-sel[data-key="cre"] { --shimmer-delay: 1s; }
  .cs-sel[data-key="ind"] { --shimmer-delay: 2s; }

  /* Pulsing accent border on inactive cards */
  .cs-sel:not(.active) { animation: sel-pulse 2.8s ease-in-out infinite; animation-delay: var(--shimmer-delay, 0s); }
  @keyframes sel-pulse {
    0%,100% { border-color: rgba(255,255,255,0.07); }
    50%      { border-color: rgba(var(--ar), 0.35); box-shadow: 0 0 20px rgba(var(--ar),0.1); }
  }

  /* Hover — lift + full accent glow */
  .cs-sel:not(.active):hover {
    animation: none;
    background: rgba(255,255,255,0.07);
    border-color: rgba(var(--ar), 0.6);
    box-shadow: 0 0 50px rgba(var(--ar), 0.2), 0 10px 30px rgba(0,0,0,0.35);
    transform: translateY(-4px) scale(1.015);
  }
  .cs-sel.active {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.11);
    box-shadow: 0 0 50px var(--ag2);
    animation: none;
  }

  /* Card content */
  .cs-sel-num {
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
    color: rgba(var(--ar), 0.45);
    transition: color 0.28s;
  }
  .cs-sel.active .cs-sel-num { color: rgba(var(--ar), 0.9); }
  .cs-accent-bar {
    width: 40px;
    height: 2px;
    border-radius: 1px;
    margin-bottom: 12px;
    opacity: 0.35;
    transition: opacity 0.28s, width 0.28s;
  }
  .cs-sel.active .cs-accent-bar {
    opacity: 0.7;
    width: 56px;
  }
  .cs-accent-bar[data-audience="biz"] { background: var(--color-blue); }
  .cs-accent-bar[data-audience="cre"] { background: var(--color-pink-deep); }
  .cs-accent-bar[data-audience="ind"] { background: var(--color-emerald); }
  .cs-sel-title {
    font-family: 'Exo 2', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.01em;
    margin-bottom: 7px;
    color: rgba(233,213,255,0.55);
    transition: color 0.28s;
  }
  .cs-sel.active .cs-sel-title { color: var(--text-primary-aurora); }
  .cs-sel-sub {
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.6;
    color: rgba(233,213,255,0.3);
    max-width: 200px;
    transition: color 0.28s;
  }
  .cs-sel.active .cs-sel-sub { color: rgba(233,213,255,0.55); }
  .cs-sel-tag {
    display: inline-block;
    margin-top: 14px;
    font-family: 'Exo 2', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    background: rgba(var(--ar), 0.07);
    border: 1px solid rgba(var(--ar), 0.22);
    color: rgba(var(--ar), 0.65);
    transition: all 0.28s;
  }
  .cs-sel.active .cs-sel-tag {
    background: rgba(var(--ar), 0.13);
    border-color: rgba(var(--ar), 0.45);
    color: rgba(var(--ar), 1);
  }
  .cs-sel-cta {
    position: absolute;
    bottom: 16px; left: 28px;
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(var(--ar), 0.45);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.25s, gap 0.25s;
  }
  .cs-sel-cta::after { content: '\2192'; font-size: 10px; transition: transform 0.25s; }
  .cs-sel:not(.active):hover .cs-sel-cta { color: rgba(var(--ar), 1); gap: 10px; }
  .cs-sel:not(.active):hover .cs-sel-cta::after { transform: translateX(3px); }
  .cs-sel.active .cs-sel-cta { display: none; }

  /* ── Content grid ── */
  .cs-content {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 24px;
    align-items: stretch;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s ease;
  }
  .cs-content.expanded {
    max-height: 700px;
    opacity: 1;
    overflow: visible;
  }

  /* ── Glass Chat Window ── */
  .cs-window {
    position: relative;
    border-radius: 18px;
    background: rgba(255,255,255,0.045);
    border: 1px solid rgba(168,85,247,0.18);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    box-shadow: 0 0 80px rgba(168,85,247,0.11), inset 0 0 40px rgba(168,85,247,0.03), 0 0 0 1px rgba(255,255,255,0.04);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .cs-window::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(168,85,247,0.55) 35%, rgba(34,197,94,0.4) 65%, transparent);
    z-index: 2;
  }
  .cs-titlebar {
    display: flex;
    align-items: center;
    padding: 13px 16px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    flex-shrink: 0;
    position: relative;
    z-index: 11;
  }
  .cs-trafficlights { display: flex; align-items: center; gap: 8px; }
  .cs-dot-close { width: 12px; height: 12px; border-radius: 50%; background: #FF5F57; box-shadow: inset 0 -1px 0 rgba(0,0,0,0.25), 0 0 4px rgba(255,95,87,0.4); }
  .cs-dot-min   { width: 12px; height: 12px; border-radius: 50%; background: #FEBC2E; box-shadow: inset 0 -1px 0 rgba(0,0,0,0.25), 0 0 4px rgba(254,188,46,0.35); }
  .cs-dot-max   { width: 12px; height: 12px; border-radius: 50%; background: #28C840; box-shadow: inset 0 -1px 0 rgba(0,0,0,0.25), 0 0 4px rgba(40,200,64,0.35); }
  .cs-window-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(233,213,255,0.45);
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .cs-live-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(34,197,94,0.85);
    animation: live-pulse 2s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%,100% { opacity: 0.4; }
    50% { opacity: 1; box-shadow: 0 0 7px rgba(34,197,94,0.7); }
  }
  .cs-chat-body {
    padding: 20px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: flex-start;
  }

  /* :global() — bubbles/typing are JS-created, no Astro scope attr */
  :global(.cs-bubble) {
    max-width: 88%;
    padding: 9px 13px;
    font-family: 'Exo 2', sans-serif;
    font-size: 12.5px;
    line-height: 1.5;
    z-index: 1;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  :global(.cs-bubble.vis) { opacity: 1; transform: translateY(0); }
  :global(.cs-bq) {
    align-self: flex-end;
    background: rgba(168,85,247,0.14);
    border: 1px solid rgba(168,85,247,0.3);
    border-radius: 13px 13px 3px 13px;
    color: rgba(233,213,255,0.88);
    font-weight: 500;
  }
  :global(.cs-ba) {
    align-self: flex-start;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 13px 13px 13px 3px;
    color: rgba(233,213,255,0.52);
    font-weight: 300;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  :global(.cs-av) {
    width: 20px; height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(135deg, rgba(168,85,247,0.65), rgba(34,197,94,0.45));
    margin-top: 1px;
  }
  .cs-typ {
    align-self: flex-start;
    padding: 9px 13px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 13px 13px 13px 3px;
    display: flex;
    gap: 4px;
    align-items: center;
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 1;
  }
  .cs-typ.vis { opacity: 1; }
  .dot { width: 5px; height: 5px; border-radius: 50%; animation: bounce 1.4s ease-in-out infinite; }
  .dot:nth-child(1) { background: rgba(168,85,247,0.65); animation-delay: 0s; }
  .dot:nth-child(2) { background: rgba(140,85,247,0.6);  animation-delay: 0.18s; }
  .dot:nth-child(3) { background: rgba(34,197,94,0.6);   animation-delay: 0.36s; }
  @keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-5px); } }

  /* ── Description card ── */
  .cs-desc-card {
    position: relative;
    border-radius: 18px;
    background: rgba(255,255,255,0.045);
    border: 1px solid rgba(168,85,247,0.18);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    box-shadow: 0 0 80px rgba(168,85,247,0.11), inset 0 0 40px rgba(168,85,247,0.03), 0 0 0 1px rgba(255,255,255,0.04);
    overflow: hidden;
    display: flex;
    transition: opacity 0.2s ease;
  }
  .cs-desc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(168,85,247,0.55) 35%, rgba(34,197,94,0.4) 65%, transparent);
    z-index: 2;
  }
  .cs-img-col {
    flex: 0 0 240px;
    position: relative;
    overflow: hidden;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .cs-img-col img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0.55;
    filter: saturate(0.7) brightness(0.85);
    transition: opacity 0.4s ease;
  }
  .cs-img-col::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--img-wash, linear-gradient(160deg,rgba(59,130,246,.35) 0%,rgba(168,85,247,.2) 100%));
    mix-blend-mode: color;
    transition: background 0.4s ease;
  }
  .cs-img-col::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(90deg, transparent 55%, rgba(2,0,10,0.88) 100%);
  }
  .cs-text-col {
    flex: 1;
    padding: 48px 52px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 26px;
    position: relative;
  }
  .cs-text-aurora {
    position: absolute;
    width: 320px; height: 320px;
    background: radial-gradient(ellipse, rgba(168,85,247,0.07) 0%, transparent 70%);
    top: -80px; right: -60px;
    filter: blur(40px);
    pointer-events: none;
    animation: a-pulse 7s ease-in-out infinite;
  }
  @keyframes a-pulse {
    0%,100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
  }
  .cs-desc-label {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(34,197,94,0.65);
    position: relative;
  }
  .cs-desc-title {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: 30px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 280px;
    position: relative;
  }
  .cs-title-pre { color: var(--text-primary-aurora); }
  .cs-title-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(168,85,247,0.3));
  }
  .cs-desc-body {
    font-family: 'Exo 2', sans-serif;
    font-weight: 200;
    font-size: 14px;
    line-height: 1.8;
    color: rgba(233,213,255,0.55);
    border-left: 1px solid rgba(168,85,247,0.22);
    padding-left: 16px;
    position: relative;
    margin: 0;
  }
  :global(.cs-tag) {
    font-family: 'Exo 2', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 5px 13px;
    border-radius: 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    color: rgba(233,213,255,0.3);
  }
  .cs-tags { display: flex; flex-wrap: wrap; gap: 7px; position: relative; }
  .cs-explore {
    font-family: 'Exo 2', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(34,197,94,0.75);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    transition: color 0.2s, gap 0.2s;
    position: relative;
    width: fit-content;
  }
  .cs-explore:hover { color: rgba(34,197,94,1); gap: 10px; }

  /* ── Fake cursor ── */
  #fake-cursor {
    position: absolute;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: left 0.7s cubic-bezier(0.33,1,0.68,1), top 0.7s cubic-bezier(0.33,1,0.68,1), opacity 0.35s ease;
    filter:
      drop-shadow(0 0 10px rgba(168,85,247,0.55))
      drop-shadow(0 0 3px rgba(168,85,247,0.3))
      drop-shadow(0 2px 4px rgba(0,0,0,0.4));
  }
  #fake-cursor.visible { opacity: 1; }
  #fake-cursor .cur-svg { transition: transform 0.12s ease; transform-origin: 4px 2px; }
  #fake-cursor.clicking .cur-svg { transform: scale(0.78); }
  @keyframes cur-nope {
    0%,100% { transform: translateX(0); }
    20%      { transform: translateX(-5px); }
    40%      { transform: translateX(4px); }
    60%      { transform: translateX(-3px); }
    80%      { transform: translateX(2px); }
  }
  #fake-cursor.nope { animation: cur-nope 0.4s ease; }

  /* ── Click burst effect ── */
  :global(.cs-click-burst) {
    position: absolute;
    pointer-events: none;
    z-index: 10000;
    width: 10px;
    height: 10px;
    margin: -5px 0 0 -5px;
    border-radius: 50%;
    animation: click-burst 0.75s ease-out forwards;
  }
  @keyframes click-burst {
    0% {
      box-shadow:
        0 0 8px 4px rgba(168,85,247,0.9),
        0 0 0 0 rgba(168,85,247,0.4),
        0 -12px 0 1px rgba(192,132,252,0.9),
        12px 0 0 1px rgba(34,197,94,0.9),
        0 12px 0 1px rgba(192,132,252,0.9),
        -12px 0 0 1px rgba(34,197,94,0.9),
        9px -9px 0 1px rgba(168,85,247,0.85),
        -9px 9px 0 1px rgba(134,239,172,0.85),
        9px 9px 0 1px rgba(192,132,252,0.8),
        -9px -9px 0 1px rgba(34,197,94,0.8);
      opacity: 1;
    }
    100% {
      box-shadow:
        0 0 0 0 rgba(168,85,247,0),
        0 0 0 44px rgba(168,85,247,0),
        0 -60px 0 -2px rgba(192,132,252,0),
        60px 0 0 -2px rgba(34,197,94,0),
        0 60px 0 -2px rgba(192,132,252,0),
        -60px 0 0 -2px rgba(34,197,94,0),
        42px -42px 0 -2px rgba(168,85,247,0),
        -42px 42px 0 -2px rgba(134,239,172,0),
        42px 42px 0 -2px rgba(192,132,252,0),
        -42px -42px 0 -2px rgba(34,197,94,0);
      opacity: 0;
    }
  }

  /* ── Mobile stack ── */
  @media (max-width: 640px) {
    .cs-selectors { grid-template-columns: 1fr; }
    .cs-content { grid-template-columns: 1fr; }
    .cs-content.expanded { max-height: 1400px; }
    .cs-desc-card { flex-direction: column; }
    .cs-img-col { flex: none; height: 200px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .cs-text-col { padding: 32px 28px; }
  }
</style>

<script define:vars={{ bundles }}>
  var _timers = []
  var _currentKey = null
  var _chatCache = {}
  var _demoTimer = null
  var _introPhase = 'waiting'
  var _cursorHinted = false
  var _onUserExpand = null

  function later(fn, ms) {
    var t = setTimeout(fn, ms)
    _timers.push(t)
    return t
  }

  function clearTimers() {
    _timers.forEach(function(t) { clearTimeout(t) })
    _timers = []
    if (_demoTimer) { clearTimeout(_demoTimer); _demoTimer = null }
  }

  function wipeDom() {
    var el = document.getElementById('cs-chat')
    var typ = document.getElementById('cs-typ')
    if (!el) return
    var kids = Array.prototype.slice.call(el.children)
    kids.forEach(function(c) { if (c.id !== 'cs-typ') el.removeChild(c) })
    if (typ) typ.style.display = 'none'
  }

  function makeBubble(type, text, instant) {
    var b = document.createElement('div')
    b.className = 'cs-bubble ' + (type === 'q' ? 'cs-bq' : 'cs-ba')
    if (type === 'a') {
      var av = document.createElement('div')
      av.className = 'cs-av'
      b.appendChild(av)
      var sp = document.createElement('span')
      sp.textContent = text
      b.appendChild(sp)
    } else {
      b.textContent = text
    }
    if (instant) b.classList.add('vis')
    return b
  }

  function populateChat(pairs, stagger) {
    var el = document.getElementById('cs-chat')
    if (!el) return
    var delay = 0, step = 700
    pairs.forEach(function(p) {
      var bq = makeBubble('q', p.q, !stagger)
      if (stagger) bq.style.transitionDelay = delay + 'ms'
      el.appendChild(bq)
      delay += step
      var ba = makeBubble('a', p.a, !stagger)
      if (stagger) ba.style.transitionDelay = delay + 'ms'
      el.appendChild(ba)
      delay += step
    })
    if (stagger) {
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          var bubbles = el.querySelectorAll('.cs-bubble')
          for (var i = 0; i < bubbles.length; i++) bubbles[i].classList.add('vis')
        })
      })
    }
  }

  function renderDesc(bundle) {
    var card = document.getElementById('cs-desc-card')
    if (card) card.style.opacity = '0'
    later(function() {
      function set(id, v) { var e = document.getElementById(id); if (e) e.textContent = v }
      set('cs-label', bundle.label)
      set('cs-pre', bundle.titlePre)
      set('cs-tgrad', bundle.titleGrad)
      set('cs-body', bundle.desc)
      set('cs-explore-text', bundle.explore)
      var exploreLink = document.getElementById('cs-explore-link')
      if (exploreLink) exploreLink.setAttribute('href', bundle.href)
      var img = document.getElementById('cs-img')
      if (img) img.src = bundle.img
      var imgCol = document.getElementById('cs-img-col')
      if (imgCol) imgCol.style.setProperty('--img-wash', bundle.imgWash)
      var tags = document.getElementById('cs-tags')
      if (tags) {
        while (tags.firstChild) tags.removeChild(tags.firstChild)
        bundle.tags.forEach(function(t) {
          var s = document.createElement('span')
          s.className = 'cs-tag'
          s.textContent = t
          tags.appendChild(s)
        })
      }
      if (card) card.style.opacity = '1'
    }, 160)
  }

  function switchTo(key) {
    if (key === _currentKey) return
    clearTimers()
    _currentKey = key
    var bundle = bundles.filter(function(b) { return b.id === key })[0]
    if (!bundle) return
    renderDesc(bundle)
    var chatEl = document.getElementById('cs-chat')
    if (chatEl) chatEl.style.opacity = '0'
    later(function() {
      wipeDom()
      var firstVisit = !_chatCache[key]
      _chatCache[key] = true
      populateChat(bundle.pairs, firstVisit)
      if (chatEl) chatEl.style.opacity = '1'
    }, 200)
  }

  function lockWindowHeight() {
    var win = document.querySelector('.cs-window')
    var contentEl = document.getElementById('cs-content')
    if (!win) return
    // Temporarily expand content for measurement
    if (contentEl) { contentEl.style.transition = 'none'; contentEl.classList.add('expanded') }
    win.style.opacity = '0'
    var maxH = 0
    bundles.forEach(function(bundle) {
      wipeDom()
      populateChat(bundle.pairs, false)
      var h = win.offsetHeight
      if (h > maxH) maxH = h
    })
    wipeDom()
    win.style.height = maxH + 'px'
    win.style.overflow = 'hidden'
    win.style.opacity = ''
    // Collapse back without animation
    if (contentEl) { contentEl.classList.remove('expanded'); contentEl.offsetHeight; contentEl.style.transition = '' }
  }

  function initDemoCursor() {
    var cur = document.getElementById('fake-cursor')
    if (!cur) return

    var section = document.getElementById('clientele-section')

    // Convert viewport coords to section-relative coords
    function relPos(el) {
      var sr = section.getBoundingClientRect()
      var r = el.getBoundingClientRect()
      return { left: r.left - sr.left, top: r.top - sr.top, width: r.width, height: r.height, right: r.right - sr.left }
    }

    function moveTo(el, cb, duration) {
      var r = relPos(el)
      cur.style.left = (r.left + r.width * 0.72) + 'px'
      cur.style.top = (r.top + r.height * 0.18) + 'px'
      later(cb, duration || 750)
    }

    function tryClick(cb) {
      cur.classList.add('clicking')
      later(function() {
        cur.classList.remove('clicking')
        later(cb, 100)
      }, 140)
    }

    function shake(cb) {
      cur.classList.add('nope')
      later(function() {
        cur.classList.remove('nope')
        later(cb, 200)
      }, 420)
    }

    function exitCursor(cb) {
      cur.style.left = (section.offsetWidth + 30) + 'px'
      later(function() {
        cur.classList.remove('visible')
        if (cb) cb()
      }, 700)
    }

    function clickBurst() {
      var b = document.createElement('div')
      b.className = 'cs-click-burst'
      b.style.left = cur.style.left
      b.style.top = cur.style.top
      section.appendChild(b)
      later(function() { if (b.parentNode) b.parentNode.removeChild(b) }, 700)
    }

    // Intro: try clicking all 3 cards sequentially, then exit
    function runIntro() {
      if (_introPhase !== 'waiting') return
      _introPhase = 'running'
      var keys = ['biz', 'cre', 'ind']
      var idx = 0

      function nextCard() {
        if (_introPhase !== 'running') return
        if (idx >= keys.length) {
          exitCursor(function() { _introPhase = 'done' })
          return
        }
        var target = document.querySelector('.cs-sel[data-key="' + keys[idx] + '"]')
        idx++
        if (!target) { nextCard(); return }

        if (idx === 1) {
          var r = relPos(target)
          cur.style.transition = 'none'
          cur.style.left = (r.left + r.width * 0.5) + 'px'
          cur.style.top = (r.top - 40) + 'px'
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              cur.style.transition = ''
              cur.classList.add('visible')
              moveTo(target, function() {
                if (_introPhase !== 'running') return
                tryClick(function() { shake(function() { nextCard() }) })
              })
            })
          })
        } else {
          moveTo(target, function() {
            if (_introPhase !== 'running') return
            tryClick(function() { shake(function() { nextCard() }) })
          })
        }
      }

      nextCard()
    }

    // Trigger intro 0.5s after section scrolls into view
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && _introPhase === 'waiting') {
          observer.disconnect()
          later(runIntro, 500)
        }
      })
    }, { threshold: 0.3 })

    var selsArea = document.getElementById('cs-selectors')
    if (selsArea) observer.observe(selsArea)

    // When user expands a dropdown: cursor returns to click explore link
    _onUserExpand = function() {
      if (_introPhase !== 'done') {
        _introPhase = 'done'
        cur.classList.remove('visible', 'clicking', 'nope')
      }
      if (_cursorHinted) return
      _cursorHinted = true

      // Wait 2.5s after expand before pointing to explore link
      later(function() {
        var exploreLink = document.getElementById('cs-explore-link')
        if (!exploreLink) return
        var r = relPos(exploreLink)
        cur.style.transition = 'none'
        cur.style.left = '-30px'
        cur.style.top = (r.top + r.height * 0.5) + 'px'
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            cur.style.transition = 'left 1.4s cubic-bezier(0.33,1,0.68,1), top 1.4s cubic-bezier(0.33,1,0.68,1), opacity 0.35s ease'
            cur.classList.add('visible')
            moveTo(exploreLink, function() {
              cur.style.transition = ''
              clickBurst()
              tryClick(function() {
                later(function() { exitCursor() }, 300)
              })
            }, 1500)
          })
        })
      }, 2500)
    }
  }

  function csInit() {
    var sels = document.getElementById('cs-selectors')
    if (!sels) return

    // Set chat opacity transition
    var chatEl = document.getElementById('cs-chat')
    if (chatEl) chatEl.style.transition = 'opacity 0.18s ease'

    sels.addEventListener('click', function(e) {
      var sel = e.target.closest('.cs-sel')
      if (!sel) return
      var key = sel.getAttribute('data-key')
      var contentEl = document.getElementById('cs-content')

      // Toggle: clicking active selector collapses content
      if (sel.classList.contains('active')) {
        sel.classList.remove('active')
        sel.setAttribute('aria-selected', 'false')
        if (contentEl) contentEl.classList.remove('expanded')
        _currentKey = null
        return
      }

      document.querySelectorAll('.cs-sel').forEach(function(s) {
        s.classList.remove('active')
        s.setAttribute('aria-selected', 'false')
      })
      sel.classList.add('active')
      sel.setAttribute('aria-selected', 'true')
      if (contentEl) contentEl.classList.add('expanded')
      switchTo(key)
      if (_onUserExpand) _onUserExpand()
    })

    // Keyboard accessibility for selector cards
    sels.addEventListener('keydown', function(e) {
      var sel = e.target.closest('.cs-sel')
      if (!sel) return
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        sel.click()
      }
    })

    _currentKey = null
    _chatCache = {}
    lockWindowHeight()
    initDemoCursor()
  }

  document.addEventListener('astro:before-swap', function() {
    clearTimers()
    _currentKey = null
    _chatCache = {}
    _introPhase = 'waiting'
    _cursorHinted = false
    _onUserExpand = null
    var cur = document.getElementById('fake-cursor')
    if (cur) cur.classList.remove('visible')
  })

  document.addEventListener('astro:page-load', csInit)
</script>
