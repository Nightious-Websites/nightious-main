---
interface TileService {
  slug: string
  title: string
  icon: string       // SVG path data (Heroicons outline)
  tier: 'hero' | 'standard' | 'compact'
  description: string
  features: string[]  // 3-4 short feature labels
}

interface Props {
  heroService: TileService
  standardServices: TileService[]
  compactServices: TileService[]
  accentRgb: string       // e.g. "59, 130, 246"
  columnCount?: 2 | 3     // 2 for Individuals (5 services), 3 for others
}

const {
  heroService,
  standardServices,
  compactServices,
  accentRgb,
  columnCount = 3,
} = Astro.props

const mainGridClass = columnCount === 2
  ? 'grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-3'
  : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr] gap-3'
---

<section
  class="py-16 overflow-hidden"
  style={`background-color: var(--color-bg-deep);`}
  data-accent-rgb={accentRgb}
  aria-label="Services overview"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main bento grid -->
    <div class={mainGridClass}>

      <!-- Hero tile -->
      <button
        type="button"
        class="grid-tile glass text-left p-6 md:row-span-2 rounded-2xl opacity-0 flex flex-col gap-4"
        style={`border-color: rgba(${accentRgb}, 0.2);`}
        data-slug={heroService.slug}
        data-title={heroService.title}
        data-description={heroService.description}
        data-features={JSON.stringify(heroService.features)}
        aria-expanded="false"
      >
        <!-- Icon -->
        <div
          class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0"
          style={`background: rgba(${accentRgb}, 0.12); border: 1px solid rgba(${accentRgb}, 0.25);`}
          aria-hidden="true"
        >
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke={`rgba(${accentRgb}, 0.9)`}
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <Fragment set:html={heroService.icon} />
          </svg>
        </div>

        <!-- Title -->
        <h3
          class="font-display text-base leading-snug"
          style="color: var(--color-text-primary);"
        >
          {heroService.title}
        </h3>

        <!-- Description -->
        <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">
          {heroService.description}
        </p>

        <!-- Feature pills -->
        <div class="flex flex-wrap gap-2">
          {heroService.features.map(f => (
            <span
              class="text-xs px-3 py-1 rounded-full"
              style={`background: rgba(${accentRgb}, 0.1); color: rgba(${accentRgb}, 0.85); border: 1px solid rgba(${accentRgb}, 0.2);`}
            >
              ✦ {f}
            </span>
          ))}
        </div>

        <!-- Explore link -->
        <span
          class="font-display text-xs mt-auto"
          style={`color: rgba(${accentRgb}, 0.7);`}
        >
          Explore &rarr;
        </span>
      </button>

      <!-- Standard tiles -->
      {standardServices.map(service => (
        <button
          type="button"
          class="grid-tile glass text-left p-5 rounded-2xl opacity-0 flex flex-col gap-3"
          style={`border-color: rgba(${accentRgb}, 0.15);`}
          data-slug={service.slug}
          data-title={service.title}
          data-description={service.description}
          data-features={JSON.stringify(service.features)}
          aria-expanded="false"
        >
          <!-- Icon -->
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
            style={`background: rgba(${accentRgb}, 0.10); border: 1px solid rgba(${accentRgb}, 0.20);`}
            aria-hidden="true"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke={`rgba(${accentRgb}, 0.85)`}
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <Fragment set:html={service.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3
            class="font-display text-sm leading-snug"
            style="color: var(--color-text-primary);"
          >
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-xs leading-relaxed flex-1" style="color: var(--color-text-muted);">
            {service.description}
          </p>

          <!-- Feature pills -->
          <div class="flex flex-wrap gap-1.5">
            {service.features.map(f => (
              <span
                class="text-xs px-2 py-0.5 rounded-full"
                style={`background: rgba(${accentRgb}, 0.08); color: rgba(${accentRgb}, 0.75); border: 1px solid rgba(${accentRgb}, 0.15);`}
              >
                ✦ {f}
              </span>
            ))}
          </div>

          <!-- Explore link -->
          <span
            class="font-display text-xs"
            style={`color: rgba(${accentRgb}, 0.65);`}
          >
            Explore &rarr;
          </span>
        </button>
      ))}
    </div>

    <!-- Compact row -->
    {compactServices.length > 0 && (
      <div
        class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-3"
        style={compactServices.length > 3 ? `--compact-cols: repeat(${Math.min(compactServices.length, 5)}, 1fr);` : ''}
      >
        {compactServices.map(service => (
          <button
            type="button"
            class="grid-tile glass text-left px-4 py-3 rounded-xl opacity-0 flex items-center gap-3"
            style={`border-color: rgba(${accentRgb}, 0.12);`}
            data-slug={service.slug}
            data-title={service.title}
            data-description={service.description}
            data-features={JSON.stringify(service.features)}
            aria-expanded="false"
          >
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
              style={`background: rgba(${accentRgb}, 0.08); border: 1px solid rgba(${accentRgb}, 0.15);`}
              aria-hidden="true"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke={`rgba(${accentRgb}, 0.8)`}
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <Fragment set:html={service.icon} />
              </svg>
            </div>
            <span
              class="font-display text-xs leading-snug"
              style="color: var(--color-text-primary);"
            >
              {service.title}
            </span>
          </button>
        ))}
      </div>
    )}

  </div>
</section>

<!-- Expand overlay backdrop -->
<div
  id="grid-overlay-backdrop"
  class="hidden"
  style="position:fixed;inset:0;z-index:40;background:rgba(2,0,10,0.7);"
  aria-hidden="true"
></div>

<!-- Expand overlay panel -->
<div
  id="grid-overlay-panel"
  class="hidden"
  style="position:fixed;z-index:50;background:rgba(5,0,15,0.92);border:1px solid rgba(255,255,255,0.10);border-radius:20px;backdrop-filter:blur(32px);-webkit-backdrop-filter:blur(32px);padding:28px;box-shadow:0 0 80px rgba(0,0,0,0.5);"
  role="dialog"
  aria-modal="true"
  aria-labelledby="overlay-title"
>
  <!-- Close button -->
  <button
    type="button"
    id="grid-overlay-close"
    style="position:absolute;top:16px;right:16px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);border-radius:8px;cursor:pointer;color:var(--color-text-muted);"
    aria-label="Close"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <!-- Dynamic content injected by script -->
  <div id="overlay-content"></div>
</div>

<!-- Noscript: ensure tiles are visible without JS -->
<noscript><style>.grid-tile { opacity: 1 !important; }</style></noscript>

<style>
  .grid-tile {
    position: relative;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .grid-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--reflect-x, 50%) var(--reflect-y, 50%),
      rgba(255,255,255,0.06) 0%, transparent 60%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .grid-tile:hover::after {
    opacity: 1;
  }
  @media (min-width: 768px) {
    [style*="--compact-cols"] {
      grid-template-columns: var(--compact-cols);
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let gridTl: gsap.core.Timeline | null = null
  let controller: AbortController | null = null

  // ── Safe DOM builder for overlay content ────────────────────────────────────
  function buildOverlayContent(
    container: HTMLElement,
    title: string,
    desc: string,
    features: string[],
    slug: string,
    accentRgb: string
  ) {
    container.replaceChildren()

    const h2 = document.createElement('h2')
    h2.id = 'overlay-title'
    h2.textContent = title
    h2.style.cssText = `font-family:'Orbitron',sans-serif;font-size:20px;color:rgba(${accentRgb},1);margin-bottom:8px;`
    container.appendChild(h2)

    const p = document.createElement('p')
    p.textContent = desc
    p.style.cssText = `font-size:14px;color:var(--color-text-muted);line-height:1.6;margin-bottom:16px;`
    container.appendChild(p)

    if (features.length) {
      const featureDiv = document.createElement('div')
      featureDiv.style.cssText = 'display:flex;flex-direction:column;gap:4px;margin-bottom:16px;'
      features.forEach(f => {
        const span = document.createElement('span')
        span.textContent = `✦ ${f}`
        span.style.cssText = `font-size:13px;color:rgba(${accentRgb},0.8);background:rgba(${accentRgb},0.08);padding:6px 12px;border-radius:6px;`
        featureDiv.appendChild(span)
      })
      container.appendChild(featureDiv)
    }

    const link = document.createElement('a')
    link.href = `/services/${slug}`
    link.textContent = `Explore ${title} →`
    link.style.cssText = `font-family:'Orbitron',sans-serif;font-size:12px;color:rgba(${accentRgb},0.9);text-decoration:none;`
    container.appendChild(link)
  }

  // ── Main init ────────────────────────────────────────────────────────────────
  function initLivingGrid() {
    const tiles = document.querySelectorAll<HTMLElement>('.grid-tile')
    if (!tiles.length) return

    const backdrop = document.getElementById('grid-overlay-backdrop') as HTMLElement | null
    const panel    = document.getElementById('grid-overlay-panel')    as HTMLElement | null
    const content  = document.getElementById('overlay-content')        as HTMLElement | null
    const closeBtn = document.getElementById('grid-overlay-close')     as HTMLButtonElement | null

    if (!backdrop || !panel || !content || !closeBtn) return

    // Read accentRgb from section's data attribute
    const section = document.querySelector<HTMLElement>('[data-accent-rgb]')
    const accentRgb = section?.dataset.accentRgb ?? '168, 85, 247'

    const reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const isMobile = window.matchMedia('(max-width: 767px)').matches

    // ── Reduced motion path ────────────────────────────────────────────────────
    if (reduced) {
      tiles.forEach(t => { t.style.opacity = '1' })
      setupExpandBehavior(tiles, backdrop, panel, content, closeBtn, accentRgb, true)
      return
    }

    // ── Staggered entrance ─────────────────────────────────────────────────────
    gridTl = gsap.timeline({
      scrollTrigger: {
        trigger: tiles[0],
        start: 'top 85%',
        once: true,
      },
    })

    gridTl.fromTo(
      tiles,
      { opacity: 0, y: 40 },
      { opacity: 1, y: 0, stagger: 0.08, duration: 0.5, ease: 'power2.out' }
    )

    // ── Cursor tracking (desktop only) ─────────────────────────────────────────
    if (!isMobile) {
      controller = new AbortController()
      const { signal } = controller

      let rafPending = false

      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (rafPending) return
        rafPending = true
        requestAnimationFrame(() => {
          rafPending = false
          tiles.forEach(tile => {
            const rect = tile.getBoundingClientRect()
            const cx   = rect.left + rect.width  / 2
            const cy   = rect.top  + rect.height / 2
            const dx   = e.clientX - cx
            const dy   = e.clientY - cy
            const dist = Math.sqrt(dx * dx + dy * dy)
            const maxDist = 400
            const intensity = Math.max(0, 1 - dist / maxDist)

            // Proximity glow
            if (intensity > 0) {
              tile.style.boxShadow = `0 0 ${30 * intensity}px rgba(${accentRgb}, ${0.15 * intensity})`
            } else {
              tile.style.boxShadow = ''
            }

            // 3D tilt when cursor is within tile bounds
            if (
              e.clientX >= rect.left &&
              e.clientX <= rect.right &&
              e.clientY >= rect.top  &&
              e.clientY <= rect.bottom
            ) {
              const relX = (e.clientX - rect.left) / rect.width  - 0.5
              const relY = (e.clientY - rect.top)  / rect.height - 0.5
              gsap.to(tile, {
                rotateX: -relY * 6,
                rotateY:  relX * 6,
                duration: 0.3,
                transformPerspective: 800,
                ease: 'power1.out',
              })
              tile.style.setProperty('--reflect-x', `${(relX + 0.5) * 100}%`)
              tile.style.setProperty('--reflect-y', `${(relY + 0.5) * 100}%`)
            }
          })
        })
      }, { signal })

      // Per-tile mouseleave: reset tilt
      tiles.forEach(tile => {
        tile.addEventListener('mouseleave', () => {
          gsap.to(tile, {
            rotateX: 0,
            rotateY: 0,
            duration: 0.4,
            transformPerspective: 800,
            ease: 'power2.out',
          })
          tile.style.boxShadow = ''
          tile.style.removeProperty('--reflect-x')
          tile.style.removeProperty('--reflect-y')
        }, { signal })
      })
    }

    // ── Expand behavior ────────────────────────────────────────────────────────
    setupExpandBehavior(tiles, backdrop, panel, content, closeBtn, accentRgb, false)
  }

  // ── Expand / close overlay ────────────────────────────────────────────────
  function setupExpandBehavior(
    tiles: NodeListOf<HTMLElement>,
    backdrop: HTMLElement,
    panel: HTMLElement,
    content: HTMLElement,
    closeBtn: HTMLButtonElement,
    accentRgb: string,
    instant: boolean
  ) {
    let activeTile: HTMLElement | null = null

    function openOverlay(tile: HTMLElement) {
      const title    = tile.dataset.title       ?? ''
      const desc     = tile.dataset.description ?? ''
      const slug     = tile.dataset.slug        ?? ''
      const rawFeatures = tile.dataset.features ?? '[]'
      let features: string[] = []
      try { features = JSON.parse(rawFeatures) } catch { features = [] }

      buildOverlayContent(content, title, desc, features, slug, accentRgb)

      backdrop.classList.remove('hidden')
      panel.classList.remove('hidden')

      // Position panel
      panel.style.top       = '50%'
      panel.style.left      = '50%'
      panel.style.transform = 'translate(-50%, -50%)'
      panel.style.width     = 'min(640px, 90vw)'
      panel.style.maxHeight = '80vh'
      panel.style.overflowY = 'auto'

      tile.setAttribute('aria-expanded', 'true')
      activeTile = tile

      if (!instant) {
        gsap.fromTo(backdrop, { opacity: 0 }, { opacity: 1, duration: 0.25, ease: 'power2.out' })
        gsap.fromTo(panel,    { opacity: 0, scale: 0.9 }, { opacity: 1, scale: 1, duration: 0.3, ease: 'power2.out' })
      }

      // Trap focus: move to close button
      closeBtn.focus()
    }

    function closeOverlay() {
      if (!backdrop || !panel) return

      const done = () => {
        backdrop.classList.add('hidden')
        panel.classList.add('hidden')
        if (activeTile) {
          activeTile.setAttribute('aria-expanded', 'false')
          activeTile.focus()
          activeTile = null
        }
      }

      if (instant) {
        done()
      } else {
        gsap.to(backdrop, { opacity: 0, duration: 0.2, ease: 'power2.in' })
        gsap.to(panel,    { opacity: 0, scale: 0.9, duration: 0.2, ease: 'power2.in', onComplete: done })
      }
    }

    // Tile click → open
    tiles.forEach(tile => {
      tile.addEventListener('click', () => openOverlay(tile))
    })

    // Backdrop click → close
    backdrop.addEventListener('click', closeOverlay)

    // Close button → close
    closeBtn.addEventListener('click', closeOverlay)

    // Escape key → close
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) {
        closeOverlay()
      }
    })
  }

  // ── Lifecycle ──────────────────────────────────────────────────────────────
  document.addEventListener('astro:before-swap', () => {
    gridTl?.kill()
    gridTl = null
    controller?.abort()
    controller = null
  })

  document.addEventListener('astro:page-load', initLivingGrid)
</script>
