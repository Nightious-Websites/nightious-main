---
interface CrossSellBundle {
  href: string
  label: string
  accentRgb: string
  count: number
}

interface Props {
  bundles: CrossSellBundle[]
}

const { bundles } = Astro.props
---

<section class="cs-section" aria-label="Explore other service bundles">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Section header -->
    <p id="cs-header" class="cs-header">Not quite what you're looking for?</p>

    <!-- Cards -->
    <div class="cs-grid" id="cs-grid">
      {bundles.map((b, i) => (
        <a
          href={b.href}
          class="cs-card glass-strong"
          data-accent={b.accentRgb}
          data-index={i}
          style={`--cs-accent: rgba(${b.accentRgb}, 1); --cs-accent-dim: rgba(${b.accentRgb}, 0.12); --cs-accent-border: rgba(${b.accentRgb}, 0.25);`}
          aria-label={`${b.label}: ${b.count} services`}
        >
          <!-- Top accent line -->
          <div
            class="cs-card-topline"
            style={`background: linear-gradient(90deg, transparent, rgba(${b.accentRgb}, 0.7), transparent);`}
            aria-hidden="true"
          ></div>

          <div class="cs-card-inner">
            <!-- Label -->
            <p class="cs-card-label font-display" style={`color: rgba(${b.accentRgb}, 1);`}>
              {b.label}
            </p>
            <!-- Count -->
            <p class="cs-card-count">{b.count} services</p>
            <!-- Arrow -->
            <span class="cs-card-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>

          <!-- Glow layer (shown on hover via CSS) -->
          <div
            class="cs-card-glow"
            style={`background: radial-gradient(ellipse at 50% 100%, rgba(${b.accentRgb}, 0.18) 0%, transparent 70%);`}
            aria-hidden="true"
          ></div>
        </a>
      ))}
    </div>

  </div>
</section>

<noscript>
  <style>
    .cs-header, .cs-card { opacity: 1 !important; transform: none !important; }
  </style>
</noscript>

<style>
  /* ── Section ── */
  .cs-section {
    position: relative;
    padding: 64px 0 80px;
    background-color: var(--color-bg-deep);
    overflow: hidden;
  }

  /* ── Header ── */
  .cs-header {
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--text-dim-aurora);
    margin-bottom: 32px;
    text-transform: uppercase;
    opacity: 0;
  }

  /* ── Grid ── */
  .cs-grid {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Card ── */
  .cs-card {
    position: relative;
    display: block;
    text-decoration: none;
    min-width: 200px;
    max-width: 260px;
    flex: 1 1 200px;
    border-radius: 16px;
    border: 1px solid var(--cs-accent-border, rgba(255,255,255,0.08));
    overflow: hidden;
    opacity: 0;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }
  .cs-card:hover,
  .cs-card:focus-visible {
    transform: translateY(-6px) scale(1.02);
    border-color: var(--cs-accent-border, rgba(255,255,255,0.25));
    box-shadow:
      0 0 40px var(--cs-accent-dim, rgba(168,85,247,0.12)),
      0 0 80px var(--cs-accent-dim, rgba(168,85,247,0.06)),
      inset 0 0 20px rgba(255,255,255,0.02);
  }
  .cs-card:hover .cs-card-glow,
  .cs-card:focus-visible .cs-card-glow {
    opacity: 1;
  }
  .cs-card:hover .cs-card-arrow,
  .cs-card:focus-visible .cs-card-arrow {
    transform: translateX(4px);
  }

  /* ── Top accent line ── */
  .cs-card-topline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    z-index: 2;
  }

  /* ── Card inner ── */
  .cs-card-inner {
    position: relative;
    z-index: 2;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
  }

  .cs-card-label {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1.2;
  }

  .cs-card-count {
    font-family: 'Exo 2', sans-serif;
    font-size: 12px;
    color: var(--text-dim-aurora);
    margin: 0;
  }

  .cs-card-arrow {
    display: inline-flex;
    margin-top: 12px;
    color: var(--cs-accent, rgba(168,85,247,1));
    transition: transform 0.2s ease;
  }

  /* ── Glow layer ── */
  .cs-card-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.28s ease;
    pointer-events: none;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .cs-card {
      transition: none;
    }
    .cs-card-arrow {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let csTrigger: ScrollTrigger | null = null

  function initCrossSell() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const header = document.getElementById('cs-header')
    const cards = document.querySelectorAll<HTMLElement>('.cs-card')

    if (reduced) {
      if (header) { header.style.opacity = '1' }
      cards.forEach(c => { c.style.opacity = '1' })
      return
    }

    const section = document.querySelector<HTMLElement>('.cs-section')
    if (!section) return

    // Set initial states
    if (header) gsap.set(header, { opacity: 0, y: 12 })
    cards.forEach(c => gsap.set(c, { opacity: 0, y: 24 }))

    csTrigger = ScrollTrigger.create({
      trigger: section,
      start: 'top 82%',
      once: true,
      onEnter: () => {
        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } })
        if (header) tl.to(header, { opacity: 1, y: 0, duration: 0.5 })
        tl.to(Array.from(cards), { opacity: 1, y: 0, duration: 0.55, stagger: 0.12 }, '-=0.2')
      }
    })
  }

  document.addEventListener('astro:before-swap', () => {
    csTrigger?.kill()
    csTrigger = null
  })

  document.addEventListener('astro:page-load', initCrossSell)
</script>
