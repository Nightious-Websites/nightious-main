<section class="py-20 reveal-section" aria-label="Services overview">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">WHAT WE DO</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--color-text-primary);">
        Solutions built for your business
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color: var(--color-text-muted);">
        From your first website to AI-powered workflows — we handle it all so you can focus on what you do best.
      </p>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 list-none">
      {services.map(service => (
        <li>
          <a
            href={`/services/${service.slug}`}
            class="glass card-hover neon-top flex flex-col gap-3 h-full overflow-hidden cursor-pointer"
          >
            <!-- Service thumbnail -->
            <div class="relative w-full overflow-hidden" style="height: 160px;">
              <img
                src={`/images/photos/service-${service.slug}-hero.webp`}
                alt=""
                aria-hidden="true"
                class="w-full h-full object-cover"
                loading="lazy"
                width="600"
                height="400"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(2,0,10,0.3) 0%, rgba(2,0,10,0.65) 100%);" aria-hidden="true"></div>
            </div>
            <div class="flex flex-col gap-3 p-6 pt-4">
              <!-- SVG icon replacing emoji -->
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                style="background: rgba(124, 58, 237, 0.15); color: var(--color-purple-mid);"
                aria-hidden="true"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <Fragment set:html={service.svgPath} />
                </svg>
              </div>
              <h3 class="font-display text-sm" style="color: var(--color-text-primary);">{service.title}</h3>
              <p class="text-sm leading-relaxed flex-1" style="color: var(--color-text-muted);">{service.desc}</p>
              <p class="text-xs italic mt-1" style="color: var(--color-purple-mid);">{service.plainEnglish}</p>
              <span class="text-xs font-semibold" style="color: var(--color-purple-mid);">Learn more &rarr;</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="text-center mt-10">
      <a href="/services" class="btn-ghost cursor-pointer">
        View All 12 Services &rarr;
      </a>
    </div>
  </div>
</section>
