---
const services = [
  {
    slug: 'website-solutions',
    title: 'Website Solutions',
    plainEnglish: 'A website that actually gets you customers.',
  },
  {
    slug: 'ai-integration',
    title: 'AI Integration',
    plainEnglish: 'We make software do your boring tasks.',
  },
  {
    slug: 'digital-marketing',
    title: 'Digital Marketing',
    plainEnglish: 'We help people find you online.',
  },
  {
    slug: 'computer-services',
    title: 'Computer Services',
    plainEnglish: 'We fix your tech — fast, no judgment.',
  },
  {
    slug: 'email-solutions',
    title: 'Email Solutions',
    plainEnglish: 'Professional email that works reliably.',
  },
  {
    slug: 'online-privacy',
    title: 'Online Privacy',
    plainEnglish: 'We keep hackers out of your business.',
  },
  {
    slug: 'software-services',
    title: 'Software Services',
    plainEnglish: 'We automate the stuff you hate doing.',
  },
  {
    slug: 'streaming-consultation',
    title: 'Streaming Consultation',
    plainEnglish: 'We set up your stream so you look pro.',
  },
]

// Mosaic row definitions: [slug, slug] with fr widths
const rows = [
  { services: [services[0], services[1]], cols: '2fr 1fr' },
  { services: [services[2], services[3]], cols: '1fr 2fr' },
  { services: [services[4], services[5], services[6]], cols: '1.5fr 1fr 1fr' },
  { services: [services[7]], cols: '2fr', hasViewAll: true },
]
---

<section class="py-20 reveal-section section-alt" aria-label="Services overview">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">WHAT WE DO</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--color-text-primary);">
        Solutions built for your business
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color: var(--color-text-muted);">
        From your first website to AI-powered workflows — we handle it all.
      </p>
    </div>

    <!-- Mosaic: stacked rows on mobile, fr-grid on desktop -->
    <ul class="flex flex-col gap-2 list-none" id="services-mosaic">
      {rows.map((row, rowIdx) => (
        <li>
          <!-- Mobile: stack services vertically. Desktop: fr-grid row -->
          <div
            class="flex flex-col lg:grid gap-2"
            style={`--row-cols: ${row.cols};`}
          >
            {row.services.map(service => (
              <a
                href={`/services/${service.slug}`}
                class="service-strip relative overflow-hidden glass card-hover cursor-pointer flex flex-col justify-end"
                style="height: 100px;"
                data-slug={service.slug}
              >
                <!-- Photo background -->
                <img
                  src={`/images/photos/service-${service.slug}-hero.webp`}
                  alt=""
                  aria-hidden="true"
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                  width="600"
                  height="400"
                />
                <!-- Overlay -->
                <div
                  class="absolute inset-0"
                  style="background: linear-gradient(to top, rgba(2,0,10,0.85) 0%, rgba(2,0,10,0.4) 60%, transparent 100%);"
                  aria-hidden="true"
                ></div>
                <!-- Content -->
                <div class="relative z-10 px-5 pb-4">
                  <p class="font-display text-xs tracking-widest" style="color: var(--color-text-primary);">{service.title}</p>
                  <!-- Tagline: always visible on mobile, hover-reveal on desktop -->
                  <p
                    class="service-tagline text-xs mt-1 lg:opacity-0"
                    style="color: var(--color-purple-light);"
                  >
                    {service.plainEnglish}
                  </p>
                </div>
              </a>
            ))}
            {row.hasViewAll && (
              <a
                href="/services"
                class="glass card-hover flex items-center justify-center cursor-pointer"
                style="height: 100px; border-style: dashed;"
              >
                <span class="font-display text-xs tracking-widest" style="color: var(--color-purple-mid);">
                  VIEW ALL 12 SERVICES &rarr;
                </span>
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Apply CSS grid columns on desktop using the custom property */
  @media (min-width: 1024px) {
    [style*="--row-cols"] {
      grid-template-columns: var(--row-cols);
    }
  }
</style>

<script>
  import { gsap } from 'gsap'

  function initMosaic() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) return

    // Desktop only: hover expand strips to 180px and reveal tagline
    if (window.innerWidth < 1024) return

    const strips = document.querySelectorAll<HTMLElement>('.service-strip')

    strips.forEach(strip => {
      const tagline = strip.querySelector<HTMLElement>('.service-tagline')
      if (!tagline) return

      strip.addEventListener('mouseenter', () => {
        gsap.to(strip, { height: 180, duration: 0.35, ease: 'power2.out' })
        gsap.to(tagline, { opacity: 1, duration: 0.25, delay: 0.1 })
      })

      strip.addEventListener('mouseleave', () => {
        gsap.to(strip, { height: 100, duration: 0.3, ease: 'power2.in' })
        gsap.to(tagline, { opacity: 0, duration: 0.2 })
      })

      // Keyboard focus
      strip.addEventListener('focusin', () => {
        gsap.to(strip, { height: 180, duration: 0.35, ease: 'power2.out' })
        gsap.to(tagline, { opacity: 1, duration: 0.25, delay: 0.1 })
      })
      strip.addEventListener('focusout', () => {
        gsap.to(strip, { height: 100, duration: 0.3, ease: 'power2.in' })
        gsap.to(tagline, { opacity: 0, duration: 0.2 })
      })
    })

    return strips
  }

  let activeStrips: NodeListOf<HTMLElement> | null = null

  document.addEventListener('astro:before-swap', () => {
    if (activeStrips) { gsap.killTweensOf(activeStrips); activeStrips = null }
  })
  document.addEventListener('astro:page-load', () => { activeStrips = initMosaic() ?? null })
</script>
