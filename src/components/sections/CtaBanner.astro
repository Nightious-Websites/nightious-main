---
---

<section
  class="py-20 reveal-section relative overflow-hidden"
  aria-label="Final call to action"
>
  <!-- Background image -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src="/images/photos/home-ctabanner.webp"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="lazy"
      width="1920"
      height="600"
    />
    <div class="absolute inset-0" style="background: rgba(2,0,10,0.82);"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 z-10 bg-grid pointer-events-none" aria-hidden="true"></div>

  <!-- Subtle gradient glow -->
  <div
    class="absolute inset-0 z-10 pointer-events-none"
    style="background: linear-gradient(135deg, rgba(124, 58, 237, 0.12) 0%, rgba(236, 72, 153, 0.08) 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative glass-strong neon-top p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- HUD corner accents inside the card -->
      <div class="absolute top-4 left-4 w-5 h-5 pointer-events-none" style="border-top: 1px solid rgba(168,85,247,0.4); border-left: 1px solid rgba(168,85,247,0.4);" aria-hidden="true"></div>
      <div class="absolute bottom-4 right-4 w-5 h-5 pointer-events-none" style="border-bottom: 1px solid rgba(168,85,247,0.4); border-right: 1px solid rgba(168,85,247,0.4);" aria-hidden="true"></div>

      <div>
        <h2 class="font-display text-2xl md:text-3xl mb-2" style="color: var(--color-text-primary);">
          Still reading jargon on other IT sites?
        </h2>
        <p class="text-sm" style="color: var(--color-text-muted);">
          Let's talk like humans. Free quote, no contracts, no tech-speak.
        </p>
      </div>
      <a href="/contact" class="btn-primary text-base flex-shrink-0 cursor-pointer">
        Talk to a Real Human &rarr;
      </a>
    </div>
  </div>
</section>
