---
const steps = [
  {
    number: '01',
    heading: 'Tell us what you need',
    bodyHtml: 'Fill out the contact form or give us a call. No questionnaires, no runaround. Just tell us what\'s not working. <strong style="color: var(--color-purple-light);">We respond within 4 hours.</strong>',
  },
  {
    number: '02',
    heading: 'We send you a clear plan',
    bodyHtml: 'We look at your situation and put together a proposal. What we\'ll do, what it costs, how long it takes. <strong style="color: var(--color-purple-light);">No hidden fees. No long-term lock-in.</strong>',
  },
  {
    number: '03',
    heading: 'We get it done',
    bodyHtml: 'We handle the work end-to-end and keep you posted along the way. When it\'s finished, we make sure you know how everything works. <strong style="color: var(--color-purple-light);">Ongoing support if you need it.</strong>',
  },
]
---

<section class="py-20 overflow-hidden" aria-label="How it works">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">THE PROCESS</p>
      <h2 class="font-display text-3xl md:text-4xl" style="color: var(--color-text-primary);">
        How it works
      </h2>
    </div>

    <!-- Desktop: horizontal grid with connecting line -->
    <!-- Mobile: vertical stack -->
    <div class="relative">

      <!-- Horizontal connector line (desktop only) -->
      <div
        id="process-line"
        class="hidden lg:block absolute top-6 left-0 right-0 pointer-events-none"
        style="height: 1px; background: linear-gradient(to right, transparent, rgba(168,85,247,0.4), transparent); transform-origin: left center; transform: scaleX(0);"
        aria-hidden="true"
      ></div>

      <ol class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 list-none">
        {steps.map((step, i) => (
          <li
            class="process-step flex flex-col gap-4 opacity-0"
          >
            <!-- Step circle -->
            <div
              class="w-12 h-12 rounded-full flex items-center justify-center font-display text-sm flex-shrink-0"
              style={`background: rgba(124, 58, 237, ${0.12 + i * 0.06}); border: 1px solid rgba(168, 85, 247, 0.45); color: var(--color-purple-light); box-shadow: 0 0 20px rgba(168, 85, 247, ${0.15 + i * 0.05}), inset 0 0 10px rgba(168, 85, 247, 0.05);`}
            >
              {step.number}
            </div>

            <!-- Mobile connector line (vertical) -->
            {i < steps.length - 1 && (
              <div
                class="lg:hidden w-px ml-6"
                style="height: 32px; background: linear-gradient(to bottom, rgba(168,85,247,0.4), rgba(168,85,247,0.1));"
                aria-hidden="true"
              ></div>
            )}

            <!-- Content -->
            <div class="glass p-6">
              <h3 class="font-display text-sm mb-3" style="color: var(--color-text-primary);">{step.heading}</h3>
              {/* SECURITY: bodyHtml must remain compile-time static. Never accept from CMS, DB, or user input without sanitization. */}
              <p class="text-sm leading-relaxed" style="color: var(--color-text-primary);" set:html={step.bodyHtml} />
            </div>
          </li>
        ))}
      </ol>
    </div>

    <div class="text-center mt-12">
      <a href="/contact" class="btn-primary cursor-pointer">Get Started &rarr;</a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let processTl: gsap.core.Timeline | null = null

  function initProcess() {
    const steps = document.querySelectorAll<HTMLElement>('.process-step')
    const line = document.getElementById('process-line')
    if (!steps.length) return

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) {
      steps.forEach(s => { s.style.opacity = '1'; s.style.transform = '' })
      if (line) line.style.transform = 'scaleX(1)'
      return
    }

    processTl = gsap.timeline({
      scrollTrigger: { trigger: steps[0], start: 'top 80%', once: true },
    })

    processTl.fromTo(
      steps,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, stagger: 0.15, duration: 0.6, ease: 'power2.out' }
    )

    if (line) {
      processTl.fromTo(
        line,
        { scaleX: 0 },
        { scaleX: 1, duration: 0.6, ease: 'power2.out' },
        '<'
      )
    }
  }

  document.addEventListener('astro:before-swap', () => { processTl?.kill(); processTl = null })
  document.addEventListener('astro:page-load', initProcess)
</script>
