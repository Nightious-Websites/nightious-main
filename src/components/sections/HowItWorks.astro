---
const steps = [
  {
    number: '01',
    title: 'Discovery Call',
    bodyHtml: "Tell us what's broken. We listen, ask the right questions, and figure out the real problem — not just the symptoms. <strong>Fast response, every time.</strong>",
    accentRgb: '168, 85, 247',
    duration: '~1 week',
    durationFill: 20,
    blobPath: 'M45.2,-62.3C57.1,-53.6,64.2,-37.8,69.4,-21.3C74.6,-4.8,77.8,12.4,72.2,26.5C66.5,40.6,52,51.6,36.8,59.4C21.6,67.2,5.6,71.9,-10.8,71.1C-27.2,70.3,-43.9,64.1,-55.3,53C-66.7,41.9,-72.7,25.9,-74.5,9.4C-76.2,-7.2,-73.6,-24.2,-64.4,-36.5C-55.3,-48.8,-39.5,-56.4,-24.2,-63.6C-8.8,-70.8,6.1,-77.6,20,-74.3C33.9,-70.9,33.3,-71,45.2,-62.3Z',
  },
  {
    number: '02',
    title: 'Strategy & Blueprint',
    bodyHtml: "We map out the solution — what we'll build, the timeline, and exact costs. You see the full picture before anything starts. <strong>No hidden fees. No lock-in.</strong>",
    accentRgb: '129, 140, 248',
    duration: '1–2 weeks',
    durationFill: 25,
    blobPath: 'M42.1,-55.8C53.3,-48.2,60.1,-33.5,65.4,-18.1C70.7,-2.7,74.6,13.4,68.8,26.4C63,39.4,47.6,49.3,32.2,56.6C16.8,63.9,1.5,68.6,-14.7,67.5C-30.9,66.4,-48,59.5,-58.2,46.8C-68.4,34.1,-71.7,15.5,-69.2,-1.6C-66.7,-18.7,-58.4,-34.3,-46.3,-41.7C-34.2,-49.1,-18.3,-48.3,-1.2,-56.8C15.9,-65.3,30.9,-63.4,42.1,-55.8Z',
  },
  {
    number: '03',
    title: 'Build & Ship',
    bodyHtml: 'We handle the work end-to-end and keep you in the loop. You get progress updates, not radio silence. <strong>We ship when we say we will.</strong>',
    accentRgb: '94, 168, 247',
    duration: '3–6 weeks',
    durationFill: 60,
    blobPath: 'M38.5,-51.4C52.9,-44.7,69.5,-37.2,74.8,-24.8C80.1,-12.4,74.1,4.9,66.5,19.8C58.9,34.7,49.7,47.2,37.6,55.4C25.5,63.6,10.6,67.5,-3.1,65.8C-16.8,64.1,-29.3,56.8,-41.9,48.1C-54.5,39.4,-67.2,29.3,-71.5,16.1C-75.8,2.9,-71.8,-13.4,-63.3,-26C-54.8,-38.6,-41.8,-47.5,-29,-54.4C-16.2,-61.2,-3.5,-66,6.1,-63.8C15.8,-61.6,24.1,-58.2,38.5,-51.4Z',
  },
  {
    number: '04',
    title: 'Launch & Evolve',
    bodyHtml: "Go live with confidence. We make sure everything works, train your team, and stay on for support as things grow. <strong>Your success is our success.</strong>",
    accentRgb: '34, 197, 94',
    duration: 'Ongoing',
    durationFill: 15,
    blobPath: 'M40.6,-52.1C54.3,-46.2,68.3,-36.1,73.2,-22.6C78.1,-9.1,73.9,7.8,66.3,21.4C58.7,35,47.7,45.3,34.8,53.1C21.9,60.9,7.1,66.2,-8.4,66.1C-23.9,66,-40.1,60.5,-51.1,49.9C-62.1,39.3,-67.9,23.6,-69,7.6C-70.1,-8.4,-66.5,-24.7,-57.4,-35.8C-48.3,-46.9,-33.7,-52.8,-19.6,-58.5C-5.5,-64.2,8.1,-69.7,21.5,-67.1C34.9,-64.5,26.9,-58,40.6,-52.1Z',
  },
]
---

<section class="hiw-section" aria-label="How we work" id="hiw-section">

  <!-- Aurora background canvas (desktop only, hidden on mobile via CSS) -->
  <canvas class="hiw-aurora" id="hiw-aurora" aria-hidden="true"></canvas>

  <!-- Header -->
  <div class="hiw-header">
    <h2 class="hiw-headline">
      How <span class="accent-italic">we</span> <span class="hiw-grad">work.</span>
    </h2>
  </div>

  <!-- Sticky Split -->
  <div class="hiw-split" id="hiw-split">

    <!-- Glow zone: tracks active card position -->
    <div class="hiw-glow-zone" id="hiw-glow-zone" aria-hidden="true"></div>

    <!-- LEFT: Sticky Spine Column -->
    <div class="hiw-spine-col" id="hiw-spine-col" aria-hidden="true">
      <div class="spine-wrap">
        <!-- Track (background line) -->
        <div class="spine-track"></div>
        <!-- Fill (animated progress) -->
        <div class="spine-fill" id="spine-fill"></div>
        <!-- Traveling particle -->
        <div class="spine-particle" id="spine-particle"></div>

        <!-- 4 Nodes -->
        {steps.map((step, i) => (
          <div class={`spine-node ${i === 0 ? 'active' : ''}`} data-node={i}>
            <div class="spine-node-ring">
              <div class="spine-node-dot"></div>
            </div>
            <span class="spine-node-num">{step.number}</span>
            <div class="spine-node-arm"></div>
          </div>
        ))}
      </div>

      <!-- Progress label -->
      <div class="spine-label-wrap">
        <span class="spine-label" id="spine-label">Step 1 of 4</span>
      </div>
    </div>

    <!-- RIGHT: Step Cards -->
    <ol class="hiw-steps-col" role="list">
      {steps.map((step, i) => (
        <li
          class="hiw-step-card"
          data-step={step.number}
          style={`--accent: ${step.accentRgb}`}
        >
          {/* Decorative SVG blob */}
          <svg class="step-blob" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <radialGradient id={`blob-grad-${i}`} cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color={`rgba(${step.accentRgb}, 0.6)`} />
                <stop offset="100%" stop-color={`rgba(${step.accentRgb}, 0)`} />
              </radialGradient>
            </defs>
            <path fill={`url(#blob-grad-${i})`} d={step.blobPath} transform="translate(100 100)" />
          </svg>

          <div class="step-num" aria-hidden="true">{step.number}</div>
          <h3 class="step-title">{step.title}</h3>
          {/* SECURITY: bodyHtml is compile-time static only. Never accept from CMS, DB, or user input without sanitization. */}
          <p class="step-body" set:html={step.bodyHtml} />

          {/* Duration indicator pill */}
          <div class="step-duration">
            <div class="step-duration-bar" aria-hidden="true">
              <div class="step-duration-fill" style={`width: ${step.durationFill}%`}></div>
            </div>
            <span class="step-duration-label">{step.duration}</span>
          </div>
        </li>
      ))}
    </ol>

  </div>

  <!-- CTA -->
  <div class="hiw-cta-wrap">
    <a href="/contact" class="hiw-cta">
      Start your project
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

</section>

<style>
  /* ── Section ── */
  .hiw-section {
    position: relative;
    background-color: var(--color-bg-deep);
    padding: 100px 0 0;
  }

  /* ── Header ── */
  .hiw-header {
    text-align: center;
    margin-bottom: 64px;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hiw-headline {
    font-family: 'Exo 2', sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 4.5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--text-primary-aurora);
    margin: 0;
  }

  .hiw-grad {
    background: linear-gradient(120deg, #c084fc 0%, #86efac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 14px rgba(168, 85, 247, 0.4));
  }

  /* ── Sticky split layout ── */
  .hiw-split {
    display: grid;
    grid-template-columns: 120px 1fr;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 40px;
    align-items: start;
  }

  /* ── Left: Spine column (sticky via GSAP pin) ── */
  .hiw-spine-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  /* ── Spine wrapper (holds track + nodes) ── */
  .spine-wrap {
    position: relative;
    width: 60px;
    height: 100%;
    min-height: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Track (vertical background line) ── */
  .spine-track {
    position: absolute;
    top: 24px;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 1px;
  }

  /* ── Fill (glowing progress line) ── */
  .spine-fill {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 0%;
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.7), rgba(34, 197, 94, 0.5));
    border-radius: 1px;
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.3);
    transition: height 0.6s ease-out;
  }

  /* ── Traveling particle ── */
  .spine-particle {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.8);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.6), 0 0 6px rgba(168, 85, 247, 0.4);
    top: 24px;
    transition: top 0.6s ease-out;
    z-index: 3;
  }

  /* ── Nodes (4 positioned along the spine) ── */
  .spine-node {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    min-height: 100px;
  }

  /* Node ring */
  .spine-node-ring {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.08);
    background: var(--color-bg-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.5s ease, box-shadow 0.5s ease, background 0.5s ease;
    position: relative;
  }

  /* Inner dot */
  .spine-node-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    transition: background 0.5s ease, box-shadow 0.5s ease, transform 0.5s ease;
  }

  /* Node number (beside the ring) */
  .spine-node-num {
    position: absolute;
    left: calc(100% + 8px);
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: rgba(233, 213, 255, 0.15);
    white-space: nowrap;
    transition: color 0.5s ease;
  }

  /* Connecting arm (horizontal line toward cards) */
  .spine-node-arm {
    position: absolute;
    left: calc(50% + 22px);
    top: 50%;
    width: 20px;
    height: 1px;
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-50%);
    transition: background 0.5s ease, width 0.5s ease;
  }

  /* ── Active node state ── */
  .spine-node.active .spine-node-ring {
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 0 24px rgba(168, 85, 247, 0.2), inset 0 0 12px rgba(168, 85, 247, 0.06);
    background: rgba(168, 85, 247, 0.06);
  }

  .spine-node.active .spine-node-dot {
    background: rgba(168, 85, 247, 0.7);
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.5);
    transform: scale(1.2);
  }

  .spine-node.active .spine-node-num {
    color: rgba(168, 85, 247, 0.7);
  }

  .spine-node.active .spine-node-arm {
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.3), transparent);
    width: 32px;
  }

  /* ── Completed node (before active) ── */
  .spine-node.completed .spine-node-ring {
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.04);
  }

  .spine-node.completed .spine-node-dot {
    background: rgba(34, 197, 94, 0.5);
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.3);
  }

  .spine-node.completed .spine-node-num {
    color: rgba(34, 197, 94, 0.4);
  }

  .spine-node.completed .spine-node-arm {
    background: rgba(34, 197, 94, 0.12);
  }

  /* Pulse on active node ring */
  .spine-node.active .spine-node-ring::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(168, 85, 247, 0.15);
    animation: node-pulse 2.5s ease-in-out infinite;
  }

  @keyframes node-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.15); opacity: 0; }
  }

  /* ── Progress label ── */
  .spine-label-wrap {
    text-align: center;
  }

  .spine-label {
    font-family: 'Orbitron', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: rgba(233, 213, 255, 0.35);
    text-transform: uppercase;
  }

  /* ── Right: Step cards column ── */
  .hiw-steps-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 40px 0 120px;
    list-style: none;
    margin: 0;
  }

  /* ── Step card ── */
  .hiw-step-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 28px 24px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    opacity: 0.35;
    transform: translateY(8px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease,
      background 0.5s ease,
      border-color 0.5s ease,
      box-shadow 0.5s ease;
  }

  /* Inactive gradient border */
  .hiw-step-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1.4px;
    background: linear-gradient(160deg, rgba(168, 85, 247, 0.08) 0%, transparent 50%, rgba(34, 197, 94, 0.04) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    transition: background 0.5s ease;
  }

  /* Active state */
  .hiw-step-card.active {
    opacity: 1;
    transform: translateY(0);
    background: rgba(168, 85, 247, 0.04);
    border-color: rgba(168, 85, 247, 0.15);
    box-shadow: 0 0 40px rgba(168, 85, 247, 0.14);
  }

  .hiw-step-card.active::before {
    background: linear-gradient(160deg, rgba(168, 85, 247, 0.3) 0%, rgba(255, 255, 255, 0.06) 50%, rgba(34, 197, 94, 0.15) 100%);
  }

  /* Energy accent bar on active card */
  .hiw-step-card.active::after {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 2px;
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.6), rgba(34, 197, 94, 0.4));
    border-radius: 1px;
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.3);
  }

  /* Step number label */
  .step-num {
    font-family: 'Orbitron', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: rgba(168, 85, 247, 0.4);
    margin-bottom: 8px;
    transition: color 0.5s ease;
  }

  .hiw-step-card.active .step-num {
    color: rgba(168, 85, 247, 0.8);
  }

  /* Step title */
  .step-title {
    font-family: 'Exo 2', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--text-primary-aurora);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }

  /* Step body */
  .step-body {
    font-family: 'Exo 2', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(233, 213, 255, 0.65);
    margin: 0;
  }

  .step-body strong {
    font-weight: 600;
    color: rgba(192, 132, 252, 0.85);
  }

  /* ── CTA ── */
  .hiw-cta-wrap {
    text-align: center;
    padding: 40px 24px 100px;
  }

  .hiw-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 10px;
    background: rgba(168, 85, 247, 0.1);
    color: var(--text-primary-aurora);
    font-family: 'Exo 2', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.25s ease, gap 0.2s ease, box-shadow 0.25s ease;
  }

  .hiw-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.7), rgba(34, 197, 94, 0.35));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .hiw-cta:hover {
    background: rgba(168, 85, 247, 0.18);
    box-shadow: 0 0 24px rgba(168, 85, 247, 0.25);
    gap: 12px;
  }

  /* ── Mobile (< 768px): spine hidden, single column ── */
  @media (max-width: 767px) {
    .hiw-split {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .hiw-spine-col {
      display: none;
    }

    .hiw-steps-col {
      padding: 0 0 60px;
    }

    /* All cards visible on mobile */
    .hiw-step-card {
      opacity: 1;
      transform: none;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .spine-node.active .spine-node-ring::after {
      animation: none;
    }

    .spine-fill,
    .spine-particle {
      transition: none;
    }

    .hiw-step-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  let pinInstance: ScrollTrigger | null = null
  let stepTriggers: ScrollTrigger[] = []

  const STEP_LABELS = ['Step 1 of 4', 'Step 2 of 4', 'Step 3 of 4', 'Step 4 of 4']

  function activateStep(index: number) {
    const cards = document.querySelectorAll<HTMLElement>('.hiw-step-card')
    const nodes = document.querySelectorAll<HTMLElement>('.spine-node')
    const spineFill = document.getElementById('spine-fill')
    const spineParticle = document.getElementById('spine-particle')
    const spineLabel = document.getElementById('spine-label')
    const spineWrap = document.querySelector<HTMLElement>('.spine-wrap')

    // Toggle .active on cards
    cards.forEach((card, i) => {
      card.classList.toggle('active', i === index)
    })

    // Toggle node states: completed / active / inactive
    nodes.forEach((node, i) => {
      node.classList.remove('active', 'completed')
      if (i < index) node.classList.add('completed')
      else if (i === index) node.classList.add('active')
    })

    // Animate spine fill height and particle position
    if (spineFill && spineWrap && spineParticle) {
      const wrapH = spineWrap.offsetHeight
      const trackTop = 24
      const trackBottom = 24
      const trackH = wrapH - trackTop - trackBottom
      // Position fill to reach the center of the active node
      // Nodes are evenly distributed: node center = trackTop + (index + 0.5) * (trackH / 4)
      const targetH = trackTop + ((index + 0.5) / 4) * trackH
      const fillPct = ((targetH - trackTop) / trackH) * 100

      gsap.to(spineFill, {
        height: `${fillPct}%`,
        duration: 0.6,
        ease: 'power2.out',
      })

      gsap.to(spineParticle, {
        top: targetH,
        duration: 0.6,
        ease: 'power2.out',
      })
    }

    // Update label
    if (spineLabel) {
      spineLabel.textContent = STEP_LABELS[index]
    }
  }

  function initHowWeWork() {
    const cards = document.querySelectorAll<HTMLElement>('.hiw-step-card')
    const spineCol = document.getElementById('hiw-spine-col')
    const split = document.getElementById('hiw-split')
    if (!cards.length || !spineCol || !split) return

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) {
      cards.forEach(card => {
        card.style.opacity = '1'
        card.style.transform = 'none'
      })
      // Show all nodes as completed/active
      const nodes = document.querySelectorAll<HTMLElement>('.spine-node')
      nodes.forEach((node, i) => {
        if (i < 3) node.classList.add('completed')
        else node.classList.add('active')
      })
      const fill = document.getElementById('spine-fill')
      if (fill) fill.style.height = '100%'
      return
    }

    const isMobile = window.innerWidth < 768

    if (!isMobile) {
      // Pin the spine column for the full scroll of the steps
      pinInstance = ScrollTrigger.create({
        trigger: split,
        start: 'top top',
        end: 'bottom bottom',
        pin: spineCol,
        pinType: 'transform',
        anticipatePin: 1,
      })
    } else {
      // Mobile: stagger-reveal cards (spine is hidden via CSS)
      gsap.fromTo(
        cards,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          stagger: 0.15,
          duration: 0.55,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: split,
            start: 'top 80%',
            once: true,
          },
        }
      )
      return
    }

    // Activate first step
    activateStep(0)

    // Per-card ScrollTriggers
    cards.forEach((card, i) => {
      const trigger = ScrollTrigger.create({
        trigger: card,
        start: 'top 60%',
        end: 'bottom 40%',
        onEnter: () => activateStep(i),
        onEnterBack: () => activateStep(i),
      })
      stepTriggers.push(trigger)
    })
  }

  document.addEventListener('astro:before-swap', () => {
    pinInstance?.kill()
    stepTriggers.forEach(t => t.kill())
    pinInstance = null
    stepTriggers = []
  })

  document.addEventListener('astro:page-load', initHowWeWork)
</script>
