---
const audiences = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />`,
    title: 'Small Business Owners',
    desc: "You're Googling IT problems at 2am instead of running your business.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />`,
    title: 'Content Creators',
    desc: "You just want your stream, site, and setup to work — not a tech lecture.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />`,
    title: 'Startups & New Businesses',
    desc: 'You need a real tech foundation without enterprise pricing or enterprise jargon.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />`,
    title: 'Remote & Hybrid Teams',
    desc: "Your team is scattered, your tools aren't talking to each other, and IT is the last thing you want to manage.",
  },
]
---

<section class="py-20 reveal-section" aria-label="Who we help">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="font-display text-xs tracking-[0.25em] mb-3" style="color: var(--color-purple-mid);">WHO WE HELP</p>
      <h2 class="font-display text-3xl md:text-4xl mb-4" style="color: var(--color-text-primary);">
        Sound familiar?
      </h2>
      <p class="text-base max-w-xl mx-auto" style="color: var(--color-text-muted);">
        You don't need to understand the tech. You just need it to work.
      </p>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-5 list-none">
      {audiences.map((audience, i) => (
        <li class="glass card-hover neon-top p-8 flex flex-col gap-4">
          <div
            class={`rounded-lg flex items-center justify-center flex-shrink-0 ${i === 0 ? 'w-12 h-12' : 'w-10 h-10'}`}
            style="background: rgba(124, 58, 237, 0.15); color: var(--color-purple-mid);"
            aria-hidden="true"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <Fragment set:html={audience.icon} />
            </svg>
          </div>
          <h3 class="font-display text-sm" style="color: var(--color-text-primary);">{audience.title}</h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{audience.desc}</p>
        </li>
      ))}
    </ul>

    <div class="text-center mt-10">
      <a href="/contact" class="btn-ghost cursor-pointer">See if we're a good fit &rarr;</a>
    </div>
  </div>
</section>
