---
type SectionFormat = 'cinematic' | 'panel' | 'bundle'

interface Problem {
  headline: string
  description: string
  painPoints: string[]
}

interface BundledService {
  slug: string
  title: string
  icon: string
  image: string         // e.g. /images/photos/service-{slug}-1.webp
  solutionTagline: string
  features: string[]
}

export interface WalkthroughSection {
  format: SectionFormat
  problem: Problem
  services: BundledService[]
  bgImage?: string      // cinematic only: full-bleed background
}

interface Props {
  sections: WalkthroughSection[]
  painIntro: string[]
  accentRgb: string
}

const { sections, painIntro, accentRgb } = Astro.props

const RGB_RE = /^\d{1,3},\s*\d{1,3},\s*\d{1,3}$/
if (!RGB_RE.test(accentRgb)) {
  throw new Error(`BundleWalkthrough: accentRgb must be "R, G, B" format, got: ${JSON.stringify(accentRgb)}`)
}
---

<section
  class="relative py-16 lg:py-24 overflow-hidden"
  style="background-color: var(--color-bg-deep);"
  aria-label="Services walkthrough"
>
  <!-- Ambient glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style={`background: radial-gradient(ellipse at 50% 0%, rgba(${accentRgb}, 0.06) 0%, transparent 55%);`}
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ─── "Sound Familiar?" intro ──────────────────────────── -->
    <div class="pain-intro-section opacity-0 mb-20 lg:mb-28 rounded-2xl overflow-hidden relative">
      <!-- Background image with heavy overlay -->
      <img
        src="/images/photos/network-abstract.jpg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        width="1200" height="800"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(2,0,10,0.88) 0%, rgba(2,0,10,0.82) 100%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-0 pointer-events-none"
        style={`background: radial-gradient(ellipse at 50% 50%, rgba(${accentRgb}, 0.08) 0%, transparent 70%);`}
        aria-hidden="true"
      ></div>

      <!-- Content -->
      <div class="relative px-6 py-12 lg:py-16">
        <p
          class="font-display text-xs tracking-[0.3em] text-center mb-10"
          style={`color: rgba(${accentRgb}, 0.8);`}
        >
          SOUND FAMILIAR?
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {painIntro.map((pain) => (
            <div class="pain-intro-card opacity-0 glass rounded-xl p-6 lg:p-7 relative overflow-hidden">
              <div
                class="absolute left-0 top-0 bottom-0 w-0.5"
                style={`background: linear-gradient(to bottom, transparent, rgba(${accentRgb}, 0.6), transparent);`}
                aria-hidden="true"
              ></div>
              <p class="text-base lg:text-lg font-medium leading-snug pl-2" style="color: var(--color-text-primary);">{pain}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── Walkthrough sections ─────────────────────────────── -->
    <div class="space-y-14 lg:space-y-20">
      {sections.map((section, i) => {
        const sectionNum = String(i + 1).padStart(2, '0')
        const isEven = i % 2 === 0
        const firstService = section.services[0]

        // ── CINEMATIC FORMAT ──────────────────────────────────
        if (section.format === 'cinematic') {
          return (
            <div class="walkthrough-cinematic opacity-0 relative rounded-2xl overflow-hidden" style="min-height: 540px;">
              {/* Background image */}
              <img
                src={section.bgImage ?? firstService.image}
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                width="1920" height="1080"
              />
              {/* Gradient overlays */}
              <div
                class="absolute inset-0"
                style="background: linear-gradient(to right, rgba(2,0,10,0.93) 0%, rgba(2,0,10,0.78) 55%, rgba(2,0,10,0.5) 100%);"
                aria-hidden="true"
              ></div>
              <div
                class="absolute inset-0 pointer-events-none"
                style={`background: radial-gradient(ellipse at 70% 50%, rgba(${accentRgb}, 0.14) 0%, transparent 55%);`}
                aria-hidden="true"
              ></div>
              {/* Decorative section number watermark */}
              <div
                class="absolute right-6 lg:right-10 top-1/2 -translate-y-1/2 font-display leading-none select-none pointer-events-none"
                style="font-size: clamp(8rem, 18vw, 16rem); color: white; opacity: 0.04;"
                aria-hidden="true"
              >
                {sectionNum}
              </div>

              {/* Content grid */}
              <div class="relative max-w-none px-6 sm:px-8 lg:px-12 py-14 lg:py-20 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center" style="min-height: 540px;">
                {/* Problem */}
                <div class="problem-block">
                  <span
                    class="font-display text-xs tracking-[0.3em] mb-5 block"
                    style={`color: rgba(${accentRgb}, 0.6);`}
                  >
                    {sectionNum} — THE CHALLENGE
                  </span>
                  <h2
                    class="font-display text-3xl sm:text-4xl lg:text-5xl leading-tight mb-5"
                    style="color: var(--color-text-primary);"
                  >
                    {section.problem.headline}
                  </h2>
                  <p class="text-base leading-relaxed mb-6" style="color: var(--color-text-muted);">
                    {section.problem.description}
                  </p>
                  <ul class="space-y-2" role="list">
                    {section.problem.painPoints.map((point) => (
                      <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
                        <span class="shrink-0 mt-0.5 font-medium" style={`color: rgba(${accentRgb}, 0.7);`} aria-hidden="true">→</span>
                        <span>{point}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {/* Solution card */}
                <div class="solution-block">
                  <div
                    class="glass card-hover rounded-2xl p-6 lg:p-8"
                    style={`border-color: rgba(${accentRgb}, 0.3);`}
                  >
                    <div class="flex items-center gap-3 mb-5">
                      <div
                        class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0"
                        style={`background: rgba(${accentRgb}, 0.14); border: 1px solid rgba(${accentRgb}, 0.25);`}
                        aria-hidden="true"
                      >
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                          stroke={`rgba(${accentRgb}, 0.9)`} stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                        ><Fragment set:html={firstService.icon} /></svg>
                      </div>
                      <h3 class="font-display text-base leading-snug" style="color: var(--color-text-primary);">{firstService.title}</h3>
                    </div>
                    <p class="font-display text-xs tracking-[0.2em] mb-3" style={`color: rgba(${accentRgb}, 0.75);`}>OUR SOLUTION</p>
                    <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">{firstService.solutionTagline}</p>
                    <div class="flex flex-wrap gap-2 mb-6">
                      {firstService.features.map((feature) => (
                        <span class="text-xs px-3 py-1 rounded-full"
                          style={`background: rgba(${accentRgb}, 0.1); color: rgba(${accentRgb}, 0.85); border: 1px solid rgba(${accentRgb}, 0.2);`}
                        >✦ {feature}</span>
                      ))}
                    </div>
                    <a
                      href={`/services/${firstService.slug}`}
                      class="text-sm font-medium inline-flex items-center gap-1 transition-opacity hover:opacity-70"
                      style={`color: rgba(${accentRgb}, 0.9);`}
                    >Explore {firstService.title} <span aria-hidden="true">&rarr;</span></a>
                  </div>
                </div>
              </div>
            </div>
          )
        }

        // ── PANEL FORMAT ──────────────────────────────────────
        if (section.format === 'panel') {
          return (
            <div class="walkthrough-panel opacity-0 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">

              {/* Problem + solution (always first in DOM for mobile) */}
              <div class:list={['problem-block flex flex-col justify-center', !isEven && 'lg:order-2']}>
                <span
                  class="font-display text-xs tracking-[0.3em] mb-5 block"
                  style={`color: rgba(${accentRgb}, 0.5);`}
                >
                  {sectionNum} — THE CHALLENGE
                </span>
                <h2
                  class="font-display text-2xl sm:text-3xl lg:text-4xl leading-tight mb-5"
                  style="color: var(--color-text-primary);"
                >
                  {section.problem.headline}
                </h2>
                <p class="text-base leading-relaxed mb-6" style="color: var(--color-text-muted);">
                  {section.problem.description}
                </p>
                <ul class="space-y-2 mb-8" role="list">
                  {section.problem.painPoints.map((point) => (
                    <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
                      <span class="shrink-0 mt-0.5 font-medium" style={`color: rgba(${accentRgb}, 0.65);`} aria-hidden="true">→</span>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
                {/* Inline solution card */}
                <div
                  class="glass card-hover rounded-2xl p-5 lg:p-6"
                  style={`border-color: rgba(${accentRgb}, 0.25);`}
                >
                  <div class="flex items-center gap-3 mb-4">
                    <div
                      class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0"
                      style={`background: rgba(${accentRgb}, 0.12); border: 1px solid rgba(${accentRgb}, 0.2);`}
                      aria-hidden="true"
                    >
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke={`rgba(${accentRgb}, 0.9)`} stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                      ><Fragment set:html={firstService.icon} /></svg>
                    </div>
                    <h3 class="font-display text-sm leading-snug" style="color: var(--color-text-primary);">{firstService.title}</h3>
                  </div>
                  <p class="font-display text-xs tracking-[0.2em] mb-2" style={`color: rgba(${accentRgb}, 0.7);`}>OUR SOLUTION</p>
                  <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">{firstService.solutionTagline}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {firstService.features.map((feature) => (
                      <span class="text-xs px-2.5 py-0.5 rounded-full"
                        style={`background: rgba(${accentRgb}, 0.1); color: rgba(${accentRgb}, 0.85); border: 1px solid rgba(${accentRgb}, 0.2);`}
                      >✦ {feature}</span>
                    ))}
                  </div>
                  <a
                    href={`/services/${firstService.slug}`}
                    class="text-xs font-medium inline-flex items-center gap-1 transition-opacity hover:opacity-70"
                    style={`color: rgba(${accentRgb}, 0.9);`}
                  >Explore {firstService.title} <span aria-hidden="true">&rarr;</span></a>
                </div>
              </div>

              {/* Image panel */}
              <div class:list={['image-panel relative', !isEven && 'lg:order-1']}>
                <div class="relative rounded-2xl overflow-hidden h-64 lg:h-full" style="min-height: 380px;">
                  <img
                    src={firstService.image}
                    alt=""
                    aria-hidden="true"
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                    width="1200" height="800"
                  />
                  {/* Bottom gradient to fade into section bg */}
                  <div
                    class="absolute inset-0"
                    style="background: linear-gradient(to bottom, rgba(2,0,10,0.1) 40%, rgba(2,0,10,0.55) 100%);"
                    aria-hidden="true"
                  ></div>
                  {/* Accent glow overlay */}
                  <div
                    class="absolute inset-0 pointer-events-none"
                    style={`background: radial-gradient(ellipse at 30% 70%, rgba(${accentRgb}, 0.12) 0%, transparent 65%);`}
                    aria-hidden="true"
                  ></div>
                  {/* Service badge at bottom of image */}
                  <div class="absolute bottom-4 left-4 flex items-center gap-2">
                    <div
                      class="w-8 h-8 rounded-lg flex items-center justify-center"
                      style={`background: rgba(${accentRgb}, 0.2); border: 1px solid rgba(${accentRgb}, 0.35); backdrop-filter: blur(8px);`}
                      aria-hidden="true"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke={`rgba(${accentRgb}, 1)`} stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                      ><Fragment set:html={firstService.icon} /></svg>
                    </div>
                    <span
                      class="font-display text-xs tracking-wide px-3 py-1 rounded-full"
                      style={`background: rgba(2,0,10,0.55); color: rgba(${accentRgb}, 0.9); backdrop-filter: blur(8px); border: 1px solid rgba(${accentRgb}, 0.2);`}
                    >{firstService.title}</span>
                  </div>
                </div>
              </div>

            </div>
          )
        }

        // ── BUNDLE FORMAT ─────────────────────────────────────
        return (
          <div class="walkthrough-bundle opacity-0">
            {/* Problem header */}
            <div class="bundle-header mb-8 lg:mb-10 max-w-3xl">
              <span
                class="font-display text-xs tracking-[0.3em] mb-5 block"
                style={`color: rgba(${accentRgb}, 0.5);`}
              >
                {sectionNum} — THE CHALLENGE
              </span>
              <h2
                class="font-display text-2xl sm:text-3xl lg:text-4xl leading-tight mb-5"
                style="color: var(--color-text-primary);"
              >
                {section.problem.headline}
              </h2>
              <p class="text-base leading-relaxed mb-5" style="color: var(--color-text-muted);">
                {section.problem.description}
              </p>
              <ul class="space-y-2" role="list">
                {section.problem.painPoints.map((point) => (
                  <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
                    <span class="shrink-0 mt-0.5 font-medium" style={`color: rgba(${accentRgb}, 0.65);`} aria-hidden="true">→</span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Service cards with image thumbnails */}
            <div class:list={[
              'grid gap-5',
              section.services.length === 2 && 'grid-cols-1 md:grid-cols-2',
              section.services.length === 3 && 'grid-cols-1 md:grid-cols-3',
              section.services.length >= 4 && 'grid-cols-1 md:grid-cols-2',
            ]}>
              {section.services.map((service) => (
                <div
                  class="bundle-card opacity-0 glass card-hover rounded-2xl overflow-hidden flex flex-col"
                  style={`border-color: rgba(${accentRgb}, 0.2);`}
                >
                  {/* Image thumbnail header */}
                  <div class="relative h-40 overflow-hidden shrink-0">
                    <img
                      src={service.image}
                      alt=""
                      aria-hidden="true"
                      class="w-full h-full object-cover"
                      loading="lazy"
                      width="600" height="400"
                    />
                    <div
                      class="absolute inset-0"
                      style="background: linear-gradient(to bottom, rgba(2,0,10,0.15) 0%, rgba(2,0,10,0.7) 100%);"
                      aria-hidden="true"
                    ></div>
                    <div
                      class="absolute inset-0 pointer-events-none"
                      style={`background: radial-gradient(ellipse at 50% 100%, rgba(${accentRgb}, 0.1) 0%, transparent 65%);`}
                      aria-hidden="true"
                    ></div>
                    {/* Service icon + name overlay */}
                    <div class="absolute bottom-3 left-4 flex items-center gap-2">
                      <div
                        class="w-7 h-7 rounded-md flex items-center justify-center shrink-0"
                        style={`background: rgba(${accentRgb}, 0.2); border: 1px solid rgba(${accentRgb}, 0.3); backdrop-filter: blur(6px);`}
                        aria-hidden="true"
                      >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                          stroke={`rgba(${accentRgb}, 1)`} stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                        ><Fragment set:html={service.icon} /></svg>
                      </div>
                      <h3 class="font-display text-xs leading-snug" style="color: var(--color-text-primary);">{service.title}</h3>
                    </div>
                  </div>

                  {/* Solution content */}
                  <div class="p-5 flex flex-col flex-1">
                    <p class="font-display text-xs tracking-[0.2em] mb-2" style={`color: rgba(${accentRgb}, 0.7);`}>OUR SOLUTION</p>
                    <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--color-text-muted);">{service.solutionTagline}</p>
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {service.features.map((feature) => (
                        <span class="text-xs px-2.5 py-0.5 rounded-full"
                          style={`background: rgba(${accentRgb}, 0.08); color: rgba(${accentRgb}, 0.8); border: 1px solid rgba(${accentRgb}, 0.18);`}
                        >✦ {feature}</span>
                      ))}
                    </div>
                    <a
                      href={`/services/${service.slug}`}
                      class="text-xs font-medium inline-flex items-center gap-1 transition-opacity hover:opacity-70 mt-auto"
                      style={`color: rgba(${accentRgb}, 0.9);`}
                    >Explore <span aria-hidden="true">&rarr;</span></a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      })}
    </div>

  </div>
</section>

<script>
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

let triggers: ScrollTrigger[] = []

function initWalkthrough() {
  triggers.forEach(t => t.kill())
  triggers = []

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>(
      '.pain-intro-section, .pain-intro-card, .walkthrough-cinematic, .walkthrough-panel, .walkthrough-bundle, .bundle-card'
    ).forEach(el => { el.style.opacity = '1' })
    return
  }

  // Pain intro
  const introSection = document.querySelector<HTMLElement>('.pain-intro-section')
  if (introSection) {
    const cards = introSection.querySelectorAll<HTMLElement>('.pain-intro-card')
    gsap.set(cards, { y: 24 })
    triggers.push(ScrollTrigger.create({
      trigger: introSection,
      start: 'top 82%',
      once: true,
      onEnter: () => {
        gsap.to(introSection, { opacity: 1, duration: 0.4 })
        gsap.to(cards, { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out' })
      },
    }))
  }

  // Cinematic sections
  document.querySelectorAll<HTMLElement>('.walkthrough-cinematic').forEach(section => {
    const problem = section.querySelector<HTMLElement>('.problem-block')
    const solution = section.querySelector<HTMLElement>('.solution-block')
    const img = section.querySelector<HTMLImageElement>('img')
    if (problem) gsap.set(problem, { x: -40 })
    if (solution) gsap.set(solution, { x: 40 })
    if (img) gsap.set(img, { scale: 1.06 })
    triggers.push(ScrollTrigger.create({
      trigger: section,
      start: 'top 78%',
      once: true,
      onEnter: () => {
        gsap.to(section, { opacity: 1, duration: 0.15 })
        if (problem) gsap.to(problem, { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out' })
        if (solution) gsap.to(solution, { opacity: 1, x: 0, duration: 0.7, delay: 0.15, ease: 'power2.out' })
        if (img) gsap.to(img, { scale: 1, duration: 1.2, ease: 'power2.out' })
      },
    }))
  })

  // Panel sections
  document.querySelectorAll<HTMLElement>('.walkthrough-panel').forEach((section, i) => {
    const isEven = i % 2 === 0
    const problem = section.querySelector<HTMLElement>('.problem-block')
    const panel = section.querySelector<HTMLElement>('.image-panel')
    if (problem) gsap.set(problem, { x: isEven ? -35 : 35 })
    if (panel) gsap.set(panel, { opacity: 0, y: 20 })
    triggers.push(ScrollTrigger.create({
      trigger: section,
      start: 'top 78%',
      once: true,
      onEnter: () => {
        gsap.to(section, { opacity: 1, duration: 0.15 })
        if (problem) gsap.to(problem, { opacity: 1, x: 0, duration: 0.65, ease: 'power2.out' })
        if (panel) gsap.to(panel, { opacity: 1, y: 0, duration: 0.65, delay: 0.15, ease: 'power2.out' })
      },
    }))
  })

  // Bundle sections
  document.querySelectorAll<HTMLElement>('.walkthrough-bundle').forEach(section => {
    const header = section.querySelector<HTMLElement>('.bundle-header')
    const cards = section.querySelectorAll<HTMLElement>('.bundle-card')
    if (header) gsap.set(header, { y: -20 })
    triggers.push(ScrollTrigger.create({
      trigger: section,
      start: 'top 78%',
      once: true,
      onEnter: () => {
        gsap.to(section, { opacity: 1, duration: 0.15 })
        if (header) gsap.to(header, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' })
        gsap.to(cards, { opacity: 1, y: 0, duration: 0.55, stagger: 0.1, delay: 0.2, ease: 'power2.out' })
      },
    }))
    // Pre-set bundle cards position
    gsap.set(cards, { y: 30 })
  })
}

document.addEventListener('astro:before-swap', () => {
  triggers.forEach(t => t.kill())
  triggers = []
  ScrollTrigger.getAll().forEach(t => t.kill())
})
document.addEventListener('astro:page-load', initWalkthrough)
</script>
