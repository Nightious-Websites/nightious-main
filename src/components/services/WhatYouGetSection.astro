---
import { accentPronouns } from '@/utils/text'

interface Outcome {
  icon: string
  title: string
  description: string
}

interface Props {
  data: {
    banner: {
      label: string
      headline: string
      description: string
    }
    outcomes: Outcome[]
  }
  accentRgb: string
}

const { data, accentRgb } = Astro.props
---

<section
  id="what-you-get"
  class="csec reveal-section"
  aria-labelledby="what-you-get-heading"
  data-editorial
>
  <div class="section-body">
    <!-- Left: statement card -->
    <div class="out-banner">
      <div class="ob-glow" role="presentation" aria-hidden="true"></div>
      <div class="ob-content">
        <h2 class="ob-label" id="what-you-get-heading">{data.banner.label}</h2>
        <h3 class="ob-headline" set:html={accentPronouns(data.banner.headline)}></h3>
        <p class="ob-desc" set:html={data.banner.description}></p>
      </div>
    </div>

    <!-- Right: outcome grid -->
    <ul class="outcome-grid" role="list">
      {data.outcomes.map((outcome, i) => (
        <li class="outcome-card">
          <span class="out-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <span class="out-icon" aria-hidden="true">{outcome.icon}</span>
          <h3 class="out-title">{outcome.title}</h3>
          <p class="out-desc">{outcome.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section-body {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 1rem;
    align-items: stretch;
  }

  /* Statement card — stretches to match outcome grid height */
  .out-banner {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid rgba(var(--svc-accent), 0.22);
    border-top: 1px solid rgba(var(--svc-accent), 0.40);
    background: linear-gradient(135deg, rgba(var(--svc-accent), 0.08) 0%, rgba(5, 0, 15, 0.50) 65%);
    display: flex;
    flex-direction: column;
  }

  .out-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(var(--svc-accent), 0.80), transparent 60%);
    z-index: 1;
  }

  .ob-glow {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 160px;
    height: 120px;
    background: radial-gradient(ellipse at 100% 100%, rgba(var(--svc-accent), 0.14), transparent 70%);
    pointer-events: none;
  }

  .ob-content {
    position: relative;
    z-index: 1;
    flex: 1;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .ob-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: rgba(var(--svc-accent), 0.70);
    margin: 0 0 0.65rem;
  }

  .ob-headline {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-text-primary);
    line-height: 1.28;
    margin: 0 0 0.85rem;
    letter-spacing: -0.01em;
  }

  .ob-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Outcome grid */
  .outcome-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .outcome-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 12px;
    padding: 1.35rem 1.4rem 1.25rem;
    position: relative;
    overflow: hidden;
    transition: all 0.25s ease;
    cursor: default;
  }

  .outcome-card:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--svc-accent), 0.30);
    background: rgba(var(--svc-accent), 0.06);
  }

  .outcome-card:hover .out-num {
    color: rgba(var(--svc-accent), 0.13);
  }

  .out-num {
    position: absolute;
    top: -0.1rem;
    right: 0.6rem;
    font-size: 4.5rem;
    font-weight: 900;
    color: rgba(var(--svc-accent), 0.08);
    letter-spacing: -0.04em;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    transition: color 0.25s ease;
  }

  .out-icon {
    font-size: 1.2rem;
    display: block;
    margin-bottom: 0.55rem;
    position: relative;
    z-index: 1;
  }

  .out-title {
    font-size: 0.90rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.35rem;
    position: relative;
    z-index: 1;
  }

  .out-desc {
    font-size: 0.80rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 900px) {
    .section-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .outcome-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  .ob-desc strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }
</style>
