---
// Intercom live chat messenger — initialized client-side on every page.
// Calls Intercom('update') on each ViewTransition so page tracking stays accurate.
---

<script>
  import Intercom from '@intercom/messenger-js-sdk'

  Intercom({ app_id: 'qe0d8g4s' })

  // Keep Intercom in sync with Astro's SPA page transitions
  document.addEventListener('astro:page-load', () => {
    if (typeof window.Intercom === 'function') {
      window.Intercom('update')
    }
  })
</script>
