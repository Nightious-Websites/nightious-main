---
import { Image } from 'astro:assets'
import logoWhite from '@/assets/images/logos/logo-white.png'
import iconWhite from '@/assets/images/logos/icon-white.png'
import logoTextWhite from '@/assets/images/logos/logo-text-white.png'

const pathname = Astro.url.pathname

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname === href || pathname.startsWith(href + '/')
}

const services = [
  { slug: 'website-solutions',          title: 'Website Solutions',           icon: '🌐' },
  { slug: 'email-solutions',            title: 'Email Solutions',             icon: '✉️' },
  { slug: 'domain-solutions',           title: 'Domain Solutions',            icon: '🔗' },
  { slug: 'ai-integration',             title: 'AI Integration',              icon: '🤖' },
  { slug: 'digital-marketing',          title: 'Digital Marketing',           icon: '📈' },
  { slug: 'computer-services',          title: 'Computer Services',           icon: '💻' },
  { slug: 'streaming-consultation',     title: 'Streaming Consultation',      icon: '🎙️' },
  { slug: 'online-privacy',             title: 'Online Privacy',              icon: '🔒' },
  { slug: 'organizational-effectiveness', title: 'Organizational Effectiveness', icon: '⚙️' },
  { slug: 'software-services',          title: 'Software Services',           icon: '🖥️' },
  { slug: 'custom-services',            title: 'Custom Services',             icon: '✨' },
  { slug: 'training-documentation',     title: 'Training & Documentation',    icon: '📚' },
]

const bundleLinks = [
  { href: '/for-businesses', label: 'Businesses', rgb: '59, 130, 246', color: '#93c5fd' },
  { href: '/for-creators', label: 'Creators', rgb: '236, 72, 153', color: '#f9a8d4' },
  { href: '/for-individuals', label: 'Individuals', rgb: '34, 197, 94', color: '#86efac' },
]
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between"
    aria-label="Main"
  >
    <!-- Logo -->
    <a href="/" aria-label="Nightious — Home" class="flex-shrink-0">
      <Image
        src={logoWhite}
        alt="Nightious"
        width={160}
        height={40}
        class="h-8 w-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href="/"
        aria-current={isActive('/') ? 'page' : undefined}
        class="nav-link text-sm font-semibold tracking-wide transition-colors"
        style="color: var(--color-text-muted); font-family: 'Exo 2', sans-serif;"
      >
        Home
      </a>

      {bundleLinks.map(b => (
        <a
          href={b.href}
          aria-current={isActive(b.href) ? 'page' : undefined}
          class="nav-link text-xs font-semibold tracking-wide transition-colors px-3 py-1.5 rounded-md"
          style={isActive(b.href)
            ? `background: rgba(${b.rgb}, 0.2); border: 1px solid rgba(${b.rgb}, 0.3); color: ${b.color}; font-family: 'Exo 2', sans-serif;`
            : `background: rgba(${b.rgb}, 0.1); color: ${b.color}; font-family: 'Exo 2', sans-serif;`
          }
        >
          {b.label}
        </a>
      ))}

      <!-- Services with dropdown -->
      <div class="services-nav relative" id="services-nav">
        <a
          href="/services"
          aria-current={isActive('/services') ? 'page' : undefined}
          aria-haspopup="menu"
          aria-expanded="false"
          id="services-nav-btn"
          class="nav-link text-sm font-semibold tracking-wide transition-colors flex items-center gap-1"
          style="color: var(--color-text-muted); font-family: 'Exo 2', sans-serif;"
        >
          Services
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="services-chevron transition-transform duration-200">
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <!-- Mega dropdown -->
        <div
          id="services-dropdown"
          role="region"
          aria-label="Services menu"
          class="services-dropdown absolute top-full left-1/2 -translate-x-1/2 mt-3 w-[680px] glass p-5 opacity-0 pointer-events-none transition-all duration-200 translate-y-1"
          style="border-radius: 16px;"
        >
          <!-- Arrow -->
          <div
            class="absolute -top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 rotate-45"
            style="background: rgba(255,255,255,0.05); border-top: 1px solid rgba(255,255,255,0.10); border-left: 1px solid rgba(255,255,255,0.10);"
            aria-hidden="true"
          ></div>

          <div class="grid grid-cols-3 gap-1">
            {services.map(s => (
              <a
                href={`/services/${s.slug}`}
                class="dropdown-item flex items-center gap-2.5 px-3 py-2.5 rounded-lg transition-colors text-sm"
                style="color: var(--color-text-muted); font-family: 'Exo 2', sans-serif;"
              >
                <span class="text-base flex-shrink-0" aria-hidden="true">{s.icon}</span>
                <span class="font-medium">{s.title}</span>
              </a>
            ))}
          </div>

          <div class="mt-3 pt-3 border-t" style="border-color: rgba(168, 85, 247, 0.15);">
            <a
              href="/services"
              class="flex items-center justify-center gap-2 py-2 text-xs font-semibold tracking-wide transition-colors"
              style="color: var(--color-purple-mid); font-family: 'Exo 2', sans-serif;"
            >
              View all 12 services →
            </a>
          </div>
        </div>
      </div>

      <a
        href="/contact"
        aria-current={isActive('/contact') ? 'page' : undefined}
        class="nav-link text-sm font-semibold tracking-wide transition-colors"
        style="color: var(--color-text-muted); font-family: 'Exo 2', sans-serif;"
      >
        Contact
      </a>
      <a href="/contact" class="btn-primary text-sm">
        Get a Free Quote →
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5 rounded-md"
    >
      <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
      <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
      <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
    </button>
  </nav>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-40 md:hidden pointer-events-none"
>
  <div
    id="drawer-overlay"
    class="absolute inset-0 opacity-0 transition-opacity duration-300"
    style="background: rgba(2, 0, 10, 0.7);"
  ></div>

  <div
    id="drawer-panel"
    class="absolute top-0 right-0 bottom-0 w-80 glass flex flex-col overflow-y-auto translate-x-full transition-transform duration-300"
    style="border-radius: 0; border-right: none;"
  >
    <div class="flex items-center justify-between px-6 py-5 border-b" style="border-color: rgba(168, 85, 247, 0.15);">
      <div class="flex items-center gap-2">
        <Image src={iconWhite} alt="" width={28} height={28} class="h-7 w-7 object-contain" aria-hidden="true" />
        <Image src={logoTextWhite} alt="Nightious" width={110} height={26} class="h-6 w-auto object-contain" />
      </div>
      <button
        id="drawer-close"
        aria-label="Close navigation menu"
        class="flex items-center justify-center w-11 h-11 rounded-md"
        style="color: var(--color-text-muted);"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="flex flex-col px-4 py-4 gap-1 flex-1">
      <a
        href="/"
        aria-current={isActive('/') ? 'page' : undefined}
        class="drawer-link py-3 px-3 rounded-lg text-sm font-semibold transition-colors"
        style="color: var(--color-text-primary); font-family: 'Exo 2', sans-serif;"
      >
        Home
      </a>

      <!-- Bundle links (mobile) -->
      <div class="flex flex-col gap-1 py-2">
        {bundleLinks.map(b => (
          <a
            href={b.href}
            aria-current={isActive(b.href) ? 'page' : undefined}
            class="drawer-link py-2.5 px-3 rounded-lg text-sm font-semibold transition-colors"
            style={`color: ${b.color}; font-family: 'Exo 2', sans-serif; border-left: 2px solid rgba(${b.rgb}, 0.5); padding-left: 12px;`}
          >
            For {b.label}
          </a>
        ))}
      </div>

      <!-- Services accordion in mobile -->
      <div>
        <button
          id="mobile-services-toggle"
          type="button"
          aria-expanded="false"
          class="w-full flex items-center justify-between py-3 px-3 rounded-lg text-sm font-semibold transition-colors"
          style="color: var(--color-text-primary); font-family: 'Exo 2', sans-serif;"
        >
          <span>Services</span>
          <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="mobile-chevron transition-transform duration-200" style="color: var(--color-purple-mid);">
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div id="mobile-services-list" class="hidden pl-4 pt-1 pb-2 flex flex-col gap-0.5">
          {services.map(s => (
            <a
              href={`/services/${s.slug}`}
              class="drawer-link flex items-center gap-2 py-2 px-3 rounded-lg text-sm transition-colors"
              style="color: var(--color-text-muted); font-family: 'Exo 2', sans-serif;"
            >
              <span class="text-sm" aria-hidden="true">{s.icon}</span>
              {s.title}
            </a>
          ))}
          <a
            href="/services"
            class="py-2 px-3 text-xs font-semibold"
            style="color: var(--color-purple-mid); font-family: 'Exo 2', sans-serif;"
          >
            View all services →
          </a>
        </div>
      </div>

      <a
        href="/contact"
        aria-current={isActive('/contact') ? 'page' : undefined}
        class="drawer-link py-3 px-3 rounded-lg text-sm font-semibold transition-colors"
        style="color: var(--color-text-primary); font-family: 'Exo 2', sans-serif;"
      >
        Contact
      </a>
    </nav>

    <div class="px-6 py-5 border-t" style="border-color: rgba(168, 85, 247, 0.15);">
      <a href="/contact" class="btn-primary text-sm w-full justify-center">
        Get a Free Quote →
      </a>
    </div>
  </div>
</div>

<style>
  .nav-link[aria-current="page"],
  .drawer-link[aria-current="page"] {
    color: var(--color-purple-light) !important;
    text-decoration: underline;
    text-decoration-color: var(--color-purple-mid);
    text-underline-offset: 4px;
  }

  .nav-link:hover,
  .drawer-link:hover {
    color: var(--color-purple-light) !important;
  }

  .dropdown-item:hover {
    background: rgba(168, 85, 247, 0.1);
    color: var(--color-purple-light) !important;
  }

  /* Desktop dropdown — shown via JS-managed .is-open class */
  .services-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  #services-nav-btn.chevron-open .services-chevron {
    transform: rotate(180deg);
  }

  /* Override .glass background with an opaque dark base so the dropdown
     remains readable whether the navbar is transparent (top of page) or
     has its own backdrop-filter applied (scrolled state). Without this,
     the dropdown's blur samples the navbar's already-dark composited
     surface and visually disappears. */
  #services-dropdown {
    background: rgba(8, 0, 22, 0.92);
  }

  #mobile-drawer.is-open {
    pointer-events: auto;
  }

  #mobile-drawer.is-open #drawer-overlay {
    opacity: 1;
  }

  #mobile-drawer.is-open #drawer-panel {
    transform: translateX(0);
  }

  .mobile-chevron.open {
    transform: rotate(180deg);
  }
</style>

<script>
  function initNav() {
    const navbar = document.getElementById('navbar')
    const hamburger = document.getElementById('nav-hamburger')
    const drawer = document.getElementById('mobile-drawer')
    const drawerClose = document.getElementById('drawer-close')
    const overlay = document.getElementById('drawer-overlay')
    const drawerLinks = document.querySelectorAll<HTMLAnchorElement>('.drawer-link')
    const mobileServicesToggle = document.getElementById('mobile-services-toggle')
    const mobileServicesList = document.getElementById('mobile-services-list')

    // Scroll behaviour
    function onScroll() {
      if (!navbar) return
      navbar.classList.toggle('scrolled', window.scrollY > 80)
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()

    // Mobile drawer
    function openDrawer() {
      if (!drawer || !hamburger) return
      drawer.classList.add('is-open')
      hamburger.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'
      drawerClose?.focus()
    }

    function closeDrawer() {
      if (!drawer || !hamburger) return
      drawer.classList.remove('is-open')
      hamburger.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
      hamburger.focus()
    }

    hamburger?.addEventListener('click', openDrawer)
    drawerClose?.addEventListener('click', closeDrawer)
    overlay?.addEventListener('click', closeDrawer)
    drawerLinks.forEach(link => link.addEventListener('click', closeDrawer))

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeDrawer()
    })

    // Desktop dropdown with hover-gap-safe close delay
    const servicesNav = document.getElementById('services-nav')
    const servicesDropdown = document.getElementById('services-dropdown')
    const servicesNavBtn = document.getElementById('services-nav-btn')
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    function openDropdown() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null }
      servicesDropdown?.classList.add('is-open')
      servicesNavBtn?.classList.add('chevron-open')
      servicesNavBtn?.setAttribute('aria-expanded', 'true')
    }

    function scheduleClose() {
      closeTimer = setTimeout(() => {
        servicesDropdown?.classList.remove('is-open')
        servicesNavBtn?.classList.remove('chevron-open')
        servicesNavBtn?.setAttribute('aria-expanded', 'false')
      }, 150)
    }

    servicesNav?.addEventListener('mouseenter', openDropdown)
    servicesNav?.addEventListener('mouseleave', scheduleClose)
    servicesDropdown?.addEventListener('mouseenter', openDropdown)
    servicesDropdown?.addEventListener('mouseleave', scheduleClose)

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        servicesDropdown?.classList.remove('is-open')
        servicesNavBtn?.classList.remove('chevron-open')
        servicesNavBtn?.setAttribute('aria-expanded', 'false')
        servicesNavBtn?.focus()
      }
    })

    // Mobile services accordion
    mobileServicesToggle?.addEventListener('click', () => {
      const expanded = mobileServicesToggle.getAttribute('aria-expanded') === 'true'
      mobileServicesToggle.setAttribute('aria-expanded', String(!expanded))
      mobileServicesList?.classList.toggle('hidden')
      mobileServicesToggle.querySelector('.mobile-chevron')?.classList.toggle('open')
    })
  }

  document.addEventListener('astro:page-load', initNav)
</script>
