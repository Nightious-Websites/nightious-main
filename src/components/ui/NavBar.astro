---
import { Image } from 'astro:assets'
import logoWhite from '@/assets/images/logos/logo-white.png'
import iconWhite from '@/assets/images/logos/icon-white.png'
import logoTextWhite from '@/assets/images/logos/logo-text-white.png'

const pathname = Astro.url.pathname

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname === href || pathname.startsWith(href + '/')
}

/* Grid visual order:
   Row 1: Website (purple)  | AI (purple)       | Digital Marketing (pink)
   Row 2: Computer (blue)   | Email (blue)       | Domain (blue)
   Row 3: Software (purple) | Privacy (purple)   | Streaming (pink)
   Row 4: Org Eff (purple)  | Training (purple)  | Custom (pink)         */
const services = [
  { slug: 'website-solutions',            title: 'Website Solutions', icon: '🌐', color: 'purple', tagline: 'Fast sites built to convert.'      },
  { slug: 'ai-integration',               title: 'AI Integration',    icon: '🤖', color: 'purple', tagline: 'Automate with custom AI.'           },
  { slug: 'digital-marketing',            title: 'Digital Marketing', icon: '📈', color: 'pink',   tagline: 'Grow your audience online.'         },
  { slug: 'computer-services',            title: 'Computer Services', icon: '💻', color: 'blue',   tagline: 'Setup, repair, and optimize.'       },
  { slug: 'email-solutions',              title: 'Email Solutions',   icon: '✉️', color: 'blue',   tagline: 'Pro email on your domain.'          },
  { slug: 'domain-solutions',             title: 'Domain Solutions',  icon: '🔗', color: 'blue',   tagline: 'The right domain, set up right.'    },
  { slug: 'software-services',            title: 'Software Services', icon: '🖥️', color: 'purple', tagline: 'Custom scripts & integrations.'     },
  { slug: 'online-privacy',               title: 'Online Privacy',    icon: '🔒', color: 'purple', tagline: 'VPNs, 2FA, digital hygiene.'        },
  { slug: 'streaming-consultation',       title: 'Streaming',         icon: '🎙️', color: 'pink',   tagline: 'Go live like a pro.'                },
  { slug: 'organizational-effectiveness', title: 'Org Effectiveness', icon: '⚙️', color: 'purple', tagline: 'Right tools, better workflows.'      },
  { slug: 'training-documentation',       title: 'Training & Docs',   icon: '📚', color: 'purple', tagline: 'Make your team self-sufficient.'     },
  { slug: 'custom-services',              title: 'Custom Services',   icon: '✨', color: 'pink',   tagline: 'Bespoke solutions for you.'          },
]

const navLinks = [
  { href: '/',                label: 'Home'        },
  { href: '/for-businesses',  label: 'Businesses'  },
  { href: '/for-individuals', label: 'Individuals' },
  { href: '/for-creators',    label: 'Creators'    },
  { href: '/blog',            label: 'Blog'        },
]
---

<!-- ─── Header bar ─────────────────────────────────────────────────────────── -->
<header id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center"
    aria-label="Main"
  >

    <!-- ① Logo (left) — flex-1 balances the right column so center stays centered -->
    <div class="flex-1 flex items-center">
    <a href="/" aria-label="Nightious — Home" class="flex-shrink-0">
      <Image
        src={logoWhite}
        alt="Nightious"
        width={160}
        height={40}
        class="h-8 w-auto object-contain"
        loading="eager"
      />
    </a>
    </div>

    <!-- ② Center nav links — flex-1 flanks keep this naturally centered at any width -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="nav-link text-sm font-semibold tracking-wide transition-colors"
          style="color: var(--color-text-muted);"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- ③ Right actions (desktop: Services + Contact | mobile: hamburger) -->
    <!-- relative here anchors the dropdown to the full right-column width -->
    <div class="flex-1 flex items-center justify-end gap-3 relative">

      <!-- Services dropdown trigger — desktop only -->
      <div class="hidden md:block" id="services-nav">
        <button
          type="button"
          id="services-nav-btn"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="services-dropdown"
          class="nav-link text-sm font-semibold tracking-wide transition-colors flex items-center gap-1 cursor-pointer"
          style="color: var(--color-text-muted);"
        >
          Services
          <svg
            width="12" height="12" viewBox="0 0 12 12" fill="none"
            aria-hidden="true"
            class="services-chevron transition-transform duration-200"
          >
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- ── Mega-panel: outside trigger wrapper, anchored to right-column ── -->
      <!-- right-0 aligns dropdown's right edge with Contact button's right edge -->
      <div
        id="services-dropdown"
        aria-label="Services"
        class="services-mega hidden md:block absolute top-full right-0 mt-4"
      >
          <!-- Panel header -->
          <div class="flex items-center justify-between mb-4">
            <span class="font-display text-[10px] tracking-[0.25em] uppercase" style="color: var(--color-purple-mid);">Services</span>
            <a
              href="/services"
              class="text-[11px] font-semibold transition-colors"
              style="color: var(--color-text-muted);"
              tabindex="-1"
            >12 solutions →</a>
          </div>

          <!-- 3-column service grid -->
          <div class="grid grid-cols-3 gap-1">
            {services.map(s => (
              <a
                href={`/services/${s.slug}`}
                class="svc-card flex items-center gap-2.5 px-3 py-2.5 rounded-[10px]"
                data-color={s.color}
              >
                <div
                  class="svc-icon-pill flex-shrink-0 flex items-center justify-center rounded-[8px] text-lg"
                  data-color={s.color}
                  aria-hidden="true"
                >{s.icon}</div>
                <div class="flex flex-col min-w-0">
                  <span class="svc-title font-semibold leading-tight truncate">{s.title}</span>
                  <span class="svc-tagline leading-snug">{s.tagline}</span>
                </div>
              </a>
            ))}
          </div>

          <!-- Footer CTA -->
          <div class="neon-divider mt-4 mb-3"></div>
          <a
            href="/services"
            class="flex items-center justify-center gap-1.5 py-1 text-xs font-semibold tracking-wide gradient-text font-display transition-opacity hover:opacity-75"
          >
            Browse all 12 services →
          </a>
        </div>

      <!-- Contact CTA — glow-breathe animation, desktop only -->
      <a
        href="/contact"
        aria-current={isActive('/contact') ? 'page' : undefined}
        class="btn-contact hidden md:inline-flex items-center gap-1.5 text-sm font-semibold tracking-wide px-4 py-2 rounded-lg whitespace-nowrap"
      >
        Contact Us →
      </a>

      <!-- Mobile hamburger -->
      <button
        id="nav-hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-overlay"
        class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5 rounded-md"
      >
        <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
        <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
        <span class="hamburger-line block w-6 h-0.5 rounded-full transition-all duration-300" style="background: var(--color-purple-light);"></span>
      </button>
    </div>

  </nav>
</header>

<!-- ─── Mobile full-screen overlay ───────────────────────────────────────────── -->
<div
  id="mobile-overlay"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  aria-hidden="true"
  class="fixed inset-0 z-[60] md:hidden flex flex-col"
  style="background: rgba(2, 0, 10, 0.97); backdrop-filter: blur(32px); -webkit-backdrop-filter: blur(32px);"
>
  <!-- Top bar with logo + close -->
  <div class="flex items-center justify-between px-6 py-5 flex-shrink-0 border-b" style="border-color: rgba(168, 85, 247, 0.12);">
    <div class="flex items-center gap-2">
      <Image src={iconWhite} alt="" width={28} height={28} class="h-7 w-7 object-contain" aria-hidden="true" />
      <Image src={logoTextWhite} alt="Nightious" width={110} height={26} class="h-6 w-auto object-contain" />
    </div>
    <button
      id="overlay-close"
      aria-label="Close navigation menu"
      class="flex items-center justify-center w-11 h-11 rounded-md"
      style="color: var(--color-text-muted);"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Centred nav items — GSAP animates these on open -->
  <nav
    id="mobile-nav-links"
    class="flex flex-col items-center justify-center flex-1 gap-1 overflow-y-auto py-6"
    aria-label="Mobile navigation"
  >
    <!-- Primary links -->
    {navLinks.map(link => (
      <a
        href={link.href}
        aria-current={isActive(link.href) ? 'page' : undefined}
        class="mobile-link py-3 px-8 text-2xl font-semibold tracking-wide transition-colors text-center"
        style="color: var(--color-text-primary);"
      >
        {link.label}
      </a>
    ))}

    <!-- Services accordion -->
    <div class="flex flex-col items-center w-full">
      <button
        id="mobile-services-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-services-list"
        class="mobile-link flex items-center gap-2 py-3 px-8 text-2xl font-semibold tracking-wide transition-colors"
        style="color: var(--color-text-primary);"
      >
        Services
        <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="mobile-services-chevron transition-transform duration-200" style="color: var(--color-purple-mid);">
          <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div id="mobile-services-list" class="hidden w-full gap-0.5 pb-2 px-4">
        {services.map(s => (
          <a
            href={`/services/${s.slug}`}
            class="mobile-link flex items-center gap-3 py-2.5 px-4 rounded-xl transition-colors w-full"
            data-color={s.color}
          >
            <div
              class="svc-icon-pill flex-shrink-0 flex items-center justify-center rounded-[8px] text-base"
              data-color={s.color}
              aria-hidden="true"
            >{s.icon}</div>
            <div class="flex flex-col">
              <span class="text-sm font-semibold" style="color: var(--color-text-primary);">{s.title}</span>
              <span class="svc-tagline">{s.tagline}</span>
            </div>
          </a>
        ))}
        <a
          href="/services"
          class="mobile-link mt-1 py-2 px-4 text-xs font-semibold gradient-text font-display"
        >
          Browse all services →
        </a>
      </div>
    </div>

    <!-- Contact CTA -->
    <a
      href="/contact"
      class="mobile-link mt-6 btn-contact inline-flex items-center gap-1.5 text-base font-semibold tracking-wide px-8 py-3 rounded-xl"
    >
      Contact Us →
    </a>
  </nav>
</div>

<style>
  /* ── Scroll behaviour: transparent → glass ─────────────────────────── */
  #navbar {
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
  }
  #navbar.scrolled {
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 4px 30px rgba(168, 85, 247, 0.08);
  }

  /* ── Desktop nav links ──────────────────────────────────────────────── */
  .nav-link[aria-current="page"] {
    color: var(--color-purple-light) !important;
    text-decoration: underline;
    text-decoration-color: var(--color-purple-mid);
    text-underline-offset: 4px;
  }
  .nav-link:hover {
    color: var(--color-purple-light) !important;
  }

  /* ── Services mega-panel ─────────────────────────────────────────────── */
  .services-mega {
    width: 640px;
    background: rgba(5, 0, 15, 0.97);
    border: 1px solid rgba(168, 85, 247, 0.25);
    border-radius: 18px;
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    box-shadow:
      0 0 80px rgba(168, 85, 247, 0.18),
      inset 0 0 40px rgba(168, 85, 247, 0.04),
      0 0 0 1px rgba(255, 255, 255, 0.05);
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  /* Neon top accent line */
  .services-mega::before {
    content: '';
    position: absolute;
    top: 0;
    left: 12px;
    right: 12px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.8), rgba(232, 121, 249, 0.8), transparent);
  }
  .services-mega.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* ── Service card (desktop + mobile) ─────────────────────────────────── */
  .svc-card {
    border: 1px solid transparent;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .svc-card[data-color="purple"]:hover {
    background: rgba(168, 85, 247, 0.1);
    border-color: rgba(168, 85, 247, 0.2);
    transform: translateY(-1px);
  }
  .svc-card[data-color="pink"]:hover {
    background: rgba(236, 72, 153, 0.1);
    border-color: rgba(236, 72, 153, 0.2);
    transform: translateY(-1px);
  }
  .svc-card[data-color="blue"]:hover {
    background: rgba(96, 165, 250, 0.1);
    border-color: rgba(96, 165, 250, 0.2);
    transform: translateY(-1px);
  }

  /* ── Icon pill: 36×36, color-coded background ─────────────────────────── */
  .svc-icon-pill {
    width: 36px;
    height: 36px;
  }
  .svc-icon-pill[data-color="purple"] { background: rgba(168, 85, 247, 0.18); }
  .svc-icon-pill[data-color="pink"]   { background: rgba(236, 72, 153, 0.18); }
  .svc-icon-pill[data-color="blue"]   { background: rgba(96, 165, 250, 0.18); }

  /* ── Service text ────────────────────────────────────────────────────── */
  .svc-title {
    font-size: 13px;
    color: var(--color-text-primary);
  }
  .svc-tagline {
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.3;
    margin-top: 1px;
  }

  /* Chevron rotates when dropdown is open */
  #services-nav-btn.is-open .services-chevron {
    transform: rotate(180deg);
  }

  /* ── Contact CTA — glow-breathe animation ───────────────────────────── */
  @keyframes glow-breathe {
    0%, 100% {
      box-shadow: 0 0 4px 0px rgba(168, 85, 247, 0.15),
                  0 0 6px 1px rgba(236, 72, 153, 0.08);
    }
    50% {
      box-shadow: 0 0 7px 1px rgba(168, 85, 247, 0.28),
                  0 0 10px 2px rgba(236, 72, 153, 0.14);
    }
  }
  .btn-contact {
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: #ffffff;
    animation: glow-breathe 4s ease-in-out infinite;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .btn-contact:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: reduce) {
    .btn-contact {
      animation: none;
    }
  }

  /* ── Mobile overlay ─────────────────────────────────────────────────── */
  #mobile-overlay {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  #mobile-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile nav links ───────────────────────────────────────────────── */
  .mobile-link[aria-current="page"] {
    color: var(--color-purple-light) !important;
  }
  .mobile-link:hover {
    color: var(--color-purple-light) !important;
  }
  .mobile-services-chevron.open {
    transform: rotate(180deg);
  }
</style>

<script>
  import gsap from 'gsap'

  let navController: AbortController | null = null
  // Module-level so cleanupNav can clear any pending timer before DOM swap
  let closeTimer: ReturnType<typeof setTimeout> | null = null

  function cleanupNav(): void {
    // Clear pending close timer before DOM is torn down
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null }
    // Abort all signal-attached listeners to prevent stale-DOM access
    navController?.abort()
    navController = null
    gsap.killTweensOf('#mobile-nav-links > *')
    gsap.killTweensOf('#services-dropdown .svc-card')
    document.body.style.overflow = ''
  }

  function initNav(): void {
    navController = new AbortController()
    const { signal } = navController

    const navbar           = document.getElementById('navbar')
    const hamburger        = document.getElementById('nav-hamburger')
    const overlay          = document.getElementById('mobile-overlay')
    const overlayClose     = document.getElementById('overlay-close')
    const navLinks         = document.querySelectorAll<HTMLElement>('#mobile-nav-links > *')
    const servicesTgl      = document.getElementById('mobile-services-toggle')
    const servicesList     = document.getElementById('mobile-services-list')
    const servicesNav      = document.getElementById('services-nav')
    const servicesDropdown = document.getElementById('services-dropdown')
    const servicesBtn      = document.getElementById('services-nav-btn')

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // ── Scroll: transparent → glass ─────────────────────────────────────
    const onScroll = () => navbar?.classList.toggle('scrolled', window.scrollY > 80)
    window.addEventListener('scroll', onScroll, { passive: true, signal })
    onScroll()

    // ── Mobile overlay ───────────────────────────────────────────────────
    // Focus trap for mobile overlay
    function trapFocus(e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      const focusableEls = overlay!.querySelectorAll<HTMLElement>(
        'a[href]:not([tabindex="-1"]), button:not([disabled]):not([tabindex="-1"]), [tabindex="0"]'
      );
      if (focusableEls.length === 0) return;
      const first = focusableEls[0];
      const last = focusableEls[focusableEls.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    function openOverlay(): void {
      if (!overlay || !hamburger) return
      overlay.classList.add('is-open')
      overlay.removeAttribute('aria-hidden')
      hamburger.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'

      if (!reducedMotion) {
        gsap.fromTo(
          navLinks,
          { opacity: 0, y: 28 },
          { opacity: 1, y: 0, stagger: 0.06, duration: 0.45, ease: 'power2.out', clearProps: 'all' }
        )
      }

      overlayClose?.focus()
      overlay.addEventListener('keydown', trapFocus)
    }

    function closeOverlay(): void {
      if (!overlay || !hamburger) return
      overlay.classList.remove('is-open')
      overlay.setAttribute('aria-hidden', 'true')
      hamburger.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
      overlay.removeEventListener('keydown', trapFocus)
      hamburger.focus()
    }

    hamburger?.addEventListener('click', openOverlay, { signal })
    overlayClose?.addEventListener('click', closeOverlay, { signal })

    // Close when any link inside the overlay is clicked
    overlay?.querySelectorAll<HTMLAnchorElement>('a').forEach(a =>
      a.addEventListener('click', closeOverlay, { signal })
    )

    // Auto-close mobile overlay when viewport resizes past md breakpoint
    window.matchMedia('(min-width: 768px)').addEventListener('change', e => {
      if (e.matches && overlay?.classList.contains('is-open')) closeOverlay()
    }, { signal } as AddEventListenerOptions)

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        if (overlay?.classList.contains('is-open')) closeOverlay()
        if (servicesDropdown?.classList.contains('is-open')) {
          servicesDropdown.classList.remove('is-open')
          servicesBtn?.classList.remove('is-open')
          servicesBtn?.setAttribute('aria-expanded', 'false')
          servicesBtn?.focus()
        }
      }
    }, { signal })

    // ── Desktop services dropdown (hover + click + gap-safe close delay) ─
    const openDropdown = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null }
      const alreadyOpen = servicesDropdown?.classList.contains('is-open')
      servicesDropdown?.classList.add('is-open')
      servicesBtn?.classList.add('is-open')
      servicesBtn?.setAttribute('aria-expanded', 'true')
      if (!reducedMotion && !alreadyOpen) {
        gsap.fromTo(
          '#services-dropdown .svc-card',
          { opacity: 0, y: 8 },
          { opacity: 1, y: 0, stagger: 0.025, duration: 0.28, ease: 'power2.out', clearProps: 'all' }
        )
      }
    }

    const scheduleClose = () => {
      closeTimer = setTimeout(() => {
        closeTimer = null
        servicesDropdown?.classList.remove('is-open')
        servicesBtn?.classList.remove('is-open')
        servicesBtn?.setAttribute('aria-expanded', 'false')
      }, 600)
    }

    servicesNav?.addEventListener('mouseenter', openDropdown, { signal })
    servicesNav?.addEventListener('mouseleave', scheduleClose, { signal })
    servicesDropdown?.addEventListener('mouseenter', openDropdown, { signal })
    servicesDropdown?.addEventListener('mouseleave', scheduleClose, { signal })

    // Click to toggle — enables keyboard users to open/close the dropdown
    servicesBtn?.addEventListener('click', (e) => {
      e.stopPropagation()
      const isOpen = servicesDropdown?.classList.contains('is-open')
      if (isOpen) scheduleClose()
      else openDropdown()
    }, { signal })

    // Click-outside: exclude both the trigger AND the dropdown panel (now siblings)
    document.addEventListener('click', (e) => {
      const target = e.target as Node
      if (!servicesNav?.contains(target) && !servicesDropdown?.contains(target)) {
        servicesDropdown?.classList.remove('is-open')
        servicesBtn?.classList.remove('is-open')
        servicesBtn?.setAttribute('aria-expanded', 'false')
      }
    }, { signal })

    // ── Mobile services accordion ────────────────────────────────────────
    servicesTgl?.addEventListener('click', () => {
      const expanded = servicesTgl.getAttribute('aria-expanded') === 'true'
      servicesTgl.setAttribute('aria-expanded', String(!expanded))
      if (servicesList) {
        if (expanded) {
          servicesList.classList.add('hidden')
          servicesList.classList.remove('flex')
        } else {
          servicesList.classList.remove('hidden')
          servicesList.classList.add('flex', 'flex-col')
        }
      }
      servicesTgl.querySelector('.mobile-services-chevron')?.classList.toggle('open')
    }, { signal })
  }

  document.addEventListener('astro:before-swap', cleanupNav)
  document.addEventListener('astro:page-load', initNav)
</script>
