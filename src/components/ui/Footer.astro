---
import { Image } from 'astro:assets'
import logoCompleteWhite from '@/assets/images/logos/logo-complete-white.png'

const year = new Date().getFullYear()
---

<footer class="relative overflow-hidden border-t" style="border-color: rgba(168, 85, 247, 0.15); background-color: var(--color-bg-deep);">
  <!-- Subtle background blobs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="blob absolute -bottom-32 -left-32 w-80 h-80 opacity-20" style="background: var(--color-purple-base);"></div>
    <div class="blob absolute -top-20 right-0 w-64 h-64 opacity-10" style="background: var(--color-pink);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 py-12">

      <!-- Brand + CTA -->
      <div class="md:col-span-4">
        <a href="/" aria-label="Nightious — Home" class="inline-block mb-4">
          <Image
            src={logoCompleteWhite}
            alt="Nightious"
            width={180}
            height={43}
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed mb-5" style="color: var(--color-text-muted);">
          IT & digital solutions for small businesses and content creators.
        </p>
        <a href="/contact" class="btn-ghost text-sm">
          Get a Free Quote →
        </a>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-2">
        <p class="font-display text-xs tracking-widest mb-4" style="color: var(--color-purple-mid);">NAVIGATE</p>
        <ul class="flex flex-col gap-2.5 list-none">
          <li><a href="/" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Home</a></li>
          <li><a href="/services" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">All Services</a></li>
          <li><a href="/for-businesses" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">For Businesses</a></li>
          <li><a href="/for-creators" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">For Creators</a></li>
          <li><a href="/for-individuals" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">For Individuals</a></li>
          <li><a href="/contact" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Contact</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <p class="font-display text-xs tracking-widest mb-4" style="color: var(--color-purple-mid);">SERVICES</p>
        <ul class="flex flex-col gap-2.5 list-none">
          <li><a href="/services/website-solutions" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Website Solutions</a></li>
          <li><a href="/services/ai-integration" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">AI Integration</a></li>
          <li><a href="/services/digital-marketing" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Digital Marketing</a></li>
          <li><a href="/services/computer-services" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Computer Services</a></li>
          <li><a href="/services/online-privacy" class="text-sm transition-colors hover:text-white" style="color: var(--color-text-muted);">Online Privacy</a></li>
          <li><a href="/services" class="text-xs transition-colors" style="color: var(--color-purple-mid);">View all 12 →</a></li>
        </ul>
      </div>

      <!-- Hours + Contact -->
      <div class="md:col-span-3">
        <p class="font-display text-xs tracking-widest mb-4" style="color: var(--color-purple-mid);">HOURS</p>
        <ul class="flex flex-col gap-2 list-none text-sm mb-5" style="color: var(--color-text-muted);">
          <li class="flex justify-between gap-4">
            <span>Mon – Fri</span>
            <span>2 PM – 11 PM</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Saturday</span>
            <span>9 AM – 11 PM</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Sunday</span>
            <span>12 PM – 11 PM</span>
          </li>
        </ul>
        <p class="text-xs mb-4" style="color: var(--color-text-muted);">All times EST</p>

        <address class="not-italic text-xs leading-relaxed mb-3" style="color: var(--color-text-muted);">
          7901 4th St N, Suite 300<br />
          St. Petersburg, FL 33702
        </address>

        <a
          href="https://www.linkedin.com/company/nightious"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nightious on LinkedIn"
          class="inline-flex items-center gap-2 text-xs transition-colors hover:text-white"
          style="color: var(--color-purple-light);"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6 border-t" style="border-color: rgba(168, 85, 247, 0.1);">
      <p class="text-xs" style="color: var(--color-text-muted);">
        &copy; {year} Nightious. All rights reserved.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <p class="text-xs" style="color: var(--color-text-muted);">
          Your information is private and never shared.
        </p>
        <div class="flex gap-4">
          <a href="/privacy" class="text-xs transition-colors hover:text-white" style="color: rgba(233, 213, 255, 0.80);">Privacy Policy</a>
          <a href="/terms" class="text-xs transition-colors hover:text-white" style="color: rgba(233, 213, 255, 0.80);">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
