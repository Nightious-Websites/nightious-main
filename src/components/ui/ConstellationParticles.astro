---
interface Props {
  density?: 'high' | 'medium' | 'low'
  colors?:  'purple-emerald' | 'purple-only' | 'accent'
  accentRgb?: string
  zIndex?:  number
}

const {
  density = 'high',
  colors  = 'purple-emerald',
  accentRgb = '',
  zIndex  = 3,
} = Astro.props

const counts = { high: 28, medium: 16, low: 8 }
const count  = counts[density]

// Generate a stable unique ID for the container so multiple instances on a
// page don't collide. We use a short random hex suffix baked in at build time.
const uid = Math.random().toString(36).slice(2, 8)
const containerId = `constellation-particles-${uid}`
---

<div
  id={containerId}
  class="constellation-particles"
  style={`z-index: ${zIndex};`}
  aria-hidden="true"
></div>

<style is:global>
  @keyframes particle-twinkle {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50%       { opacity: 0.9; transform: scale(1.5); }
  }
</style>

<style>
  .constellation-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
</style>

<script define:vars={{ containerId, count, colors, accentRgb }}>
  function spawnParticles() {
    const container = document.getElementById(containerId)
    if (!container) return

    // Clear existing particles from previous navigation or re-spawn
    while (container.firstChild) container.removeChild(container.firstChild)

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    for (let i = 0; i < count; i++) {
      const dot     = document.createElement('span')
      const size    = Math.random() < 0.3 ? 2 : 1
      const x       = Math.random() * 100
      const y       = Math.random() * 100
      const opacity = 0.15 + Math.random() * 0.4
      const delay   = Math.random() * 6
      const dur     = 3 + Math.random() * 4

      // Color selection based on prop
      let bgColor
      if (colors === 'accent' && accentRgb) {
        bgColor = `rgba(${accentRgb},${opacity})`
      } else if (colors === 'purple-only') {
        bgColor = `rgba(168,85,247,${opacity})`
      } else {
        // purple-emerald: ~40% emerald, ~60% purple
        bgColor = Math.random() > 0.6
          ? `rgba(34,197,94,${opacity})`
          : `rgba(168,85,247,${opacity})`
      }

      const animPart = reduced
        ? ''
        : `;animation:particle-twinkle ${dur}s ease-in-out ${delay}s infinite`

      dot.style.cssText = [
        'position:absolute',
        `left:${x}%`,
        `top:${y}%`,
        `width:${size}px`,
        `height:${size}px`,
        'border-radius:50%',
        `background:${bgColor}`,
        `opacity:${opacity}`,
      ].join(';') + animPart

      container.appendChild(dot)
    }
  }

  function clearParticles() {
    const container = document.getElementById(containerId)
    if (!container) return
    while (container.firstChild) container.removeChild(container.firstChild)
  }

  document.addEventListener('astro:page-load',    spawnParticles)
  document.addEventListener('astro:before-swap',  clearParticles)
</script>
