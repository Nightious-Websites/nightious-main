---
interface Props {
  title: string
  description: string
  slug: string
  category?: string
  image?: string
  keywords?: string[]
}

const { title, description, slug, category, image, keywords } = Astro.props

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `https://nightious.com/services/${slug}/#service`,
  "name": title,
  "description": description,
  "url": `https://nightious.com/services/${slug}`,
  "provider": {
    "@type": "Organization",
    "@id": "https://nightious.com/#organization",
    "name": "Nightious",
  },
  "areaServed": "Worldwide",
  "serviceType": category ?? "Technology Services",
  ...(image ? { "image": `https://nightious.com${image}` } : {}),
  ...(keywords?.length ? { "knowsAbout": keywords } : {}),
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
