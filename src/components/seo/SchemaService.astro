---
interface Props {
  title: string
  description: string
  slug: string
}

const { title, description, slug } = Astro.props

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": title,
  "description": description,
  "url": `https://nightious.com/services/${slug}`,
  "provider": {
    "@type": "Organization",
    "@id": "https://nightious.com/#organization",
    "name": "Nightious",
  },
  "areaServed": "Worldwide",
  "serviceType": title,
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
