---
import BaseLayout from './BaseLayout.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'

interface Props {
  title: string
  description: string
  slug: string
  category?: string
  ogImage?: string
  serviceImage?: string
  keywords?: string[]
  accentRgb?: string
}

const { title, description, slug, category, ogImage = '/images/og/og-service-page.png', serviceImage, keywords, accentRgb } = Astro.props

let bodyStyle: string | undefined
if (accentRgb) {
  const [r, g, b] = accentRgb.split(', ').map(Number)
  const bgDeep    = `rgb(${Math.max(1,Math.round(r*.035))},${Math.max(1,Math.round(g*.035))},${Math.max(1,Math.round(b*.035))})`
  const bgSection = `rgb(${Math.max(1,Math.round(r*.055))},${Math.max(1,Math.round(g*.055))},${Math.max(1,Math.round(b*.055))})`
  bodyStyle = `--color-bg-deep:${bgDeep};--color-bg-section:${bgSection};`
}

// Keep page title under 60 chars — short names get the full suffix; long ones drop "for Small Businesses"
const suffix = ' for Small Businesses | Nightious'
const shortSuffix = ' | Nightious'
const pageTitle =
  (title + suffix).length <= 60 ? title + suffix : title + shortSuffix

const breadcrumbItems = [
  { name: 'Home', url: 'https://nightious.com' },
  { name: 'Services', url: 'https://nightious.com/services' },
  { name: title, url: `https://nightious.com/services/${slug}` },
]
---

<BaseLayout
  title={pageTitle}
  description={description}
  ogImage={ogImage}
  bodyStyle={bodyStyle}
>
  <SchemaService title={title} description={description} slug={slug} category={category} image={serviceImage} keywords={keywords} />
  <SchemaBreadcrumb items={breadcrumbItems} />
  <slot />
</BaseLayout>
