---
import { ClientRouter } from 'astro:transitions'
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import SEO from '@/components/seo/SEO.astro'
import NavBar from '@/components/ui/NavBar.astro'
import Footer from '@/components/ui/Footer.astro'
import '@/styles/global.css'

interface Props {
  title: string
  description: string
  ogImage?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
  bodyStyle?: string
}

const { title, description, ogImage, ogType, noindex, bodyStyle } = Astro.props
const isProductionDeploy = process.env.VERCEL_ENV === 'production'
const hasVercelRuntime = process.env.VERCEL === '1'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Security meta tags -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com https://vercel.live; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; connect-src 'self' https://va.vercel-scripts.com https://vitals.vercel-insights.com https://vercel.live; frame-src 'self' https://vercel.live; object-src 'none'; form-action 'self'; base-uri 'self'; upgrade-insecure-requests;"
    />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />


    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/x-icon" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    {isProductionDeploy && <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />}

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    {hasVercelRuntime && <Analytics />}
    {hasVercelRuntime && <SpeedInsights />}
    <ClientRouter />
  </head>
  <body style={bodyStyle}>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <NavBar />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 9999;
    padding: 12px 24px;
    background: var(--color-purple-base, #7c3aed);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    border-radius: 0 0 8px 0;
  }
  .skip-link:focus {
    left: 0;
    top: 0;
  }
</style>

<script>
  import { initManagedAutoplayVideos, initVideoUpgrades } from '@/utils/media'

  function runPageInit() {
    initVideoUpgrades()
    initManagedAutoplayVideos()
  }

  document.addEventListener('astro:before-swap', () => {
    // Reset video initialization flags so new page videos reinitialize
    document.querySelectorAll('video[data-video-initialized]').forEach(v => {
      (v as HTMLVideoElement).pause()
      delete (v as HTMLVideoElement).dataset.videoInitialized
    })
    // Unload managed autoplay videos to prevent stale frame snapshots
    document.querySelectorAll('video[data-autoplay-managed]').forEach(v => {
      const vid = v as HTMLVideoElement
      vid.pause()
      vid.removeAttribute('src')
      vid.querySelectorAll('source').forEach(s => s.remove())
      vid.load()
    })
  })

  document.addEventListener('astro:page-load', runPageInit)

  window.addEventListener('load', () => {
    document.dispatchEvent(new Event('astro:page-load'))
  }, { once: true })
</script>
