---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import SEO from '@/components/seo/SEO.astro'
import NavBar from '@/components/ui/NavBar.astro'
import Footer from '@/components/ui/Footer.astro'
import '@/styles/global.css'

interface Props {
  title: string
  description: string
  ogImage?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
}

const { title, description, ogImage, ogType, noindex } = Astro.props
const isProductionDeploy = process.env.VERCEL_ENV === 'production'
const hasVercelRuntime = process.env.VERCEL === '1'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Security meta tags -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />


    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/x-icon" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    {isProductionDeploy && <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />}

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    {hasVercelRuntime && <Analytics />}
    {hasVercelRuntime && <SpeedInsights />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <NavBar />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 9999;
    padding: 12px 24px;
    background: var(--color-purple-base, #7c3aed);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    border-radius: 0 0 8px 0;
  }
  .skip-link:focus {
    left: 0;
    top: 0;
  }
</style>

<script>
  import { initManagedAutoplayVideos, initVideoUpgrades } from '@/utils/media'

  function runPageInit() {
    initVideoUpgrades()
    initManagedAutoplayVideos()
  }

  // Media runtime hooks
  document.addEventListener('astro:page-load', runPageInit)

  // Ensure component scripts listening to `astro:page-load` fire on full loads
  window.addEventListener('load', () => {
    document.dispatchEvent(new Event('astro:page-load'))
  }, { once: true })
</script>
