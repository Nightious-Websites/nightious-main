{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run preview -- --host 0.0.0.0 --port 4321",
      "url": [
        "http://localhost:4321/",
        "http://localhost:4321/services",
        "http://localhost:4321/services/ai-integration",
        "http://localhost:4321/services/computer-services",
        "http://localhost:4321/services/custom-services",
        "http://localhost:4321/services/digital-marketing",
        "http://localhost:4321/services/domain-solutions",
        "http://localhost:4321/services/email-solutions",
        "http://localhost:4321/services/online-privacy",
        "http://localhost:4321/services/organizational-effectiveness",
        "http://localhost:4321/services/software-services",
        "http://localhost:4321/services/streaming-consultation",
        "http://localhost:4321/services/training-documentation",
        "http://localhost:4321/services/website-solutions",
        "http://localhost:4321/contact",
        "http://localhost:4321/for-businesses",
        "http://localhost:4321/for-creators",
        "http://localhost:4321/for-individuals",
        "http://localhost:4321/blog",
        "http://localhost:4321/blog/welcome",
        "http://localhost:4321/privacy",
        "http://localhost:4321/terms"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "errors-in-console": "warn"
      }
    },
    "upload": {
      "target": "filesystem",
      "reportFilePath": "./lhci-report.json"
    }
  }
}
